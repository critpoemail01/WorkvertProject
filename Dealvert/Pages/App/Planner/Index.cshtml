@page
@model Alivert.Pages.App.Planner.IndexModel
@{
    ViewData["Title"] = "Nova campanha";
}

<section class="app-page-hero ai-planner-hero">
    <div>
        <span class="tag mb-3">Campaign builder</span>
        <h1 class="hero-title fw-bold mb-2">Configura uma campanha completa.</h1>
        <p class="lead muted mb-0">Adiciona o URL da empresa, publico-alvo e canais. A Promovert cria Business DNA, posts, emails, landing page, aprovacao, captacao de leads e relatorio.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Dashboard"><i class="bi bi-bar-chart me-1"></i>Dashboard</a>
    </div>
</section>

<div class="planner-layout mt-4">
    <form id="campaign-config" method="post" asp-page-handler="Generate" class="surface app-panel planner-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @if (!string.IsNullOrWhiteSpace(Model.SuggestionMessage))
        {
            <div class="alert alert-success mb-3">
                <i class="bi bi-magic me-1"></i>@Model.SuggestionMessage
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LeadDiscoveryMessage))
        {
            <div class="alert alert-info mb-3">
                <i class="bi bi-building-add me-1"></i>@Model.LeadDiscoveryMessage
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info mb-3">
                <i class="bi bi-info-circle me-1"></i>@Model.StatusMessage
            </div>
        }
        <div class="app-panel-header">
            <div>
                <h2>Configuracao da campanha</h2>
                <p>Comeca pelo URL. A Promovert sugere o briefing e tu ajustas antes de gerar posts para aprovacao.</p>
            </div>
        </div>
        <input asp-for="Input.DetectedApplicationType" type="hidden" />
        <input asp-for="Input.SelectedTemplateKey" type="hidden" data-selected-template-key />

        <div class="row g-3">
            <div class="col-12">
                <section id="mvp-funnel" class="mvp-funnel-panel">
                    <div>
                        <span class="tag">MVP recomendado</span>
                        <h3>Campanha completa de 14 dias</h3>
                        <p>Usa isto para manter a primeira versao focada: URL da empresa, Business DNA, 3 campanhas sugeridas, uma campanha escolhida, 5 posts LinkedIn, 5 posts Instagram, 3 emails, 1 landing page, links UTM, captacao de leads e dashboard simples.</p>
                    </div>
                    <div class="mvp-funnel-actions">
                        <button class="btn btn-outline-secondary" type="submit" formaction="?handler=UseMvp#mvp-funnel" formnovalidate>
                            <i class="bi bi-magic me-1"></i>Usar MVP
                        </button>
                        <span>Integracoes iniciais: LinkedIn, Instagram/Facebook, Brevo ou Mailchimp, Google Analytics/Pixel/UTM.</span>
                    </div>
                </section>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ProductName" class="form-label"></label>
                    <input asp-for="Input.ProductName" class="form-control" placeholder="Promovert, Acme CRM, faturacao com IA..." />
                <span asp-validation-for="Input.ProductName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ProductUrl" class="form-label"></label>
                <div class="planner-url-row">
                    <input asp-for="Input.ProductUrl" class="form-control" placeholder="https://app.example.com" />
                    <button class="btn btn-outline-secondary" type="submit" formaction="?handler=Suggest#campaign-config" formnovalidate>
                        <i class="bi bi-magic me-1"></i>Sugerir pelo URL
                    </button>
                </div>
                <div class="form-text">Usa isto para preencher automaticamente o briefing com base no website.</div>
                <span asp-validation-for="Input.ProductUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Input.CompanyOrIdea" class="form-label"></label>
                <textarea asp-for="Input.CompanyOrIdea" class="form-control" rows="3" placeholder="O que a empresa/app faz, modelo de negocio e fase atual"></textarea>
                <span asp-validation-for="Input.CompanyOrIdea" class="text-danger"></span>
            </div>
            @if (Model.CompanyLearning.HasData)
            {
                <div class="col-12">
                    <section class="company-learning-panel">
                        <div class="company-learning-head">
                            <span><i class="bi bi-graph-up-arrow"></i></span>
                            <div>
                                <h3>Aprendizagem da empresa</h3>
                                <p>@Model.CompanyLearning.Summary</p>
                            </div>
                        </div>
                        <div class="company-learning-grid">
                            <article>
                                <strong>@Model.CompanyLearning.CampaignsAnalyzed</strong>
                                <span>campanhas analisadas</span>
                            </article>
                            <article>
                                <strong>@Model.CompanyLearning.LeadsGenerated</strong>
                                <span>leads atribuidas</span>
                            </article>
                            <article>
                                <strong>@string.Join(", ", Model.CompanyLearning.PreferredPlatforms)</strong>
                                <span>canais preferidos</span>
                            </article>
                        </div>
                        <div class="company-learning-columns">
                            <div>
                                <strong>Esta empresa converte melhor com</strong>
                                @foreach (var pattern in Model.CompanyLearning.WinningPatterns)
                                {
                                    <span><i class="bi bi-check2"></i>@pattern</span>
                                }
                            </div>
                            <div>
                                <strong>Adaptacao da proxima campanha</strong>
                                @foreach (var adaptation in Model.CompanyLearning.RecommendedAdaptations)
                                {
                                    <span><i class="bi bi-arrow-repeat"></i>@adaptation</span>
                                }
                            </div>
                        </div>
                        <div class="company-learning-recommendation">
                            <i class="bi bi-stars"></i>
                            <span>@Model.CompanyLearning.RecommendedCampaignBrief</span>
                        </div>
                    </section>
                </div>
            }
            @if (Model.CampaignRecommendations.Any())
            {
                <div class="col-12">
                    <section id="campaign-library" class="campaign-library-panel">
                        <div class="lead-discovery-head">
                            <div>
                                <h3>Biblioteca de campanhas</h3>
                                <p class="form-text mb-0">Campanhas completas sugeridas com base no setor, sinais da empresa e objetivo. Escolhe uma ou usa a opcao customizada.</p>
                            </div>
                        </div>
                        <div class="campaign-library-grid">
                            @{
                                var customActive = Model.ActiveCampaignTemplateKey == "custom";
                            }
                            <article class="campaign-template-card custom @(customActive ? "is-active" : "")" data-campaign-template-card data-template-key="custom">
                                <span class="tag">Customizado</span>
                                <span class="campaign-active-badge" hidden="@(!customActive)"><i class="bi bi-check2"></i>Selecionada</span>
                                <h4>Campanha customizada</h4>
                                <p>Usa os campos da configuracao para definir objetivo, oferta, publico, canais, duracao e tracking sem aplicar um template de setor.</p>
                                <dl>
                                    <div><dt>Objetivo</dt><dd>definido por ti</dd></div>
                                    <div><dt>Oferta</dt><dd>usa a tua proposta de valor</dd></div>
                                    <div><dt>Canais</dt><dd>os canais selecionados abaixo</dd></div>
                                    <div><dt>Duracao</dt><dd>a duracao configurada</dd></div>
                                </dl>
                                <button class="btn btn-sm @(customActive ? "btn-primary" : "btn-outline-secondary")" type="button" data-campaign-template-button disabled="@customActive">
                                    @(customActive ? "Selecionada" : "Usar customizado")
                                </button>
                            </article>
                            @foreach (var recommendation in Model.CampaignRecommendations)
                            {
                                var templateActive = Model.ActiveCampaignTemplateKey == recommendation.Key;
                                <article class="campaign-template-card @(templateActive ? "is-active" : "")"
                                    data-campaign-template-card
                                    data-template-key="@recommendation.Key"
                                    data-template-sector="@recommendation.Sector"
                                    data-template-title="@recommendation.Title"
                                    data-template-strategy="@recommendation.Strategy"
                                    data-template-goal="@recommendation.Goal"
                                    data-template-offer="@recommendation.Offer"
                                    data-template-audience="@recommendation.Audience"
                                    data-template-duration="@recommendation.DurationDays"
                                    data-template-frequency="@recommendation.Frequency"
                                    data-template-platforms="@string.Join("|", recommendation.Platforms)">
                                    <span class="tag">@recommendation.Sector</span>
                                    <span class="campaign-active-badge" hidden="@(!templateActive)"><i class="bi bi-check2"></i>Selecionada</span>
                                    <h4>@recommendation.Title</h4>
                                    <p>@recommendation.Strategy</p>
                                    <dl>
                                        <div><dt>Objetivo</dt><dd>@recommendation.Goal</dd></div>
                                        <div><dt>Oferta</dt><dd>@recommendation.Offer</dd></div>
                                        <div><dt>Canais</dt><dd>@string.Join(" + ", recommendation.Platforms)</dd></div>
                                        <div><dt>Duracao</dt><dd>@recommendation.DurationDays dias</dd></div>
                                    </dl>
                                    <button class="btn btn-sm @(templateActive ? "btn-primary" : "btn-outline-secondary")" type="button" data-campaign-template-button disabled="@templateActive">
                                        @(templateActive ? "Selecionada" : "Aplicar campanha")
                                    </button>
                                </article>
                            }
                        </div>
                    </section>
                </div>
            }
            <div class="col-md-6">
                <label asp-for="Input.TargetAudience" class="form-label"></label>
                <textarea asp-for="Input.TargetAudience" class="form-control" rows="4" placeholder="Fundadores, clinicas locais, equipas B2B SaaS, ecommerce managers..."></textarea>
                <span asp-validation-for="Input.TargetAudience" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ValueProposition" class="form-label"></label>
                <textarea asp-for="Input.ValueProposition" class="form-control" rows="4" placeholder="Resultado principal, problema resolvido e porque devem agir"></textarea>
                <span asp-validation-for="Input.ValueProposition" class="text-danger"></span>
            </div>
            <div class="col-12">
                <section class="planner-location" data-location-targeting>
                    <div class="planner-location-head">
                        <div>
                            <label class="form-label mb-1">Regiao do publico</label>
                            <p class="form-text mb-0">Escolhe se a campanha e mundial, por pais ou por cidade com raio em km.</p>
                        </div>
                        <span class="planner-location-summary" data-location-summary>Campanha mundial</span>
                    </div>

                    <div class="planner-location-modes" role="radiogroup" aria-label="Audience region">
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="World" checked="@(Model.Input.AudienceLocationScope == "World")" />
                            <span><i class="bi bi-globe2"></i>Mundo</span>
                        </label>
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="Country" checked="@(Model.Input.AudienceLocationScope == "Country")" />
                            <span><i class="bi bi-flag"></i>Pais</span>
                        </label>
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="City" checked="@(Model.Input.AudienceLocationScope == "City")" />
                            <span><i class="bi bi-geo-alt"></i>Cidade + raio</span>
                        </label>
                    </div>
                    <span asp-validation-for="Input.AudienceLocationScope" class="text-danger"></span>

                    <div class="planner-location-grid mt-3">
                        <div class="planner-location-country" data-location-panel="country">
                            <label asp-for="Input.AudienceCountry" class="form-label"></label>
                            <input asp-for="Input.AudienceCountry" class="form-control" list="audienceCountryOptions" autocomplete="country-name" placeholder="Portugal, Espanha, Estados Unidos..." data-location-country />
                            <datalist id="audienceCountryOptions" data-location-country-list></datalist>
                            <div class="planner-location-autocomplete" data-location-country-menu hidden></div>
                            <span asp-validation-for="Input.AudienceCountry" class="text-danger"></span>
                        </div>
                        <div class="planner-location-city" data-location-panel="city">
                            <label asp-for="Input.AudienceCity" class="form-label"></label>
                            <input asp-for="Input.AudienceCity" class="form-control" list="audienceCityOptions" autocomplete="address-level2" placeholder="Lisboa, Porto, Madrid..." data-location-city />
                            <datalist id="audienceCityOptions" data-location-city-list></datalist>
                            <div class="planner-location-autocomplete" data-location-city-menu hidden></div>
                            <span asp-validation-for="Input.AudienceCity" class="text-danger"></span>
                        </div>
                        <div class="planner-location-city" data-location-panel="city">
                            <label asp-for="Input.AudienceRadiusKm" class="form-label"></label>
                            <div class="planner-radius-row">
                                <input asp-for="Input.AudienceRadiusKm" class="form-control" type="number" min="1" max="1000" step="1" data-location-radius />
                                <span>km</span>
                            </div>
                            <input class="form-range mt-2" type="range" min="1" max="250" step="1" value="@Math.Min(Model.Input.AudienceRadiusKm, 250)" data-location-radius-range />
                            <span asp-validation-for="Input.AudienceRadiusKm" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="planner-map-wrap mt-3" data-location-panel="city">
                        <div class="planner-map" data-location-map></div>
                        <div class="planner-map-meta">
                            <span>Clica no mapa para definir o centro da campanha.</span>
                            <span data-location-coordinates>Nenhum ponto selecionado.</span>
                        </div>
                    </div>

                    <input asp-for="Input.AudienceLatitude" type="hidden" data-location-lat />
                    <input asp-for="Input.AudienceLongitude" type="hidden" data-location-lng />
                    <span asp-validation-for="Input.AudienceLatitude" class="text-danger"></span>
                    <span asp-validation-for="Input.AudienceLongitude" class="text-danger"></span>
                </section>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.CampaignGoal" class="form-label"></label>
                <input asp-for="Input.CampaignGoal" class="form-control" list="campaignGoalOptions" placeholder="subscricoes, demos, compras..." />
                <datalist id="campaignGoalOptions">
                    @foreach (var goal in Model.GoalOptions)
                    {
                        <option value="@goal"></option>
                    }
                </datalist>
                <span asp-validation-for="Input.CampaignGoal" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Tone" class="form-label"></label>
                <input asp-for="Input.Tone" class="form-control" placeholder="direto, premium, educativo..." />
                <span asp-validation-for="Input.Tone" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.StartDate" class="form-label"></label>
                <input asp-for="Input.StartDate" class="form-control" type="date" />
                <span asp-validation-for="Input.StartDate" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.DurationDays" class="form-label"></label>
                <select asp-for="Input.DurationDays" class="form-select">
                    <option value="7">1 semana</option>
                    <option value="14">2 semanas</option>
                    <option value="30">1 mes</option>
                    <option value="60">2 meses</option>
                    <option value="90">3 meses</option>
                </select>
                <span asp-validation-for="Input.DurationDays" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Frequency" class="form-label"></label>
                <select asp-for="Input.Frequency" class="form-select">
                    <option value="Daily">Todos os dias</option>
                    <option value="Weekdays">Dias uteis</option>
                    <option value="ThreePerWeek">3 vezes por semana</option>
                    <option value="Weekly">Semanal</option>
                    <option value="Mvp14">MVP: 5 LinkedIn + 5 Instagram em 14 dias</option>
                </select>
                <span asp-validation-for="Input.Frequency" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Redes</label>
                <div class="planner-platforms">
                    @foreach (var platform in Model.PlatformOptions)
                    {
                        <label>
                            <input type="checkbox" name="Input.Platforms" value="@platform" checked="@Model.Input.Platforms.Contains(platform)" />
                            <span>@platform</span>
                        </label>
                    }
                </div>
                <span asp-validation-for="Input.Platforms" class="text-danger"></span>
            </div>
            <div class="col-12">
                <section class="lead-discovery-panel crm-optional-panel" data-crm-leads-panel>
                    <label class="crm-focus-toggle crm-optional-toggle">
                        <input asp-for="Input.UseCrmLeads" data-crm-leads-toggle />
                        <span>
                            <strong>Focar esta campanha em leads CRM importadas</strong>
                            <small>Opcional. Usa apenas quando a campanha deve trabalhar contactos ja importados pela equipa.</small>
                        </span>
                    </label>
                    <div class="crm-focus-grid crm-optional-fields mt-3 @(Model.Input.UseCrmLeads ? "is-open" : "")" data-crm-leads-fields aria-hidden="@(Model.Input.UseCrmLeads ? "false" : "true")">
                        <div class="crm-optional-info">
                            <label asp-for="Input.UseCrmLeads" class="form-label mb-1"></label>
                            <p class="form-text mb-0">@Model.CrmLeadEmails email@(Model.CrmLeadEmails == 1 ? "" : "s") de leads CRM disponivel@(Model.CrmLeadEmails == 1 ? "" : "s") depois dos filtros de consentimento/exclusao, a partir de @Model.CrmLeadCount contacto@(Model.CrmLeadCount == 1 ? "" : "s") importado@(Model.CrmLeadCount == 1 ? "" : "s").</p>
                            <p class="form-text mb-0 mt-2">A importacao CSV fica na area CRM leads; aqui apenas escolhes contactos que ja existem.</p>
                        </div>
                        <div class="crm-lead-picker">
                            <div class="crm-lead-picker-head">
                                <span>Leads importadas disponiveis</span>
                                <strong>@Model.AvailableCrmLeads.Count visiveis</strong>
                            </div>
                            @if (!Model.AvailableCrmLeads.Any())
                            {
                                <div class="empty-state compact">
                                    <i class="bi bi-database-x"></i>
                                    <span>Nao existem leads CRM disponiveis. Importa primeiro o CSV em CRM leads e volta para criar a campanha.</span>
                                </div>
                            }
                            else
                            {
                                <div class="crm-lead-list">
                                    @foreach (var lead in Model.AvailableCrmLeads)
                                    {
                                        var leadMeta = string.Join(" - ", new[] { lead.CompanyName, lead.Role, lead.Industry, lead.Country, lead.City, lead.Stage }.Where(x => !string.IsNullOrWhiteSpace(x)));
                                        <label class="crm-lead-option">
                                            <input type="checkbox" name="Input.SelectedCrmLeadIds" value="@lead.Id" checked="@Model.Input.SelectedCrmLeadIds.Contains(lead.Id)" />
                                            <span>
                                                <strong>@(string.IsNullOrWhiteSpace(lead.ContactName) ? lead.Email : lead.ContactName)</strong>
                                                <small>@lead.Email</small>
                                                @if (!string.IsNullOrWhiteSpace(leadMeta))
                                                {
                                                    <em>@leadMeta</em>
                                                }
                                            </span>
                                        </label>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <span asp-validation-for="Input.SelectedCrmLeadIds" class="text-danger"></span>
                </section>
            </div>
            <div class="col-12">
                <section id="lead-emails" class="lead-discovery-panel lead-email-builder">
                    <div class="lead-discovery-head">
                        <div>
                            <label asp-for="Input.EmailAudience" class="form-label mb-1"></label>
                            <p class="form-text mb-0">Escreve emails manualmente ou deixa a Promovert sugerir contactos publicos com base no produto, publico e localizacao.</p>
                        </div>
                        <button class="btn btn-outline-secondary" type="submit" formaction="?handler=SuggestLeadEmails#lead-emails" formnovalidate>
                            <i class="bi bi-search me-1"></i>Sugerir emails
                        </button>
                    </div>
                    <textarea asp-for="Input.EmailAudience" class="form-control mt-3" rows="5" placeholder="ana@example.com&#10;joao@example.com&#10;marketing@empresa.pt"></textarea>
                    <div class="form-text">Um email por linha. Os emails sugeridos ficam aqui para revisao antes de gerar a campanha.</div>
                    <span asp-validation-for="Input.EmailAudience" class="text-danger"></span>

                    @if (Model.LeadSearchQueries.Any() || Model.DiscoveredLeadEmails.Any() || Model.LeadDiscoveryWarnings.Any())
                    {
                        <div class="lead-discovery-results">
                            @if (Model.LeadSearchQueries.Any())
                            {
                                <div>
                                    <strong>Pesquisas de prospecao</strong>
                                    <div class="lead-query-list">
                                        @foreach (var query in Model.LeadSearchQueries)
                                        {
                                            <a href="@query.Url" target="_blank" rel="noopener">@query.Label <i class="bi bi-box-arrow-up-right"></i></a>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.DiscoveredLeadEmails.Any())
                            {
                                <div>
                                    <strong>Emails publicos encontrados</strong>
                                    <div class="lead-email-list">
                                        @foreach (var leadEmail in Model.DiscoveredLeadEmails)
                                        {
                                            <span>@leadEmail.Email <small>@leadEmail.SourceHost</small></span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.LeadDiscoveryWarnings.Any())
                            {
                                <div class="lead-discovery-warnings">
                                    @foreach (var warning in Model.LeadDiscoveryWarnings)
                                    {
                                        <span><i class="bi bi-info-circle"></i>@warning</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </section>
            </div>
        </div>

        <div class="alert-form-actions mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-stars me-1"></i>Gerar rascunhos de posts</button>
            <span class="muted">Reve os posts gerados e aprova ou rejeita cada um antes de agendar.</span>
        </div>
    </form>

    <aside class="surface app-panel planner-side">
        <span class="tag">O que e gerado</span>
        <div class="planner-feature">
            <i class="bi bi-rocket-takeoff"></i>
            <div>
                <strong>Funil MVP</strong>
                <span>14 dias com 5 posts LinkedIn, 5 posts Instagram, 3 emails, 1 landing page e tracking UTM.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-calendar2-week"></i>
            <div>
                <strong>Calendario de publicacao</strong>
                <span>Posts e scripts de video para cada rede selecionada ao longo do periodo.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-check2-square"></i>
            <div>
                <strong>Workflow de aprovacao</strong>
                <span>Reve rascunhos, aprova em massa, agenda conteudo aprovado e publica itens vencidos.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-envelope-paper"></i>
            <div>
                <strong>Sequencia de emails</strong>
                <span>Templates para dias diferentes, personalizados com placeholders de primeiro nome.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-building-add"></i>
            <div>
                <strong>Ideias de leads</strong>
                <span>Setores, cargos e pesquisas sugeridas para prospecao.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-window-stack"></i>
            <div>
                <strong>Landing page + formulario</strong>
                <span>Uma pagina de campanha capta leads depois da publicacao autorizada.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-database-add"></i>
            <div>
                <strong>Publico CRM</strong>
                <span>Leads CRM importadas podem ser o foco da campanha.</span>
            </div>
        </div>
    </aside>
</div>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Campanhas recentes</h2>
            <p>Abre uma campanha para aprovar, agendar ou rever os posts sugeridos.</p>
        </div>
    </div>

    @if (!Model.RecentPlans.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-stars"></i>
            <span>Ainda nao existem campanhas geradas.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Periodo</th>
                        <th>Regiao</th>
                        <th>Plataformas</th>
                        <th>Conteudo</th>
                        <th>Estado</th>
                        <th class="text-end">Acao</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var plan in Model.RecentPlans)
                {
                    <tr>
                        <td>@plan.ProductName</td>
                        <td>@plan.StartDate.ToString("MMM d") - @plan.EndDate.ToString("MMM d")</td>
                        <td>@plan.Location</td>
                        <td>@plan.Platforms.Replace(",", ", ")</td>
                        <td>@plan.Posts posts / @plan.Emails emails / landing page</td>
                        <td><span class="badge text-bg-secondary">@plan.Status</span></td>
                        <td class="text-end">
                            <div class="campaign-row-actions">
                                <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Details" asp-route-id="@plan.Id">Abrir</a>
                                <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#deletePlanModal-@plan.Id">Eliminar</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @foreach (var plan in Model.RecentPlans)
        {
            <div class="modal fade" id="deletePlanModal-@plan.Id" tabindex="-1" aria-labelledby="deletePlanModalLabel-@plan.Id" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content account-modal campaign-delete-modal">
                        <div class="modal-header border-0">
                            <div>
                                <span class="tag">Eliminar campanha</span>
                                <h2 class="modal-title h3 mt-2 mb-0" id="deletePlanModalLabel-@plan.Id">Eliminar @plan.ProductName?</h2>
                            </div>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fechar"></button>
                        </div>
                        <div class="modal-body">
                            <div class="campaign-delete-warning">
                                <span><i class="bi bi-exclamation-triangle"></i></span>
                                <div>
                                    <strong>Esta acao nao pode ser desfeita.</strong>
                                    <p>Vais apagar a campanha completa, incluindo posts, emails, landing page, leads captadas, sugestoes e historico associado a este plano.</p>
                                </div>
                            </div>
                            <dl class="campaign-delete-summary">
                                <div><dt>Estado</dt><dd>@plan.Status</dd></div>
                                <div><dt>Periodo</dt><dd>@plan.StartDate.ToString("MMM d") - @plan.EndDate.ToString("MMM d")</dd></div>
                                <div><dt>Canais</dt><dd>@plan.Platforms.Replace(",", ", ")</dd></div>
                                <div><dt>Conteudo</dt><dd>@plan.Posts posts / @plan.Emails emails</dd></div>
                            </dl>
                        </div>
                        <div class="modal-footer border-0 campaign-delete-actions">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@plan.Id">
                                <button class="btn btn-danger" type="submit"><i class="bi bi-trash3 me-1"></i>Eliminar campanha</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</section>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/alivert-location-targeting.js" asp-append-version="true"></script>
    <script>
        (() => {
            const library = document.querySelector('[data-selected-template-key]')?.closest('form')?.querySelector('#campaign-library');
            if (!library) return;

            const form = library.closest('form');
            const fields = {
                selectedTemplateKey: form.querySelector('[data-selected-template-key]'),
                detectedType: form.querySelector('[name="Input.DetectedApplicationType"]'),
                campaignGoal: form.querySelector('[name="Input.CampaignGoal"]'),
                valueProposition: form.querySelector('[name="Input.ValueProposition"]'),
                targetAudience: form.querySelector('[name="Input.TargetAudience"]'),
                companyOrIdea: form.querySelector('[name="Input.CompanyOrIdea"]'),
                durationDays: form.querySelector('[name="Input.DurationDays"]'),
                frequency: form.querySelector('[name="Input.Frequency"]'),
                tone: form.querySelector('[name="Input.Tone"]')
            };
            const cards = Array.from(library.querySelectorAll('[data-campaign-template-card]'));
            const platformInputs = Array.from(form.querySelectorAll('input[name="Input.Platforms"]'));

            const setValue = (input, value) => {
                if (!input || value === undefined || value === null) return;
                input.value = value;
                input.dispatchEvent(new Event('input', { bubbles: true }));
                input.dispatchEvent(new Event('change', { bubbles: true }));
            };

            const optionExists = (select, value) => {
                return select && Array.from(select.options).some((option) => option.value === value);
            };

            const setActiveCard = (activeCard) => {
                cards.forEach((card) => {
                    const active = card === activeCard;
                    card.classList.toggle('is-active', active);

                    const badge = card.querySelector('.campaign-active-badge');
                    if (badge) badge.hidden = !active;

                    const button = card.querySelector('[data-campaign-template-button]');
                    if (!button) return;

                    button.disabled = active;
                    button.classList.toggle('btn-primary', active);
                    button.classList.toggle('btn-outline-secondary', !active);
                    button.textContent = active
                        ? 'Selecionada'
                        : (card.dataset.templateKey === 'custom' ? 'Usar customizado' : 'Aplicar campanha');
                });
            };

            const applyTemplate = (card) => {
                const key = card.dataset.templateKey || 'custom';
                setValue(fields.selectedTemplateKey, key);
                setActiveCard(card);

                if (key === 'custom') {
                    setValue(fields.detectedType, 'Customizado');
                    return;
                }

                const baseValue = fields.valueProposition?.dataset.baseValue ?? fields.valueProposition?.value ?? '';
                if (fields.valueProposition && fields.valueProposition.dataset.baseValue === undefined) {
                    fields.valueProposition.dataset.baseValue = fields.valueProposition.value || '';
                }

                setValue(fields.campaignGoal, card.dataset.templateGoal || '');
                setValue(fields.detectedType, card.dataset.templateSector || '');
                setValue(fields.tone, `${(card.dataset.templateSector || '').toLowerCase()}, practical and conversion-focused`.slice(0, 80));

                const offer = card.dataset.templateOffer || '';
                setValue(fields.valueProposition, baseValue.trim() ? `${baseValue.trim()}. Campaign offer: ${offer}`.slice(0, 700) : offer.slice(0, 700));

                if (fields.targetAudience && !fields.targetAudience.value.trim()) {
                    setValue(fields.targetAudience, (card.dataset.templateAudience || '').slice(0, 700));
                }

                if (fields.companyOrIdea && !fields.companyOrIdea.value.trim()) {
                    setValue(fields.companyOrIdea, `${card.dataset.templateSector || 'Campaign'} campaign: ${card.dataset.templateStrategy || ''}`.slice(0, 400));
                }

                setValue(fields.durationDays, card.dataset.templateDuration || fields.durationDays?.value);
                const frequency = card.dataset.templateFrequency || 'ThreePerWeek';
                setValue(fields.frequency, optionExists(fields.frequency, frequency) ? frequency : 'ThreePerWeek');

                const platforms = (card.dataset.templatePlatforms || '')
                    .split('|')
                    .map((value) => value.trim().toLowerCase())
                    .filter(Boolean);
                platformInputs.forEach((input) => {
                    input.checked = platforms.includes(input.value.toLowerCase());
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                });
            };

            cards.forEach((card) => {
                const button = card.querySelector('[data-campaign-template-button]');
                if (!button) return;
                button.addEventListener('click', () => applyTemplate(card));
            });
        })();

        document.querySelectorAll('[data-crm-leads-panel]').forEach((panel) => {
            const toggle = panel.querySelector('[data-crm-leads-toggle]');
            const fields = panel.querySelector('[data-crm-leads-fields]');
            if (!toggle || !fields) return;

            const syncCrmFields = () => {
                fields.classList.toggle('is-open', toggle.checked);
                fields.setAttribute('aria-hidden', toggle.checked ? 'false' : 'true');
            };

            toggle.addEventListener('change', syncCrmFields);
            syncCrmFields();
        });
    </script>
}
