@page
@model Dealvert.Pages.App.Planner.IndexModel
@{
    ViewData["Title"] = "Opportunity reports";
}

<section class="app-page-hero product-hero">
    <div>
        <span class="tag mb-3">Opportunity reports</span>
        <h1 class="hero-title fw-bold mb-2">Scout a category every day and act only on useful price gaps.</h1>
        <p class="lead muted mb-0">Create a daily opportunity report from a product URL, category, country, city, trusted stores, and resale marketplaces.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-bell me-1"></i>View alerts</a>
    </div>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Daily category scouting</h2>
            <p>Dealvert keeps the workflow product-first: a real URL anchors the category, and the report compares trusted-store prices against resale benchmarks.</p>
        </div>
    </div>
    <div class="product-flow-grid">
        <article>
            <span><i class="bi bi-link-45deg"></i></span>
            <strong>Anchor URL</strong>
            <p>Start from Amazon.es or another product page to define the item family.</p>
        </article>
        <article>
            <span><i class="bi bi-geo-alt"></i></span>
            <strong>Local market</strong>
            <p>Set country, city, and category so shipping and resale context are realistic.</p>
        </article>
        <article>
            <span><i class="bi bi-shop"></i></span>
            <strong>Trusted stores</strong>
            <p>Restrict the report to stores you are willing to buy from.</p>
        </article>
        <article>
            <span><i class="bi bi-envelope-check"></i></span>
            <strong>Daily report</strong>
            <p>Receive price, store, margin, benchmark, and score in one email.</p>
        </article>
    </div>
</section>
