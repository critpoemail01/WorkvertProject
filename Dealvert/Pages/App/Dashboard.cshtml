@page
@model Dealvert.Pages.App.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="app-page-hero product-hero">
    <div>
        <span class="tag mb-3">Price radar</span>
        <h1 class="hero-title fw-bold mb-2">Dashboard</h1>
        <p class="lead muted mb-0">Summary of watched products, triggered alerts, sent emails, and plan capacity.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-bell me-1"></i>View alerts</a>
    </div>
</section>

<section class="surface dashboard-plan-card mt-4">
    <div class="dashboard-plan-main">
        <span class="app-stat-icon dashboard-plan-icon"><i class="bi @(Model.IsUnlimitedPlan ? "bi-stars" : "bi-wallet2")"></i></span>
        <div>
            <div class="app-stat-label">Current plan</div>
            <h2>@Model.PlanName</h2>
            <p>@Model.PlanDescription</p>
        </div>
    </div>
    <div class="dashboard-plan-usage">
        <div class="dashboard-plan-meter-head">
            <span>@Model.ActiveAlerts active alerts</span>
            <strong>@Model.PlanCapacityLabel</strong>
        </div>
        <div class="dashboard-plan-meter" aria-label="Plan usage">
            <span style="width:@Model.PlanUsagePercent%"></span>
        </div>
        <div class="dashboard-plan-meta">
            <span>@Model.PlanRemainingLabel</span>
            @if (Model.PlanExpiresOnUtc is not null && Model.IsUnlimitedPlan)
            {
                <span>Ends on @Model.PlanExpiresOnUtc.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
            }
        </div>
    </div>
    <div class="dashboard-plan-actions">
        <a class="btn btn-primary" asp-page="/App/Billing">Manage plan</a>
        <a class="btn btn-outline-secondary" asp-page="/Pricing">Compare plans</a>
    </div>
</section>

<div class="dashboard-stat-grid mt-4">
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-box-seam"></i></span>
        <div>
            <div class="app-stat-label">Watched products</div>
            <div class="app-stat-value">@Model.UniqueSymbols</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-bell-fill"></i></span>
        <div>
            <div class="app-stat-label">Active alerts</div>
            <div class="app-stat-value">@Model.ActiveAlerts</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-lightning-charge"></i></span>
        <div>
            <div class="app-stat-label">Signals 7 days</div>
            <div class="app-stat-value">@Model.TriggersLast7Days</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-envelope-check"></i></span>
        <div>
            <div class="app-stat-label">Failures 7 days</div>
            <div class="app-stat-value">@Model.FailedDeliveriesLast7Days</div>
        </div>
    </div>
</div>

<section class="surface app-panel product-opportunity-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Opportunity flow</h2>
            <p>Dealvert combines the source URL, trusted stores, region, and resale benchmark to decide when to notify you.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
    </div>

    <div class="product-flow-grid">
        <article>
            <span><i class="bi bi-link-45deg"></i></span>
            <strong>Product URL</strong>
            <p>Amazon.es or another store used as the starting reference.</p>
        </article>
        <article>
            <span><i class="bi bi-shield-check"></i></span>
            <strong>Trusted stores</strong>
            <p>Worten, Fnac, PcComponentes, MediaMarkt, and custom lists.</p>
        </article>
        <article>
            <span><i class="bi bi-arrow-repeat"></i></span>
            <strong>Resale market</strong>
            <p>OLX, Vinted, Wallapop, and other resale benchmarks.</p>
        </article>
        <article>
            <span><i class="bi bi-envelope-paper"></i></span>
            <strong>Actionable email</strong>
            <p>Price, store, margin, category, and check time.</p>
        </article>
    </div>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent alerts</h2>
            <p>Signals generated when the price or opportunity score matched the rule.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Log">Open history</a>
    </div>

    @if (!Model.LatestTriggers.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-bell"></i>
            <span>No signals yet. Create an alert and set a target price to start.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Product</th>
                        <th>Signal</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestTriggers)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.TriggeredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent deliveries</h2>
            <p>Emails, webhooks, and team channels used to deliver alerts.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Settings">Configure channels</a>
    </div>

    @if (!Model.LatestDeliveries.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-send"></i>
            <span>No delivery attempts yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Product</th>
                        <th>Channel</th>
                        <th>Status</th>
                        <th>Detail</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestDeliveries)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Channel</td>
                        <td>
                            @if (row.Status == "Sent")
                            {
                                <span class="badge text-bg-success">Sent</span>
                            }
                            else if (row.Status == "Failed")
                            {
                                <span class="badge text-bg-danger">Failed</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Skipped</span>
                            }
                        </td>
                        <td class="text-muted">@row.ErrorMessage</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
