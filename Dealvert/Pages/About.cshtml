@page
@model Alivert.Pages.AboutModel
@{
    ViewData["Title"] = "Sobre";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-megaphone-fill"></i>
            <span>Sobre a Promovert</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">Uma forma pratica de transformar empresas em campanhas mensuraveis.</h1>
          <p class="lead muted mb-4">
            A Promovert ajuda fundadores, PMEs e equipas comerciais a transformar um URL, empresa ou ideia de negocio em campanhas completas com posts, emails, landing page e relatorio.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Comecar gratis</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">Ver workflow</a>
          </div>
          <div class="micro-proof-row">
            <span><i class="bi bi-check2"></i> Campanha como unidade principal</span>
            <span><i class="bi bi-check2"></i> Criado para aquisicao</span>
            <span><i class="bi bi-check2"></i> Funil mensuravel</span>
          </div>
        </div>

        <div class="quote-card">
          <p class="mb-3">
            "Descreve o que vendes uma vez. A Promovert transforma isso em campanhas que alcancam, envolvem e convertem clientes."
          </p>
          <div class="d-flex align-items-center gap-2 muted">
            <i class="bi bi-shield-check"></i>
            <span>Campanhas primeiro. Vaidade depois.</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-compass"></i> Principios</span>
        <h2 class="section-title">Velocidade, clareza e crescimento mensuravel.</h2>
        <p class="section-copy">Cada parte do produto foi pensada para reduzir o tempo entre uma ideia comercial e uma campanha que gera dados reais.</p>
      </div>

      <div class="value-grid">
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-bullseye"></i></div>
          <h2>Resultado acima de volume</h2>
          <p class="mb-0">O dashboard foca-se em pessoas alcancadas, pessoas que interagiram e pessoas que converteram.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-wallet2"></i></div>
          <h2>Capacidade justa</h2>
          <p class="mb-0">Creditos servem lancamentos pontuais. O ilimitado serve equipas com campanhas continuas.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-globe2"></i></div>
          <h2>Workflow multicanal</h2>
          <p class="mb-0">Social, email, landing page, CRM e tracking vivem no mesmo fluxo de campanha.</p>
        </div>
      </div>
    </section>

    <div class="conversion-band mt-4">
      <div>
        <span class="tag mb-2">Experimenta primeiro</span>
        <h2 class="h3 fw-bold mb-2">Comeca com 5 creditos gratis.</h2>
        <p class="mb-0 muted">Cria uma campanha real, revê o dashboard e depois escolhe creditos ou ilimitado quando precisares de mais plataformas ativas.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Criar conta</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">Ver precos</a>
      </div>
    </div>
  </div>
</section>
