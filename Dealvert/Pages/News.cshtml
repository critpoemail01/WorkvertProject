@page
@model Dealvert.Pages.NewsModel
@{
    ViewData["Title"] = "News";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-megaphone-fill"></i>
            <span>Product updates</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">News, improvements, and next steps.</h1>
          <p class="lead muted mb-4">
            Follow the changes that make Dealvert faster to configure, easier to trust, and more useful for recurring price monitoring.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Create account</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View pricing</a>
          </div>
        </div>

        <div class="proof-panel">
          <div class="proof-row">
            <i class="bi bi-credit-card-2-front"></i>
            <div>
              <strong>Clear pricing</strong>
              <span>Credits, monthly unlimited, and annual unlimited in the same flow.</span>
            </div>
          </div>
          <div class="proof-row">
            <i class="bi bi-graph-up-arrow"></i>
            <div>
              <strong>Opportunity signals</strong>
              <span>Price, margin, benchmark, and category score show what deserves action.</span>
            </div>
          </div>
          <div class="proof-row">
            <i class="bi bi-send"></i>
            <div>
              <strong>Channel roadmap</strong>
              <span>More stores, marketplaces, and delivery channels will be added through trusted integrations.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-newspaper"></i> Latest notes</span>
        <h2 class="section-title">Updates with practical impact.</h2>
        <p class="section-copy">Every improvement should make product monitoring faster, pricing clearer, or alerts more reliable.</p>
      </div>

      <div class="news-grid">
        @foreach (var p in Model.Posts.OrderByDescending(x => x.DateUtc))
        {
          <article class="news-card">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
              <span class="tag">@p.Tag</span>
              <span class="muted small">@p.DateUtc.ToString("yyyy-MM-dd")</span>
            </div>
            <h2>@p.Title</h2>
            <p class="mb-0">@p.Excerpt</p>
          </article>
        }
      </div>
    </section>

    <div class="conversion-band mt-5">
      <div>
        <span class="tag mb-2">Follow from the inside</span>
        <h2 class="h3 fw-bold mb-2">The best way to see progress is to test the app.</h2>
        <p class="mb-0 muted">Create a free account, set product watches with 5 credits, and follow new features from the dashboard.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">How it works</a>
      </div>
    </div>
  </div>
</section>
