@page
@model Dealvert.Pages.HowItWorksModel
@{
    ViewData["Title"] = "How it works";
}

<section class="hero-section">
    <div class="container">
        <div class="page-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-diagram-3-fill"></i>
                        <span>From URL to actionable alert</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">Turn a product link into a regional price radar.</h1>
                    <p class="lead muted mb-4">
                        Dealvert reads the product URL, stores your region and category, compares trusted stores with resale benchmarks, and sends an email when the target price or margin is reached.
                    </p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View pricing</a>
                    </div>
                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> 5 free credits</span>
                        <span><i class="bi bi-check2"></i> URL, region, and margin rules</span>
                        <span><i class="bi bi-check2"></i> Daily opportunity reports</span>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-link-45deg"></i>
                        <div>
                            <strong>Start with the URL</strong>
                            <span>Paste an Amazon.es, Fnac, Worten, or other product page.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-geo-alt"></i>
                        <div>
                            <strong>Set the region</strong>
                            <span>Choose country, city, category, trusted stores, and resale marketplaces.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-bullseye"></i>
                        <div>
                            <strong>Define the rule</strong>
                            <span>Use a target price, a margin below target, or a daily opportunity score.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-envelope-check"></i>
                        <div>
                            <strong>Get the alert</strong>
                            <span>Receive the store, price, benchmark, margin, and check time by email or webhook.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5">
            <div class="section-header">
                <span class="section-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Main workflow</span>
                <h2 class="section-title">Every watch is built around one buying decision.</h2>
                <p class="section-copy">The product URL is the anchor. Region, trusted stores, resale sites, and margin rules decide when Dealvert should interrupt you.</p>
            </div>

            <div class="step-grid workflow-step-grid">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h2>Product URL</h2>
                    <p class="mb-0">Paste the product page you want to monitor.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h2>Region</h2>
                    <p class="mb-0">Add country and city so the watch reflects local stock and pricing.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h2>Category</h2>
                    <p class="mb-0">Use category reporting to discover similar opportunities each day.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">4</div>
                    <h2>Trusted stores</h2>
                    <p class="mb-0">Limit alerts to stores you are willing to buy from.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">5</div>
                    <h2>Resale benchmark</h2>
                    <p class="mb-0">Compare against OLX, Vinted, Wallapop, or your chosen resale sites.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">6</div>
                    <h2>Target and margin</h2>
                    <p class="mb-0">Trigger only when the price clears the buying rule you set.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">7</div>
                    <h2>Delivery window</h2>
                    <p class="mb-0">Keep alerts inside the days and hours when you can act.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">8</div>
                    <h2>History</h2>
                    <p class="mb-0">Review sent, skipped, and failed deliveries from one place.</p>
                </div>
            </div>
        </section>

        <section class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Recommended start</span>
                <h2 class="h3 fw-bold mb-2">Create one watch from an Amazon.es URL.</h2>
                <p class="mb-0 muted">Start with a product you already understand, then add daily reports for the categories you want to scout.</p>
            </div>
            <div class="conversion-actions">
                <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View pricing</a>
            </div>
        </section>
    </div>
</section>
