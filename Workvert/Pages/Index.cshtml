@page
@model Workvert.Pages.IndexModel
@{
    ViewData["Title"] = "Intelligent professional assistant";
}

<section class="hero-section product-landing">
    <div class="container">
        <div class="promo-strip mb-4">
            <div>
                <span class="promo-label">Workvert</span>
                <span class="promo-copy">AI for three types of necessities: find the right work, offer goods and services, or find someone who can do the service you need.</span>
            </div>
            <a class="promo-link" asp-page="/Pricing" asp-fragment="plans">View plans <i class="bi bi-arrow-right-short"></i></a>
        </div>

        <div class="surface hero-card product-landing-hero p-4 p-md-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-stars"></i>
                        <span>Three types of necessities. One solution.</span>
                    </div>

                    <h1 class="display-5 fw-bold hero-title mb-3">Find the right work, offer goods and services, or find someone who can do the service you need.</h1>
                    <p class="lead mb-4 muted">
                        Workvert helps people who want better work, people who can provide value, and people who need a reliable provider for a real service.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary btn-lg" asp-page="/App/Career/Index">Analyze profile</a>
                            <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Dashboard">Open dashboard</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                            <button type="button" class="btn btn-outline-secondary btn-lg" data-auth-open="login">Log in</button>
                        }
                    </div>

                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> Find the right work</span>
                        <span><i class="bi bi-check2"></i> Offer goods and services</span>
                        <span><i class="bi bi-check2"></i> Find a good provider</span>
                    </div>

                    <div class="hero-proof mt-4">
                        <div>
                            <strong>3</strong>
                            <span>types of necessities</span>
                        </div>
                        <div>
                            <strong>AI</strong>
                            <span>profile and request matching</span>
                        </div>
                        <div>
                            <strong>24/7</strong>
                            <span>future opportunity alerts</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="career-preview-panel">
                        <div class="career-preview-head">
                            <span class="badge badge-soft">Profile analyzed</span>
                            <span class="market-dot"></span>
                        </div>
                        <div class="career-preview-profile">
                            <span><i class="bi bi-person-vcard"></i></span>
                            <div>
                                <strong>Professional profile</strong>
                                <small>Skills / goals / location</small>
                            </div>
                        </div>
                        <div class="career-preview-row best">
                            <div>
                                <strong>Company work path</strong>
                                <small>Role fit, skills, and preferences</small>
                            </div>
                            <span>Match</span>
                        </div>
                        <div class="career-preview-row">
                            <div>
                                <strong>Independent work path</strong>
                                <small>Services, pricing, and proposal angle</small>
                            </div>
                            <span>Plan</span>
                        </div>
                        <div class="career-preview-alert">
                            <i class="bi bi-file-earmark-text-fill"></i>
                            <div>
                                <strong>Service request match</strong>
                                <span>Need, required skills, and professional type identified.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5 path-choice-section">
            <div class="section-header path-choice-section-header">
                <span class="section-eyebrow"><i class="bi bi-diagram-3"></i> Three types of necessities</span>
                <h2 class="section-title">Choose the need you have now. Use all three with one account.</h2>
                <p class="section-copy">Start with work, an offer, or a service request. Your account stays flexible and can run separate searches or alerts for each path.</p>
            </div>

            <div class="row g-4 path-choice-grid">
                <div class="col-md-4">
                    <article class="surface path-choice-card h-100">
                        <span class="path-choice-number">01</span>
                        <div class="path-choice-top">
                            <div class="path-choice-icon"><i class="bi bi-person-badge"></i></div>
                        </div>
                        <h3>I want to find the right work</h3>
                        <p>Match your profile to company roles, understand missing skills, and generate CV or application messages.</p>
                        <div class="path-choice-meta">
                            <span><i class="bi bi-check2"></i> Company work</span>
                            <span><i class="bi bi-check2"></i> Compatibility score</span>
                        </div>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Career/Index" asp-route-path="job">Start work path</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register" data-auth-return="/App/Career?path=job">Start work path</button>
                        }
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="surface path-choice-card h-100">
                        <span class="path-choice-number">02</span>
                        <div class="path-choice-top">
                            <div class="path-choice-icon"><i class="bi bi-cash-coin"></i></div>
                        </div>
                        <h3>I want to offer goods and services</h3>
                        <p>Turn skills, tools, goods, or services you can provide into sellable offers, pricing, and proposals.</p>
                        <div class="path-choice-meta">
                            <span><i class="bi bi-check2"></i> Self-employed work</span>
                            <span><i class="bi bi-check2"></i> Service offers</span>
                        </div>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Career/Index" asp-route-path="freelance">Start offer path</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register" data-auth-return="/App/Career?path=freelance">Start offer path</button>
                        }
                    </article>
                </div>
                <div class="col-md-4">
                    <article class="surface path-choice-card h-100">
                        <span class="path-choice-number">03</span>
                        <div class="path-choice-top">
                            <div class="path-choice-icon"><i class="bi bi-search-heart"></i></div>
                        </div>
                        <h3>I need someone who can do a good service</h3>
                        <p>Describe what you need and get the right professional type, required skills, and recommended provider profiles.</p>
                        <div class="path-choice-meta">
                            <span><i class="bi bi-check2"></i> Service request</span>
                            <span><i class="bi bi-check2"></i> Provider match</span>
                        </div>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Services/Index">Start request path</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register" data-auth-return="/App/Services">Start request path</button>
                        }
                    </article>
                </div>
            </div>

            <div class="path-choice-note mt-3">
                <i class="bi bi-arrow-repeat"></i>
                <span>One user can use all three necessity flows. Each choice can become a separate active search or alert later, but it never locks the account into one role.</span>
            </div>
        </section>

        <section class="mt-5 workvert-connects-section">
            <div class="section-header workvert-connects-header">
                <span class="section-eyebrow"><i class="bi bi-lightning-charge-fill"></i> What Workvert connects</span>
                <h2 class="section-title">
                    One platform connecting
                    <span>right work</span>
                    <span>valuable offers</span>
                    <span>reliable providers</span>
                </h2>
                <p class="section-copy">Profiles, offers, and requests become practical recommendations for the next action.</p>
            </div>

            <div class="row g-4 workvert-connects-grid">
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-person-lines-fill"></i></div>
                        <h5>Find the right work</h5>
                        <p class="mb-0 muted">Use your profile to find roles where your skills, experience, and goals can create value.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-cash-coin"></i></div>
                        <h5>Offer goods and services</h5>
                        <p class="mb-0 muted">Turn what you know, make, or deliver into sellable services, offers, and proposals.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-briefcase"></i></div>
                        <h5>Find a good provider</h5>
                        <p class="mb-0 muted">Describe a need and find the right professional, service, or solution provider for it.</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Choose your type</span>
                <h2 class="fw-bold mb-2">Use Workvert to find the right work, offer goods and services, or find someone who can do a good service.</h2>
                <p class="mb-0 muted">Start with your profile when you want work or want to offer value, or describe a request when you need someone to deliver a service well.</p>
            </div>
            <div class="conversion-actions">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" asp-page="/App/Career/Index">Analyze profile</a>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                }
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing" asp-fragment="plans">View plans</a>
            </div>
        </div>
    </div>
</section>
