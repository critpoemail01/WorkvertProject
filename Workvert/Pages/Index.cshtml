@page
@model Workvert.Pages.IndexModel
@{
    ViewData["Title"] = "URL price alerts";
}

<section class="hero-section product-landing">
    <div class="container">
        <div class="promo-strip mb-4">
            <div>
                <span class="promo-label">Deal radar</span>
                <span class="promo-copy">Track products by URL, compare trusted stores, and receive resale opportunities by email.</span>
            </div>
            <a class="promo-link" asp-page="/Pricing">View plans <i class="bi bi-arrow-right-short"></i></a>
        </div>

        <div class="surface hero-card product-landing-hero p-4 p-md-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-radar"></i>
                        <span>Price alerts and product arbitrage</span>
                    </div>

                    <h1 class="display-5 fw-bold hero-title mb-3">Workvert tells you when a product is cheap enough to buy.</h1>
                    <p class="lead mb-4 muted">
                        Paste an Amazon.es URL or another store link, choose a country, city, target price, and margin. Workvert watches trusted stores and emails you when it finds an opportunity.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary btn-lg" asp-page="/App/Alerts/Create">Create alert</a>
                            <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Dashboard">Open dashboard</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                            <button type="button" class="btn btn-outline-secondary btn-lg" data-auth-open="login">Log in</button>
                        }
                    </div>

                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> Product URL</span>
                        <span><i class="bi bi-check2"></i> Country, city, and category</span>
                        <span><i class="bi bi-check2"></i> Email at the right price</span>
                    </div>

                    <div class="hero-proof mt-4">
                        <div>
                            <strong>5</strong>
                            <span>free alerts</span>
                        </div>
                        <div>
                            <strong>24/7</strong>
                            <span>monitoring</span>
                        </div>
                        <div>
                            <strong>resale</strong>
                            <span>daily benchmark</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="deal-radar-panel">
                        <div class="deal-radar-head">
                            <span class="badge badge-soft">Active radar</span>
                            <span class="market-dot"></span>
                        </div>
                        <div class="deal-radar-product">
                            <span><i class="bi bi-link-45deg"></i></span>
                            <div>
                                <strong>amazon.es/dp/B0...</strong>
                                <small>Consoles · Lisbon, Portugal</small>
                            </div>
                        </div>
                        <div class="deal-radar-row best">
                            <div>
                                <strong>Amazon.es</strong>
                                <small>trusted store</small>
                            </div>
                            <span>EUR 389.90</span>
                        </div>
                        <div class="deal-radar-row">
                            <div>
                                <strong>OLX / Vinted</strong>
                                <small>resale benchmark</small>
                            </div>
                            <span>EUR 455.00</span>
                        </div>
                        <div class="deal-radar-alert">
                            <i class="bi bi-bell-fill"></i>
                            <div>
                                <strong>Margin found</strong>
                                <span>17% below benchmark. Email ready.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5">
            <div class="section-header">
                <span class="section-eyebrow"><i class="bi bi-stars"></i> How it works</span>
                <h2 class="section-title">From product page to the alert that matters.</h2>
                <p class="section-copy">Built for disciplined buying: target price, minimum margin, trusted stores, and a daily category report.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-link-45deg"></i></div>
                        <h5>Paste the URL</h5>
                        <p class="mb-0 muted">Start from a real product on Amazon.es, Fnac, Worten, PcComponentes, or another store.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-geo-alt"></i></div>
                        <h5>Set the region</h5>
                        <p class="mb-0 muted">Country, city, category, trusted stores, and resale marketplaces to compare.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-envelope-check"></i></div>
                        <h5>Get the signal</h5>
                        <p class="mb-0 muted">Email when the price hits the target, clears your margin, or the category shows opportunities.</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Best next step</span>
                <h2 class="fw-bold mb-2">Create your first alert with an Amazon.es URL.</h2>
                <p class="mb-0 muted">Start with a product you already want to buy or resell. Then add daily category reports.</p>
            </div>
            <div class="conversion-actions">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" asp-page="/App/Alerts/Create">New alert</a>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                }
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View plans</a>
            </div>
        </div>
    </div>
</section>
