@page
@model Workvert.Pages.PricingModel
@{
    ViewData["Title"] = "Plans";
}

<section class="hero-section">
    <div class="container">
        <div class="promo-strip mb-4">
            <div>
                <span class="promo-label">Launch offer</span>
                <span class="promo-copy">Unlimited professional recommendations for EUR 49.99/month or EUR 299/year.</span>
            </div>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a class="promo-link" asp-page="/App/Billing">Open billing <i class="bi bi-arrow-right-short"></i></a>
            }
            else
            {
                <button type="button" class="promo-link promo-button" data-auth-open="register">Create account <i class="bi bi-arrow-right-short"></i></button>
            }
        </div>

        <div class="page-hero pricing-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-credit-card-2-front-fill"></i>
                        <span>Plans for professional growth</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">Start free and scale when you want to automate opportunities.</h1>
                    <p class="lead muted mb-4">1 paid credit = 1 active professional search for 30 days. Use it for jobs, freelancing, service requests, or personalized alerts.</p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start with 5 free credits</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">How it works</a>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-gift"></i>
                        <div>
                            <strong>Free account first</strong>
                            <span>Validate your profile, recommendations, and professional copy before paying.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-wallet2"></i>
                        <div>
                            <strong>Credits for occasional use</strong>
                            <span>Packs of 25, 50, and 100 credits for active searches and alerts.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-stars"></i>
                        <div>
                            <strong>Annual is best value</strong>
                            <span>EUR 299/year saves more than 50% compared with monthly billing.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-4 pricing-grid" id="plans">
            <div class="col-lg-3">
                <div class="surface plan">
                    <div class="plan-title">Free</div>
                    <div class="plan-price mt-2">EUR 0</div>
                    <div class="muted mt-2">Validate the flow before paying.</div>

                    <ul class="mt-3 muted">
                        <li>5 credits for active professional searches</li>
                        <li>Profile analysis and suggested skills</li>
                        <li>Resume, LinkedIn, and base messages</li>
                    </ul>

                    <div class="plan-footer">
                        <button type="button" class="btn btn-outline-secondary w-100" data-auth-open="register">Create free account</button>
                        <div class="plan-footer-note" aria-hidden="true"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Credit packs</div>
                        <span class="plan-badge"><i class="bi bi-wallet2"></i> Flexible</span>
                    </div>

                    <div class="plan-price mt-2">from EUR 24.99</div>
                    <div class="muted mt-2">Buy capacity only when you need it.</div>

                    <ul class="mt-3 muted">
                        <li>25 credits for EUR 24.99</li>
                        <li>50 credits for EUR 34.99</li>
                        <li>100 credits for EUR 49.99</li>
                        <li>Credits stay active for 30 days after payment</li>
                        <li>Job, freelance, and service searches</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Buy credits</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Buy credits</button>
                        }
                        <div class="plan-footer-note small muted text-center">Capacity stays active for 30 days.</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan plan-highlight">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Monthly unlimited</div>
                        <span class="plan-badge"><i class="bi bi-arrow-repeat"></i> Monthly</span>
                    </div>

                    <div class="plan-price mt-2">EUR 49.99<span class="fs-6 muted">/month</span></div>
                    <div class="muted mt-2">For users who want to track opportunities continuously.</div>

                    <ul class="mt-3 muted">
                        <li>Unlimited active professional searches</li>
                        <li>Jobs, freelancing, services, and career planning</li>
                        <li>Notifications and reports when available</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Subscribe monthly</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Subscribe monthly</button>
                        }
                        <div class="plan-footer-note small muted text-center">Monthly access starts after payment confirmation.</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan plan-highlight">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Annual unlimited</div>
                        <span class="plan-badge plan-badge-warm"><i class="bi bi-stars"></i> Best value</span>
                    </div>

                    <div class="plan-price mt-2">EUR 299<span class="fs-6 muted">/year</span></div>
                    <div class="muted mt-2">Pay once per year and reduce the monthly cost of continuous use.</div>

                    <ul class="mt-3 muted">
                        <li>Unlimited professional searches for 1 year</li>
                        <li>All professional recommendation types</li>
                        <li>Best option for recurring monitoring</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Subscribe annually</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Subscribe annually</button>
                        }
                        <div class="plan-footer-note small muted text-center">Annual access starts after payment confirmation.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Still deciding?</span>
                <h2 class="h3 fw-bold mb-2">Start free. Pay only when usage becomes recurring.</h2>
                <p class="mb-0 muted">Most users validate profile analysis, resume copy, and opportunity matching first.</p>
            </div>
            <div class="conversion-actions">
                <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">How it works</a>
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" asp-page="/App/Billing">Go to billing</a>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                }
            </div>
        </div>
    </div>
</section>
