@page
@model Workvert.Pages.HowItWorksModel
@{
    ViewData["Title"] = "How it works";
}

<section class="hero-section">
    <div class="container">
        <div class="page-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-diagram-3-fill"></i>
                        <span>Three types of necessities, one recommendation engine</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">Workvert helps people find the right work, offer goods and services, or find a good provider.</h1>
                    <p class="lead muted mb-4">
                        Use a profile to find work or offer value, or describe a need to find someone who can do a good service.
                    </p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing" asp-fragment="plans">View plans</a>
                    </div>
                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> Find work</span>
                        <span><i class="bi bi-check2"></i> Offer goods and services</span>
                        <span><i class="bi bi-check2"></i> Find a provider</span>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-person-lines-fill"></i>
                        <div>
                            <strong>1. Choose the necessity</strong>
                            <span>Find the right work, offer value, or request a good service.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-stars"></i>
                        <div>
                            <strong>2. Analyze with AI</strong>
                            <span>Profile data or service needs are turned into structured requirements.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-briefcase"></i>
                        <div>
                            <strong>3. Recommend the match</strong>
                            <span>The right work, provider, service, or professional profile.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-send"></i>
                        <div>
                            <strong>4. Act better</strong>
                            <span>CV text, application messages, proposals, briefs, and next steps.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5 how-workflow-section">
            <div class="section-header how-workflow-header">
                <span class="section-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Main workflow</span>
                <h2 class="section-title">
                    Three paths.
                    <span>One account.</span>
                    <span>Clear next action.</span>
                </h2>
                <p class="section-copy">Start from a profile or a service request. Workvert structures the need, checks fit, and turns it into useful recommendations.</p>
            </div>

            <div class="step-grid workflow-step-grid">
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">01</div>
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <h2>Find right work</h2>
                    <p class="mb-0">Match skills, experience, education, languages, tools, and goals to ways of creating value.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">02</div>
                        <i class="bi bi-stars"></i>
                    </div>
                    <h2>Skill fit</h2>
                    <p class="mb-0">Identify strengths and missing skills that affect compatibility with company roles.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">03</div>
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <h2>Work model</h2>
                    <p class="mb-0">Worldwide, country, region, city, remote, on-site, hybrid, fixed job, or freelance.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">04</div>
                        <i class="bi bi-speedometer2"></i>
                    </div>
                    <h2>Compatibility</h2>
                    <p class="mb-0">Score and explanation for each job, project, service idea, or professional recommendation.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">05</div>
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <h2>Offer goods/services</h2>
                    <p class="mb-0">Sellable goods, services, suggested price, target client, and commercial proposal from your skills.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">06</div>
                        <i class="bi bi-search-heart"></i>
                    </div>
                    <h2>Find a good provider</h2>
                    <p class="mb-0">Request analysis and recommendation of the provider type, required skills, and suitable profiles.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">07</div>
                        <i class="bi bi-file-earmark-text"></i>
                    </div>
                    <h2>Action plan</h2>
                    <p class="mb-0">CV, proposal, brief, skill gaps, and concrete next steps according to the selected path.</p>
                </div>
                <div class="step-card workflow-step-card">
                    <div class="workflow-step-head">
                        <div class="step-number">08</div>
                        <i class="bi bi-broadcast-pin"></i>
                    </div>
                    <h2>Notifications</h2>
                    <p class="mb-0">Email, push, SMS, WhatsApp, or integrated channels when relevant opportunities appear.</p>
                </div>
            </div>
        </section>

        <section class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Recommended start</span>
                <h2 class="h3 fw-bold mb-2">Choose whether you want work, want to offer goods or services, or need someone to do a service.</h2>
                <p class="mb-0 muted">Start from a profile when you want work or want to offer value, or from a request when you need a provider.</p>
            </div>
            <div class="conversion-actions">
                <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing" asp-fragment="plans">View plans</a>
            </div>
        </section>
    </div>
</section>
