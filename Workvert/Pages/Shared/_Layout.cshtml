@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.Extensions.Configuration
@inject IAntiforgery Antiforgery
@inject IConfiguration Configuration
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
    var googleConfigured = !string.IsNullOrWhiteSpace(Configuration["Authentication:Google:ClientId"]) &&
        !string.IsNullOrWhiteSpace(Configuration["Authentication:Google:ClientSecret"]);
    var currentPath = (Context.Request.Path.Value ?? "/").TrimEnd('/');
    currentPath = string.IsNullOrWhiteSpace(currentPath) ? "/" : currentPath;
    var isActive = (string pagePath) =>
        currentPath.Equals(pagePath, StringComparison.OrdinalIgnoreCase) ||
        (pagePath == "/Index" && currentPath == "/");
    var isActivePrefix = (string pagePath) =>
        currentPath.StartsWith(pagePath, StringComparison.OrdinalIgnoreCase);
    var pricingActive = isActive("/Pricing");
    var howItWorksActive = isActive("/HowItWorks");
    var aboutActive = isActive("/About");
    var newsActive = isActive("/News");
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Workvert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/workvert_favicon.svg" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/brand/workvert_favicon_32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="512x512" href="~/assets/brand/workvert_icon_512_clean.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="csrf-token" content="@tokens.RequestToken" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg workvert-nav">
        <div class="container-fluid public-nav-inner">
            <a class="navbar-brand brand-lockup" asp-page="/Index" aria-label="Workvert home">
                <span class="brand-mark">
                    <img src="~/assets/brand/workvert_brand_mark.svg" width="42" height="42" asp-append-version="true" alt="" />
                </span>
                <span class="brand-wordmark">
                    <span class="brand-title">Workvert<sup>TM</sup></span>
                    <span class="brand-subtitle">Work and Services AI</span>
                </span>
            </a>
            <button class="navbar-toggler workvert-menu-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Open navigation menu">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav public-nav-links me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link @(pricingActive ? "active" : "")" asp-page="/Pricing" aria-current="@(pricingActive ? "page" : null)"><i class="bi bi-credit-card-2-front"></i><span>Plans</span></a></li>
                    <li class="nav-item"><a class="nav-link @(howItWorksActive ? "active" : "")" asp-page="/HowItWorks" aria-current="@(howItWorksActive ? "page" : null)"><i class="bi bi-diagram-3"></i><span>How it works</span></a></li>
                    <li class="nav-item"><a class="nav-link @(aboutActive ? "active" : "")" asp-page="/About" aria-current="@(aboutActive ? "page" : null)"><i class="bi bi-info-circle"></i><span>About</span></a></li>
                    <li class="nav-item"><a class="nav-link @(newsActive ? "active" : "")" asp-page="/News" aria-current="@(newsActive ? "page" : null)"><i class="bi bi-megaphone"></i><span>News</span></a></li>

                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<main class="public-main @(isActive("/Index") ? "homepage-main" : "")">
    @RenderBody()
</main>

<footer class="footer site-footer" id="site-footer">
    <div class="container">
        <div class="footer-main">
            <div class="footer-brand-panel">
                <a class="brand-lockup footer-brand" asp-page="/Index" aria-label="Workvert home">
                    <span class="brand-mark footer-brand-mark">
                        <img src="~/assets/brand/workvert_brand_mark.svg" width="48" height="48" asp-append-version="true" alt="" />
                    </span>
                    <span class="brand-wordmark">
                        <span class="brand-title">Workvert<sup>TM</sup></span>
                        <span class="brand-subtitle">Work and Services AI</span>
                    </span>
                </a>
                <p>AI for three types of necessities: find the right work, offer goods and services, or find someone who can do a good service.</p>
                <div class="footer-badges">
                    <span><i class="bi bi-stars"></i> Professional AI</span>
                    <span><i class="bi bi-shield-check"></i> Secure area</span>
                </div>
            </div>

            <nav class="footer-nav-grid" aria-label="Footer navigation">
                <div>
                    <h2>Product</h2>
                    <a class="footer-link" asp-page="/Pricing">Plans</a>
                    <a class="footer-link" asp-page="/HowItWorks">How it works</a>
                    <a class="footer-link" asp-page="/News">News</a>
                </div>
                <div>
                    <h2>Platform</h2>
                    <a class="footer-link" asp-page="/About">About</a>
                    <a class="footer-link" asp-page="/App/HelpDesk">Help</a>
                    <a class="footer-link" asp-page="/App/Settings">Notifications</a>
                </div>
                <div>
                    <h2>Account</h2>
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a class="footer-link" asp-page="/App/Dashboard">Dashboard</a>
                        <a class="footer-link" asp-page="/App/Career/Index">Profile and AI</a>
                        <a class="footer-link" asp-page="/App/Billing">Subscription</a>
                    }
                    else
                    {
                        <button type="button" class="footer-link footer-button-link" data-auth-open="register">Create account</button>
                        <button type="button" class="footer-link footer-button-link" data-auth-open="login">Log in</button>
                        <a class="footer-link" asp-page="/Pricing" asp-fragment="plans">Compare plans</a>
                    }
                </div>
            </nav>
        </div>

        <div class="footer-bottom">
            <span>&copy; @DateTime.Now.Year Workvert. All rights reserved.</span>
            <span>Find work, offer value, or find the right provider.</span>
        </div>
    </div>
</footer>

<!-- Auth modal (login/register) -->
<div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered auth-modal">
    <div class="modal-content">
      <button type="button" class="auth-close" data-bs-dismiss="modal" aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>

      <div class="auth-shell">
        <section class="auth-form-panel">
          <div class="auth-brand-row">
            <span class="brand-mark brand-mark-sm">
              <img src="~/assets/brand/workvert_brand_mark.svg" width="36" height="36" asp-append-version="true" alt="" />
            </span>
            <span class="brand-wordmark">
              <span class="brand-title">Workvert<sup>TM</sup></span>
              <span class="brand-subtitle">Work and Services AI</span>
            </span>
            <span class="auth-security-badge">Secure access</span>
          </div>

          <ul class="nav nav-pills auth-tabs" id="authTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tab-register" data-bs-toggle="pill" data-bs-target="#pane-register" type="button" role="tab">
                Create account
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="tab-login" data-bs-toggle="pill" data-bs-target="#pane-login" type="button" role="tab">
                Log in
              </button>
            </li>
          </ul>

          <div class="tab-content">
            <div class="tab-pane fade show active" id="pane-login" role="tabpanel">
              <div class="auth-copy">
                <h2>Welcome back</h2>
                <p>Log in to manage your profile, recommendations, proposals, and notifications.</p>
              </div>

              <div id="loginError" class="alert alert-danger d-none" role="alert"></div>
              <form id="loginForm" class="auth-form" method="post" autocomplete="on">
                <input type="hidden" name="ReturnUrl" id="loginReturnUrl" />
                <div class="mb-3">
                  <label class="form-label" for="authLoginEmail">Email</label>
                  <div class="auth-field">
                    <i class="bi bi-envelope"></i>
                    <input id="authLoginEmail" name="Email" type="email" class="form-control" placeholder="you@example.com" required />
                  </div>
                </div>
                <div class="mb-2">
                  <label class="form-label" for="authLoginPassword">Password</label>
                  <div class="auth-field">
                    <i class="bi bi-lock"></i>
                    <input id="authLoginPassword" name="Password" type="password" class="form-control" placeholder="Your password" required />
                  </div>
                </div>
                <div class="auth-options">
                  <label class="form-check">
                    <input class="form-check-input" type="checkbox" name="RememberMe" />
                    <span class="form-check-label">Remember me</span>
                  </label>
                  <a class="small" asp-area="Identity" asp-page="/Account/ForgotPassword">Forgot your password?</a>
                </div>
                <button class="btn btn-primary auth-submit" type="submit">
                  <i class="bi bi-box-arrow-in-right"></i>
                  Log in
                </button>
                <a class="btn auth-google @(googleConfigured ? "" : "disabled")" href="/auth/google" data-google-auth aria-disabled="@(!googleConfigured)">
                  <i class="bi bi-google"></i> Continue with Google
                </a>
                @if (!googleConfigured)
                {
                    <div class="auth-provider-note">
                      <i class="bi bi-info-circle"></i>
                      Google login needs Authentication:Google credentials.
                    </div>
                }
              </form>
            </div>

            <div class="tab-pane fade" id="pane-register" role="tabpanel">
              <div class="auth-copy">
                <h2>Create your account</h2>
                <p>Start free and use Workvert to find work, offer goods and services, or request a good provider.</p>
              </div>

              <div id="registerError" class="alert alert-danger d-none" role="alert"></div>
              <form id="registerForm" class="auth-form" method="post" autocomplete="on">
                <input type="hidden" name="ReturnUrl" id="registerReturnUrl" />
                <div class="mb-3">
                  <label class="form-label" for="authRegisterEmail">Email</label>
                  <div class="auth-field">
                    <i class="bi bi-envelope"></i>
                    <input id="authRegisterEmail" name="Email" type="email" class="form-control" placeholder="you@example.com" required />
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label" for="authRegisterPassword">Password</label>
                  <div class="auth-field">
                    <i class="bi bi-lock"></i>
                    <input id="authRegisterPassword" name="Password" type="password" class="form-control" minlength="6" placeholder="Minimum 6 characters" required />
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label" for="authRegisterConfirm">Confirm password</label>
                  <div class="auth-field">
                    <i class="bi bi-shield-check"></i>
                    <input id="authRegisterConfirm" name="ConfirmPassword" type="password" class="form-control" minlength="6" placeholder="Repeat password" required />
                  </div>
                </div>
                <div class="auth-terms">
                  By creating an account, you accept the terms and privacy policy.
                </div>
                <button class="btn btn-primary auth-submit" type="submit">
                  <i class="bi bi-person-plus"></i>
                  Create account
                </button>
                <a class="btn auth-google @(googleConfigured ? "" : "disabled")" href="/auth/google" data-google-auth aria-disabled="@(!googleConfigured)">
                  <i class="bi bi-google"></i> Continue with Google
                </a>
              </form>
            </div>
          </div>
        </section>

        <aside class="auth-aside">
          <div class="auth-aside-badge">
            <i class="bi bi-lightning-charge-fill"></i>
            Work and services AI
          </div>
          <h3>One system for three types of necessities: right work, valuable offers, and reliable service providers.</h3>
          <p>Match your profile to the right work, turn skills into goods or services, or describe a request and find the right provider.</p>

          <div class="auth-metric-grid">
            <div>
              <span>5</span>
              <small>free analyses</small>
            </div>
            <div>
              <span>EUR 49.99</span>
              <small>monthly unlimited</small>
            </div>
          </div>

          <div class="auth-aside-list">
            <div><i class="bi bi-check2"></i> Find the right work from your profile</div>
            <div><i class="bi bi-check2"></i> Offer goods and services from your skills</div>
            <div><i class="bi bi-check2"></i> Find someone who can do a good service</div>
          </div>
        </div>
        </aside>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/workvert-nav.js" asp-append-version="true"></script>
<script src="~/js/workvert-auth.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
