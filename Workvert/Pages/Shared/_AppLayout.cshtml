@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isActive = (string pagePath) => currentPath.Equals(pagePath, StringComparison.OrdinalIgnoreCase);
    var isActivePrefix = (string pagePath) => currentPath.StartsWith(pagePath, StringComparison.OrdinalIgnoreCase);
    var isCareerArea = isActivePrefix("/App/Career");
    var isServiceArea = isActivePrefix("/App/Services");
    var pageTitle = ViewData["Title"]?.ToString() ?? "Workspace";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Workvert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/workvert_favicon.svg" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/brand/workvert_favicon_32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="512x512" href="~/assets/brand/workvert_icon_512_clean.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
<div class="app-shell">
    <header class="app-topbar">
        <div class="app-topbar-brandline">
            <a class="brand-lockup app-topbar-brand" asp-page="/Index" aria-label="Workvert home">
                <span class="brand-mark">
                    <img src="~/assets/brand/workvert_brand_mark.svg" width="42" height="42" asp-append-version="true" alt="" />
                </span>
                <span class="brand-wordmark">
                    <span class="brand-title">Workvert<sup>TM</sup></span>
                    <span class="brand-subtitle">Work and Services AI</span>
                </span>
            </a>
            <div class="app-topbar-title">
                <span class="app-topbar-kicker"><i class="bi bi-command"></i> Workspace</span>
                <strong>@pageTitle</strong>
            </div>
        </div>
        <div class="app-topbar-account">
            <span class="app-topbar-greeting">
                <i class="bi bi-person-circle"></i>
                Hello, @(User?.Identity?.Name ?? "Account")
            </span>
            @await Component.InvokeAsync("AppPlanBadge")
            <div class="app-topbar-plan-action">
                @await Component.InvokeAsync("AppPlanCta")
            </div>
            <a class="btn btn-sm btn-outline-secondary app-topbar-site-link" asp-page="/Index">
                <i class="bi bi-arrow-left me-1"></i>Back to site
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")" method="post">
                <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-box-arrow-right me-1"></i>Sign out</button>
            </form>
        </div>
    </header>

    <div class="app-body">
        <aside class="app-sidebar">
        <a class="app-brand brand-lockup app-brand-lockup" asp-page="/Index" aria-label="Workvert home">
            <span class="brand-mark">
                <img src="~/assets/brand/workvert_brand_mark.svg" width="44" height="44" asp-append-version="true" alt="" />
            </span>
            <span class="brand-wordmark">
                <span class="brand-title">Workvert<sup>TM</sup></span>
                <span class="brand-subtitle">Work and Services AI</span>
            </span>
        </a>

        <div class="app-sidebar-cta">
            <a class="app-sidebar-cta-main" asp-page="/App/Career/Index" asp-route-path="job">
                <i class="bi bi-stars"></i>
                <span>
                    <strong>Start matching</strong>
                    <small>Jobs, freelance work or services</small>
                </span>
            </a>
        </div>

        <nav class="app-nav mt-3" aria-label="App navigation">
            <div class="app-nav-section">Workspace</div>
            <a class="app-nav-link @(isActive("/App/Dashboard") ? "active" : "")" asp-page="/App/Dashboard">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Overview</span>
            </a>
            <a class="app-nav-link @(isCareerArea ? "active" : "")" asp-page="/App/Career/Index">
                <i class="bi bi-person-vcard-fill"></i>
                <span>Find work</span>
            </a>
            <a class="app-nav-link @(isServiceArea ? "active" : "")" asp-page="/App/Services/Index">
                <i class="bi bi-briefcase-fill"></i>
                <span>Find a professional</span>
            </a>
            <div class="app-nav-section">Account and settings</div>
            <a class="app-nav-link @(isActive("/App/Billing") ? "active" : "")" asp-page="/App/Billing">
                <i class="bi bi-credit-card-2-front"></i>
                <span>Subscription</span>
            </a>
            <a class="app-nav-link @(isActive("/App/Settings") ? "active" : "")" asp-page="/App/Settings">
                <i class="bi bi-broadcast-pin"></i>
                <span>Notifications</span>
            </a>
            <a class="app-nav-link @(isActive("/App/HelpDesk") ? "active" : "")" asp-page="/App/HelpDesk">
                <i class="bi bi-chat-left-text-fill"></i>
                <span>Help</span>
            </a>
            <a class="app-nav-link @(isActivePrefix("/App/Account") ? "active" : "")" asp-page="/App/Account/Index">
                <i class="bi bi-person-fill"></i>
                <span>Personal details</span>
            </a>
        </nav>

        </aside>

        <main class="app-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
