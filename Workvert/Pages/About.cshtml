@page
@model Workvert.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero professional-hero about-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-stars"></i>
            <span>About Workvert</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">One platform for three types of necessities: right work, valuable offers, and reliable service providers.</h1>
          <p class="lead muted mb-4">
            Workvert helps people find the right work, offer goods and services, or find someone who can do a good service.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">See how it works</a>
          </div>
          <div class="micro-proof-row">
            <span><i class="bi bi-check2"></i> Find right work</span>
            <span><i class="bi bi-check2"></i> Offer goods/services</span>
            <span><i class="bi bi-check2"></i> Find a good provider</span>
          </div>
        </div>

        <div class="mission-visual" aria-label="Workvert recommendation preview">
          <div class="mission-profile-card">
            <div class="mission-profile-top">
              <span class="mission-avatar"><i class="bi bi-person-vcard"></i></span>
              <div>
                <strong>Professional profile</strong>
                <small>Skills, goals, location, experience</small>
              </div>
            </div>
            <div class="mission-score">
              <span>87%</span>
              <small>match quality</small>
            </div>
          </div>

          <div class="mission-flow">
            <span><i class="bi bi-briefcase-fill"></i> Work</span>
            <span><i class="bi bi-cash-coin"></i> Offer</span>
            <span><i class="bi bi-people-fill"></i> Request</span>
          </div>

          <div class="mission-plan-card">
            <div>
              <small>Next match</small>
              <strong>Work, offer, provider, or service match</strong>
            </div>
            <i class="bi bi-graph-up-arrow"></i>
          </div>

          <div class="mission-ethics-note">
            <i class="bi bi-shield-check"></i>
            <span>Profile photos support presentation only, never compatibility scoring.</span>
          </div>
        </div>
      </div>
    </div>

    <section class="about-signal-grid mt-4" aria-label="Workvert focus areas">
      <article>
        <span>01</span>
        <strong>Help people find right work</strong>
        <p>Workvert reads skills, tools, experience, languages, location preferences, and goals together.</p>
      </article>
      <article>
        <span>02</span>
        <strong>Turn capability into offers</strong>
        <p>Sellable goods, services, and independent work are recommended from what the user already knows how to provide.</p>
      </article>
      <article>
        <span>03</span>
        <strong>Help people find a good provider</strong>
        <p>Clients describe what they need and Workvert identifies the right provider type, skills, and profiles.</p>
      </article>
    </section>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-compass"></i> Principles</span>
        <h2 class="section-title">Better matches, clearer choices, faster action.</h2>
        <p class="section-copy">Workvert is built for three everyday needs: find suitable work, turn what you can provide into valuable offers, and choose someone capable of delivering the service you need.</p>
      </div>

      <div class="value-grid">
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-bullseye"></i></div>
          <h2>Fewer, better matches</h2>
          <p class="mb-0">Workvert prioritizes recommendations that fit the person, the offer, or the request instead of showing generic lists.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-person-check"></i></div>
          <h2>Context over keywords</h2>
          <p class="mb-0">Skills, experience, tools, languages, location, goals, and service needs are read together before any match is suggested.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-graph-up-arrow"></i></div>
          <h2>From match to next step</h2>
          <p class="mb-0">Every result should help the user act: apply, create an offer, write a brief, improve a profile, or contact the right provider.</p>
        </div>
      </div>
    </section>

    <div class="conversion-band mt-4">
      <div>
        <span class="tag mb-2">Try the three necessities</span>
        <h2 class="h3 fw-bold mb-2">Find the right work, offer goods and services, or find someone who can do a good service.</h2>
        <p class="mb-0 muted">Create a profile to find work or offer value, or describe a request to find the right provider.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Create account</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing" asp-fragment="plans">View plans</a>
      </div>
    </div>
  </div>
</section>
