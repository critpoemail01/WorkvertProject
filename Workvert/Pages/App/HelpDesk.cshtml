@page
@model Workvert.Pages.App.HelpDeskModel
@{
    ViewData["Title"] = "Help";
}

<div class="account-page helpdesk-page">
    <div class="account-heading">
        <div>
            <span class="tag mb-2">Account and settings</span>
            <h1 class="fw-bold mb-0">Help</h1>
            <p class="muted mb-0">Open a support ticket when you need help with your profile, recommendations, billing or notifications.</p>
        </div>
        <div class="helpdesk-hero-meta">
            <span><i class="bi bi-person-check"></i> Profile support</span>
            <span><i class="bi bi-credit-card"></i> Billing help</span>
            <span><i class="bi bi-bell"></i> Notification issues</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    <div class="support-workspace mt-4">
        <section class="account-section support-ticket-panel">
            <div class="support-panel-head">
                <div>
                    <span class="support-panel-kicker">New ticket</span>
                    <h2>Tell us what needs attention.</h2>
                    <p>Use one ticket per issue so support can track the right profile, recommendation, payment or notification problem.</p>
                </div>
                <span class="support-panel-icon"><i class="bi bi-life-preserver"></i></span>
            </div>

            <form method="post" class="support-ticket-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-warning support-validation-summary"></div>

                <div class="support-form-grid">
                    <div>
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="Your name" autocomplete="name" required />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" autocomplete="email" required />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="support-field-wide">
                        <label asp-for="Input.Subject" class="form-label"></label>
                        <input asp-for="Input.Subject" class="form-control" placeholder="Short issue summary" maxlength="160" required />
                        <div class="form-text">Example: Profile analysis did not generate any results.</div>
                        <span asp-validation-for="Input.Subject" class="text-danger"></span>
                    </div>
                    <div class="support-field-wide">
                        <label asp-for="Input.Message" class="form-label"></label>
                        <textarea asp-for="Input.Message" class="form-control helpdesk-message" placeholder="Describe what happened, where it happened, and what you expected instead." maxlength="4000" required></textarea>
                        <div class="form-text">Include the page, recommendation type, payment or notification channel when relevant.</div>
                        <span asp-validation-for="Input.Message" class="text-danger"></span>
                    </div>
                </div>

                <div class="support-submit-row">
                    <p class="support-submit-note mb-0">
                        <i class="bi bi-shield-check"></i>
                        We will reply to the email address above.
                    </p>
                    <button class="btn btn-primary" type="submit"><i class="bi bi-send me-1"></i> Submit new ticket</button>
                </div>
            </form>
        </section>

        <aside class="support-aside" aria-label="Support guidance">
            <section class="support-aside-card">
                <div class="support-aside-title">
                    <span><i class="bi bi-list-check"></i></span>
                    <h3>What to include</h3>
                </div>
                <ul class="support-check-list">
                    <li><i class="bi bi-check2"></i><span>The page or feature where the issue happened.</span></li>
                    <li><i class="bi bi-check2"></i><span>The recommendation, service request or plan affected.</span></li>
                    <li><i class="bi bi-check2"></i><span>What you expected to happen instead.</span></li>
                </ul>
            </section>

            <section class="support-aside-card support-aside-card-accent">
                <div class="support-aside-title">
                    <span><i class="bi bi-lightning-charge"></i></span>
                    <h3>Faster resolution</h3>
                </div>
                <p>Clear subject lines and exact details help us route the ticket to the right support flow.</p>
            </section>

            <section class="support-note-card">
                <i class="bi bi-info-circle"></i>
                <p>
                    Please do not open duplicate tickets for the same issue. Add follow-up details by replying to the confirmation email.
                </p>
            </section>
        </aside>
    </div>

    <section class="account-section support-history-panel mt-4">
        <div class="support-panel-head support-panel-head-compact">
            <div>
                <span class="support-panel-kicker">History</span>
                <h2>Recent tickets</h2>
            </div>
        </div>
        @if (!Model.Tickets.Any())
        {
            <div class="empty-state compact">
                <i class="bi bi-chat-left-text"></i>
                <span>No support tickets yet.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Subject</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td class="text-muted">@ticket.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@ticket.Subject</td>
                            <td><span class="badge text-bg-secondary">@ticket.Status</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
