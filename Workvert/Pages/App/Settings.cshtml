@page
@model Workvert.Pages.App.SettingsModel
@{
    ViewData["Title"] = "Email and channels";
}

<div class="account-page">
    <div class="account-heading">
        <div>
            <span class="tag mb-2">Account and settings</span>
            <h1 class="fw-bold mb-0">Email and channels</h1>
            <p class="muted mb-0">Choose where Workvert sends price alerts, daily opportunity reports, and webhook payloads.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/App/Alerts/Index">Back to alerts</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>

        <input type="hidden" asp-for="Input.LinkedInAuthorized" />
        <input type="hidden" asp-for="Input.LinkedInOrganizationId" />
        <input type="hidden" asp-for="Input.LinkedInOrganizationName" />
        <input type="hidden" asp-for="Input.LinkedInScopes" />
        <input type="hidden" asp-for="Input.InstagramAuthorized" />
        <input type="hidden" asp-for="Input.InstagramBusinessAccountId" />
        <input type="hidden" asp-for="Input.InstagramBusinessAccountName" />
        <input type="hidden" asp-for="Input.InstagramScopes" />
        <input type="hidden" asp-for="Input.FacebookAuthorized" />
        <input type="hidden" asp-for="Input.FacebookPageId" />
        <input type="hidden" asp-for="Input.FacebookPageName" />
        <input type="hidden" asp-for="Input.FacebookScopes" />
        <input type="hidden" asp-for="Input.GoogleBusinessAuthorized" />
        <input type="hidden" asp-for="Input.GoogleBusinessProfileName" />
        <input type="hidden" asp-for="Input.EmailProvider" />
        <input type="hidden" asp-for="Input.WhatsAppAuthorized" />
        <input type="hidden" asp-for="Input.WhatsAppProviderName" />
        <input type="hidden" asp-for="Input.GoogleAnalyticsMeasurementId" />
        <input type="hidden" asp-for="Input.MetaPixelId" />
        <input type="hidden" asp-for="Input.AgencyName" />
        <input type="hidden" asp-for="Input.AgencyWorkspaceName" />
        <input type="hidden" asp-for="Input.AgencyBrandColor" />
        <input type="hidden" asp-for="Input.AgencyReportFooter" />
        <input type="hidden" asp-for="Input.AgencyPermissionMode" />

        <section class="account-section mt-4">
            <div class="account-section-title">Delivery preferences</div>
            <div class="notification-channel-intro">
                <div>
                    <span class="tag">Primary channels</span>
                    <h2>Receive alerts where you can act quickly</h2>
                    <p>Email covers price alerts and daily reports. Webhooks connect the radar to automations, teams, or your own dashboards.</p>
                </div>
                <a class="btn btn-primary app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
            </div>

            <div class="notification-channel-grid">
                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-envelope"></i></span>
                        <div>
                            <h3>Email</h3>
                            <p>Main channel for price alerts and daily opportunity reports.</p>
                        </div>
                        <span class="notification-channel-status @(Model.Input.EmailEnabled && Model.EmailTransportConfigured ? "ready" : Model.Input.EmailEnabled ? "setup" : "muted")">
                            @(Model.Input.EmailEnabled && Model.EmailTransportConfigured ? "Ready" : Model.Input.EmailEnabled ? "Setup" : "Muted")
                        </span>
                    </div>
                    <label class="notification-channel-switch">
                        <span>
                            <strong>Email alerts</strong>
                            <small>Uses verified SMTP senders configured on the server.</small>
                        </span>
                        <span class="form-check form-switch m-0">
                            <input class="form-check-input" asp-for="Input.EmailEnabled" />
                        </span>
                    </label>
                    <small class="notification-channel-note">
                        @(Model.EmailTransportConfigured ? $"{Model.EmailSenderProfileCount} sender profile{(Model.EmailSenderProfileCount == 1 ? "" : "s")} configured." : "Configure Notifications:Email or Notifications:Email:SenderProfiles before sending emails.")
                    </small>
                </article>

                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-braces"></i></span>
                        <div>
                            <h3>Webhook</h3>
                            <p>Send structured deal alerts to automation tools, bots, spreadsheets, or custom dashboards.</p>
                        </div>
                        <span class="notification-channel-status @(string.IsNullOrWhiteSpace(Model.Input.WebhookUrl) ? "setup" : "ready")">@(string.IsNullOrWhiteSpace(Model.Input.WebhookUrl) ? "Setup" : "Ready")</span>
                    </div>
                    <label class="notification-channel-field">
                        <span>Webhook URL</span>
                        <input asp-for="Input.WebhookUrl" class="form-control" placeholder="https://example.com/workvert-webhook" />
                    </label>
                    <span asp-validation-for="Input.WebhookUrl" class="text-danger"></span>
                </article>

                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-slack"></i></span>
                        <div>
                            <h3>Slack</h3>
                            <p>Post high-margin product signals into a team channel.</p>
                        </div>
                        <span class="notification-channel-status @(string.IsNullOrWhiteSpace(Model.Input.SlackWebhookUrl) ? "setup" : "ready")">@(string.IsNullOrWhiteSpace(Model.Input.SlackWebhookUrl) ? "Setup" : "Ready")</span>
                    </div>
                    <label class="notification-channel-field">
                        <span>Slack webhook URL</span>
                        <input asp-for="Input.SlackWebhookUrl" class="form-control" placeholder="https://hooks.slack.com/services/..." />
                    </label>
                    <span asp-validation-for="Input.SlackWebhookUrl" class="text-danger"></span>
                </article>

                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-discord"></i></span>
                        <div>
                            <h3>Discord</h3>
                            <p>Route opportunities to private resale, buying, or research communities.</p>
                        </div>
                        <span class="notification-channel-status @(string.IsNullOrWhiteSpace(Model.Input.DiscordWebhookUrl) ? "setup" : "ready")">@(string.IsNullOrWhiteSpace(Model.Input.DiscordWebhookUrl) ? "Setup" : "Ready")</span>
                    </div>
                    <label class="notification-channel-field">
                        <span>Discord webhook URL</span>
                        <input asp-for="Input.DiscordWebhookUrl" class="form-control" placeholder="https://discord.com/api/webhooks/..." />
                    </label>
                    <span asp-validation-for="Input.DiscordWebhookUrl" class="text-danger"></span>
                </article>

                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-microsoft-teams"></i></span>
                        <div>
                            <h3>Microsoft Teams</h3>
                            <p>Send price signals to procurement or operations workspaces.</p>
                        </div>
                        <span class="notification-channel-status @(string.IsNullOrWhiteSpace(Model.Input.TeamsWebhookUrl) ? "setup" : "ready")">@(string.IsNullOrWhiteSpace(Model.Input.TeamsWebhookUrl) ? "Setup" : "Ready")</span>
                    </div>
                    <label class="notification-channel-field">
                        <span>Teams webhook URL</span>
                        <input asp-for="Input.TeamsWebhookUrl" class="form-control" placeholder="https://outlook.office.com/webhook/..." />
                    </label>
                    <span asp-validation-for="Input.TeamsWebhookUrl" class="text-danger"></span>
                </article>

                <article class="notification-channel-card">
                    <div class="notification-channel-head">
                        <span class="notification-channel-icon"><i class="bi bi-telegram"></i></span>
                        <div>
                            <h3>Telegram</h3>
                            <p>Receive compact mobile alerts through a configured Telegram bot.</p>
                        </div>
                        <span class="notification-channel-status @(Model.TelegramBotConfigured && !string.IsNullOrWhiteSpace(Model.Input.TelegramChatId) ? "ready" : "setup")">
                            @(Model.TelegramBotConfigured && !string.IsNullOrWhiteSpace(Model.Input.TelegramChatId) ? "Ready" : "Setup")
                        </span>
                    </div>
                    <label class="notification-channel-field">
                        <span>Telegram chat ID</span>
                        <input asp-for="Input.TelegramChatId" class="form-control" placeholder="123456789" />
                    </label>
                    <small class="notification-channel-note">@(Model.TelegramBotConfigured ? "Telegram bot is configured." : "Configure the Telegram bot token before Telegram alerts can send.")</small>
                    <span asp-validation-for="Input.TelegramChatId" class="text-danger"></span>
                </article>
            </div>

            <div class="notification-channel-actions">
                <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i>Save channels</button>
                <span>These destinations become available when you create or edit alerts.</span>
            </div>
        </section>

        <section class="account-section mt-4">
            <div class="account-section-title">Time zone settings</div>
            <div class="settings-timezone-panel" data-settings-timezone>
                <div class="settings-timezone-copy">
                    <span class="settings-timezone-icon"><i class="bi bi-globe2"></i></span>
                    <div>
                        <h2>Local timestamps in every alert</h2>
                        <p>Activity stays stored in UTC. This setting controls the local timestamp shown in emails, webhooks, and the alert history.</p>
                    </div>
                </div>

                <div class="settings-timezone-control">
                    <label class="modal-field-label" for="notificationTimeZone">Notification time zone</label>
                    <select asp-for="Input.AlertTimeZone" class="form-select settings-timezone" id="notificationTimeZone" data-combo data-settings-timezone-select>
                        @foreach (var zone in Model.NotificationTimeZones)
                        {
                            <option value="@zone.Id" selected="@(zone.Id == Model.Input.AlertTimeZone)">@zone.Label</option>
                        }
                    </select>
                    <span asp-validation-for="Input.AlertTimeZone" class="text-danger"></span>
                </div>

                <div class="schedule-timezone-card settings-timezone-card">
                    <div>
                        <span>Detected on this device</span>
                        <strong data-settings-browser-timezone>Detecting browser time zone...</strong>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" type="button" data-settings-use-browser-timezone disabled>Use detected</button>
                    <div>
                        <span>Selected local time</span>
                        <strong data-settings-selected-timezone-clock>Checking selected time...</strong>
                    </div>
                </div>

                <div class="settings-timezone-actions">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i>Save settings</button>
                    <span>Use UTC for neutral timestamps, or choose your local city for clearer alert delivery times.</span>
                </div>
            </div>
        </section>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/workvert-combos.js" asp-append-version="true"></script>
}
