@page "{id:int}"
@model Workvert.Pages.App.Alerts.EditAlertModel
@{
    ViewData["Title"] = "Edit price alert";
}

<div class="alert-form-page product-watch-page">
    <section class="app-page-hero product-hero">
        <div>
            <span class="tag mb-3">Price intelligence</span>
            <h1 class="hero-title fw-bold mb-2">Edit price alert</h1>
            <p class="lead muted mb-0">Adjust the URL, target price, margin, region, and markets used by this monitor.</p>
        </div>
        <div class="app-page-hero-actions">
            <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>
    </section>

    <div class="alert-form-grid mt-4">
        <form method="post" class="surface app-panel alert-form-panel product-watch-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="product-form-section">
                <span class="product-form-step">1</span>
                <div>
                    <h2>Product and rule</h2>
                    <p>Keep each alert focused on one product, one region, and one main rule.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Input.Symbol" class="form-label"></label>
                    <div class="symbol-input-shell">
                        <i class="bi bi-link-45deg"></i>
                        <input asp-for="Input.Symbol" class="form-control" autocomplete="off" />
                    </div>
                    <span asp-validation-for="Input.Symbol" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.MarketType" class="form-label"></label>
                    <select asp-for="Input.MarketType" class="form-select" asp-items="Model.MarketTypeOptions"></select>
                    <span asp-validation-for="Input.MarketType" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.RuleType" class="form-label"></label>
                    <select asp-for="Input.RuleType" class="form-select" asp-items="Model.RuleTypeOptions"></select>
                    <span asp-validation-for="Input.RuleType" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.Threshold" class="form-label"></label>
                    <input asp-for="Input.Threshold" class="form-control" inputmode="decimal" />
                    <span asp-validation-for="Input.Threshold" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.ZonePercent" class="form-label"></label>
                    <input asp-for="Input.ZonePercent" class="form-control" inputmode="decimal" />
                    <span asp-validation-for="Input.ZonePercent" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.Timeframe" class="form-label"></label>
                    <select asp-for="Input.Timeframe" class="form-select" asp-items="Model.TimeframeOptions"></select>
                    <span asp-validation-for="Input.Timeframe" class="text-danger"></span>
                </div>
            </div>

            <div class="product-form-section mt-4">
                <span class="product-form-step">2</span>
                <div>
                    <h2>Region and markets</h2>
                    <p>Control the trusted stores and sites used to compare resale price.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.Country" class="form-label"></label>
                    <input asp-for="Input.Country" class="form-control" />
                    <span asp-validation-for="Input.Country" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.City" class="form-label"></label>
                    <input asp-for="Input.City" class="form-control" />
                    <span asp-validation-for="Input.City" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.Category" class="form-label"></label>
                    <input asp-for="Input.Category" class="form-control" />
                    <span asp-validation-for="Input.Category" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.TrustedStores" class="form-label"></label>
                    <textarea asp-for="Input.TrustedStores" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Input.TrustedStores" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.SecondHandSites" class="form-label"></label>
                    <textarea asp-for="Input.SecondHandSites" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Input.SecondHandSites" class="text-danger"></span>
                </div>
            </div>

            <div class="product-form-section mt-4">
                <span class="product-form-step">3</span>
                <div>
                    <h2>Delivery</h2>
                    <p>Choose the channel and avoid repeated notifications with an appropriate cooldown.</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.Channel" class="form-label"></label>
                    <select asp-for="Input.Channel" class="form-select">
                        <option>Email</option>
                        <option>Webhook</option>
                        <option>Slack</option>
                        <option>Discord</option>
                        <option>Teams</option>
                        <option>Telegram</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.ReportEmail" class="form-label"></label>
                    <input asp-for="Input.ReportEmail" class="form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Input.ReportEmail" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Input.CooldownMinutes" class="form-label"></label>
                    <input asp-for="Input.CooldownMinutes" class="form-control" />
                    <span asp-validation-for="Input.CooldownMinutes" class="text-danger"></span>
                </div>
            </div>

            <label class="form-check alert-form-check mt-4">
                <input class="form-check-input" asp-for="Input.IsEnabled" />
                <span class="form-check-label">Alert active</span>
            </label>

            <div class="alert-form-actions mt-4">
                <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i>Save changes</button>
                <a class="btn btn-outline-secondary" asp-page="/App/Alerts/Index">Cancel</a>
            </div>
        </form>

        <aside class="surface app-panel alert-form-aside product-watch-aside">
            <div class="plan-badge mb-3"><i class="bi bi-bell"></i> Active alert</div>
            <h2>Avoid noise</h2>
            <p>For volatile products, use margin below target and a longer cooldown. For categories, use a daily report.</p>

            <div class="alert-form-tip">
                <strong>Target price</strong>
                <span>Triggers when a trusted store is equal to or below the chosen value.</span>
            </div>
            <div class="alert-form-tip">
                <strong>Margin</strong>
                <span>Requires an additional drop before the email, useful for resale buying.</span>
            </div>
            <div class="alert-form-tip">
                <strong>Daily report</strong>
                <span>Summarizes category opportunities with OLX, Vinted, and other marketplace benchmarks.</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
