@page
@model Workvert.Pages.App.Crm.IndexModel
@{
    ViewData["Title"] = "Source lists";
}

<section class="app-page-hero product-hero">
    <div>
        <span class="tag mb-3">Source lists</span>
        <h1 class="hero-title fw-bold mb-2">Build watches from trusted stores and resale marketplaces.</h1>
        <p class="lead muted mb-0">Workvert uses store lists, resale sites, country, city, and category context to decide which product opportunities deserve an alert.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-bell me-1"></i>View alerts</a>
    </div>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>What belongs here now</h2>
            <p>Use each alert to store the trusted shops and resale marketplaces that matter for that product or category.</p>
        </div>
    </div>
    <div class="product-flow-grid">
        <article>
            <span><i class="bi bi-shop"></i></span>
            <strong>Trusted stores</strong>
            <p>Amazon.es, Fnac, Worten, PcComponentes, MediaMarkt, or any source you trust.</p>
        </article>
        <article>
            <span><i class="bi bi-arrow-repeat"></i></span>
            <strong>Resale benchmarks</strong>
            <p>OLX, Vinted, Wallapop, eBay, or specialist second-hand marketplaces.</p>
        </article>
        <article>
            <span><i class="bi bi-geo-alt"></i></span>
            <strong>Local context</strong>
            <p>Country and city filters keep stock, shipping, and resale value realistic.</p>
        </article>
        <article>
            <span><i class="bi bi-envelope-check"></i></span>
            <strong>Alerts and reports</strong>
            <p>Get immediate price alerts or daily category reports when the margin is worth action.</p>
        </article>
    </div>
</section>
