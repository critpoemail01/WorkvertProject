@page
@model Workvert.Pages.App.Account.IndexModel
@{
    ViewData["Title"] = "My account";
}

<div class="account-page account-profile-page">
    <div class="account-heading">
        <div>
            <span class="tag mb-2">Account and settings</span>
            <h1 class="fw-bold mb-0">My account</h1>
            <p class="muted mb-0">Manage sign-in details and account profile information.</p>
        </div>
        <div class="account-heading-actions">
            <span><i class="bi bi-shield-check"></i> Secure workspace</span>
            <a class="btn btn-primary" asp-page="/App/Billing">Manage subscription</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    <section class="account-profile-summary mt-4">
        <div class="account-profile-main">
            <span class="account-profile-avatar"><i class="bi bi-person"></i></span>
            <div>
                <span class="support-panel-kicker">Signed in account</span>
                <h2>@Model.Email</h2>
                <p>Use this area to keep your access details ready for job matching, service offers and provider requests.</p>
            </div>
        </div>
        <div class="account-detail-card-grid">
            <article>
                <span>Email</span>
                <strong>@Model.Email</strong>
            </article>
            <article>
                <span>Phone number</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not set" : Model.PhoneNumber)</strong>
            </article>
            <article>
                <span>Registered since</span>
                <strong>@Model.RegisteredSince.ToLocalTime().ToString("MMMM d, yyyy")</strong>
            </article>
            <article>
                <span>Password</span>
                <strong>@(Model.HasPassword ? "Configured" : "External login only")</strong>
            </article>
        </div>
    </section>

    <div class="account-form-grid account-profile-grid mt-4">
        <section class="account-section account-profile-panel">
            <div class="account-section-title">Update profile</div>
            <form method="post" asp-page-handler="Contact" class="account-form">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" name="email" type="email" value="@Model.Email" required />

                <label class="form-label mt-3" for="phoneNumber">Phone number</label>
                <input class="form-control" id="phoneNumber" name="phoneNumber" value="@Model.PhoneNumber" placeholder="+351 900 000 000" />

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button class="btn btn-primary" type="submit">Save profile</button>
                </div>
            </form>
        </section>

        <section class="account-section account-profile-panel">
            <div class="account-section-title">Security</div>
            <form method="post" asp-page-handler="Password" class="account-form">
                @if (Model.HasPassword)
                {
                    <label class="form-label" for="currentPassword">Current password</label>
                    <input class="form-control" id="currentPassword" name="currentPassword" type="password" autocomplete="current-password" />
                }
                else
                {
                    <p class="muted mb-3">Your account currently signs in through an external provider. Set a password if you also want email/password login.</p>
                }

                <label class="form-label mt-3" for="newPassword">New password</label>
                <input class="form-control" id="newPassword" name="newPassword" type="password" minlength="6" autocomplete="new-password" />

                <label class="form-label mt-3" for="confirmPassword">Confirm password</label>
                <input class="form-control" id="confirmPassword" name="confirmPassword" type="password" minlength="6" autocomplete="new-password" />

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button class="btn btn-primary" type="submit">Update password</button>
                </div>
            </form>
        </section>
    </div>

    <section class="account-danger-zone mt-4">
        <div class="account-danger-icon">
            <i class="bi bi-shield-exclamation"></i>
        </div>
        <div class="account-danger-copy">
            <span class="support-panel-kicker">Danger zone</span>
            <h2>Delete account</h2>
            <p>
                Account deletion removes profile data, professional searches and notification history. Support reviews the request manually so payment and audit records can be checked before removal.
            </p>
            <div class="account-danger-note">
                <i class="bi bi-info-circle"></i>
                <span>This action is handled by support before any irreversible removal happens.</span>
            </div>
        </div>
        <div class="account-danger-action">
            <a class="btn btn-outline-danger" href="mailto:support@workvert.local?subject=Delete%20my%20Workvert%20account">
                Request deletion
            </a>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
