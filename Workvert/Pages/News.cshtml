@page
@model Workvert.Pages.NewsModel
@{
    ViewData["Title"] = "News";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-megaphone-fill"></i>
            <span>Product updates</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">Improvements, roadmap, and next steps.</h1>
          <p class="lead muted mb-4">
            Follow Workvert as it evolves into an assistant for people who provide value and people who need value.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Create account</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing" asp-fragment="plans">View plans</a>
          </div>
        </div>

        <div class="proof-panel">
          <div class="proof-row">
            <i class="bi bi-person-vcard"></i>
            <div>
              <strong>Profile assistant</strong>
              <span>Skills, gaps, resume, LinkedIn, and message analysis.</span>
            </div>
          </div>
          <div class="proof-row">
            <i class="bi bi-briefcase"></i>
            <div>
              <strong>Service marketplace</strong>
              <span>Client requests translated into professional types, skills, and recommended profiles.</span>
            </div>
          </div>
          <div class="proof-row">
            <i class="bi bi-send"></i>
            <div>
              <strong>Notification roadmap</strong>
              <span>Recurring alerts by email, push, SMS, WhatsApp, and personal workspace.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-newspaper"></i> Latest notes</span>
        <h2 class="section-title">Updates with practical impact.</h2>
        <p class="section-copy">Every improvement should help users offer what they can provide, find what they need, or connect with the right side faster.</p>
      </div>

      <div class="news-grid">
        @foreach (var p in Model.Posts.OrderByDescending(x => x.DateUtc))
        {
          <article class="news-card">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
              <span class="tag">@p.Tag</span>
              <span class="muted small">@p.DateUtc.ToString("yyyy-MM-dd")</span>
            </div>
            <h2>@p.Title</h2>
            <p class="mb-0">@p.Excerpt</p>
          </article>
        }
      </div>
    </section>

    <div class="conversion-band mt-5">
      <div>
        <span class="tag mb-2">Test from the inside</span>
        <h2 class="h3 fw-bold mb-2">The best way to follow progress is to create an account.</h2>
        <p class="mb-0 muted">Create a profile, test recommendations, and validate both sides of the value exchange.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">How it works</a>
      </div>
    </div>
  </div>
</section>
