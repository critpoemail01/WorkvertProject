@page
@model Alivert.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-radar"></i>
            <span>About Alivert</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">A calmer way to monitor markets.</h1>
          <p class="lead muted mb-4">
            Alivert helps traders and investors replace constant chart checking with precise, condition-based alerts that are easy to manage.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">See the workflow</a>
          </div>
          <div class="micro-proof-row">
            <span><i class="bi bi-check2"></i> Monitoring software</span>
            <span><i class="bi bi-check2"></i> Not financial advice</span>
            <span><i class="bi bi-check2"></i> Built for focus</span>
          </div>
        </div>

        <div class="quote-card">
          <p class="mb-3">
            "The product promise is simple: set the market condition once, then let the system tell you when it deserves attention."
          </p>
          <div class="d-flex align-items-center gap-2 muted">
            <i class="bi bi-shield-check"></i>
            <span>Alerts first. Noise last.</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-compass"></i> Principles</span>
        <h2 class="section-title">Designed around clarity, control and speed.</h2>
        <p class="section-copy">Every part of the product is shaped around faster setup, fewer distractions and transparent pricing.</p>
      </div>

      <div class="value-grid">
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-bullseye"></i></div>
          <h2>Signal over noise</h2>
          <p class="mb-0">Cooldowns, schedules and focused rules keep alerts useful instead of overwhelming.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-wallet2"></i></div>
          <h2>Fair capacity</h2>
          <p class="mb-0">Credits make occasional alerting simple. Unlimited gives active traders full coverage.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-globe2"></i></div>
          <h2>Two market worlds</h2>
          <p class="mb-0">Crypto pairs and traditional symbols live in one workflow, with consistent rules.</p>
        </div>
      </div>
    </section>

    <section class="surface p-4 p-lg-5 mt-5">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <span class="section-eyebrow"><i class="bi bi-rocket-takeoff"></i> Roadmap</span>
          <h2 class="section-title">What we are building next.</h2>
          <p class="section-copy">The roadmap focuses on delivery channels, faster presets and better ways to reuse watchlists.</p>
        </div>
        <div class="col-lg-6">
          <div class="proof-panel">
            <div class="proof-row">
              <i class="bi bi-send"></i>
              <div>
                <strong>More notification channels</strong>
                <span>Telegram, Discord and webhook delivery for more direct workflows.</span>
              </div>
            </div>
            <div class="proof-row">
              <i class="bi bi-stars"></i>
              <div>
                <strong>Preset library</strong>
                <span>Reusable RSI, EMA, price-zone and breakout setups.</span>
              </div>
            </div>
            <div class="proof-row">
              <i class="bi bi-share"></i>
              <div>
                <strong>Shareable watchlists</strong>
                <span>Clone proven alert stacks instead of rebuilding every setup manually.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="conversion-band mt-4">
      <div>
        <span class="tag mb-2">Try it first</span>
        <h2 class="h3 fw-bold mb-2">Start with 5 free alert credits.</h2>
        <p class="mb-0 muted">Create a real setup, see the dashboard, then choose credits or Unlimited only when it adds value.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Create account</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View plans</a>
      </div>
    </div>
  </div>
</section>
