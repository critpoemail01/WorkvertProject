@page
@model Alivert.Pages.AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="hero-section">
  <div class="container">
    <div class="page-hero">
      <div class="page-hero-grid">
        <div>
          <div class="hero-kicker mb-3">
            <i class="bi bi-megaphone-fill"></i>
            <span>About Promovert</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">A practical way to promote any online application.</h1>
          <p class="lead muted mb-4">
            Promovert helps founders and teams turn a URL, company or business idea into social posts, short videos, email outreach and SMS promotions.
          </p>
          <div class="hero-actions">
            <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
            <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">See the workflow</a>
          </div>
          <div class="micro-proof-row">
            <span><i class="bi bi-check2"></i> Campaign software</span>
            <span><i class="bi bi-check2"></i> Built for acquisition</span>
            <span><i class="bi bi-check2"></i> Measurable funnel</span>
          </div>
        </div>

        <div class="quote-card">
          <p class="mb-3">
            "The product promise is simple: describe what you sell once, then turn it into campaigns that reach, engage and convert customers."
          </p>
          <div class="d-flex align-items-center gap-2 muted">
            <i class="bi bi-shield-check"></i>
            <span>Campaigns first. Guesswork last.</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-5">
      <div class="section-header">
        <span class="section-eyebrow"><i class="bi bi-compass"></i> Principles</span>
        <h2 class="section-title">Designed around speed, clarity and measurable growth.</h2>
        <p class="section-copy">Every part of the product is shaped around faster campaign setup, cleaner distribution and transparent pricing.</p>
      </div>

      <div class="value-grid">
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-bullseye"></i></div>
          <h2>Outcome over output</h2>
          <p class="mb-0">The dashboard focuses on users reached, users interacted and users converted.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-wallet2"></i></div>
          <h2>Fair capacity</h2>
          <p class="mb-0">Credits make occasional launches simple. Unlimited gives active growth teams full coverage.</p>
        </div>
        <div class="value-card">
          <div class="icon-pill"><i class="bi bi-globe2"></i></div>
          <h2>Multi-channel workflow</h2>
          <p class="mb-0">Social content, email and SMS live in one workflow with consistent campaign tracking.</p>
        </div>
      </div>
    </section>

    <div class="conversion-band mt-4">
      <div>
        <span class="tag mb-2">Try it first</span>
        <h2 class="h3 fw-bold mb-2">Start with 5 free campaign credits.</h2>
        <p class="mb-0 muted">Create a real campaign, see the dashboard, then choose credits or Unlimited when you need more active platforms.</p>
      </div>
      <div class="conversion-actions">
        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Create account</button>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View plans</a>
      </div>
    </div>
  </div>
</section>
