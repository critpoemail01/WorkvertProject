@page
@model Alivert.Pages.PricingModel
@{
    ViewData["Title"] = "Precos";
}

<section class="hero-section">
    <div class="container">
        <div class="promo-strip mb-4">
            <div>
                <span class="promo-label">Lancamento</span>
                <span class="promo-copy">Campanhas ilimitadas por EUR 49.99/mes ou EUR 299/ano. O anual e a melhor opcao para marketing continuo.</span>
            </div>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a class="promo-link" asp-page="/App/Billing">Abrir faturacao <i class="bi bi-arrow-right-short"></i></a>
            }
            else
            {
                <button type="button" class="promo-link promo-button" data-auth-open="register">Criar conta <i class="bi bi-arrow-right-short"></i></button>
            }
        </div>

        <div class="page-hero pricing-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-credit-card-2-front-fill"></i>
                        <span>Precos simples para campanhas recorrentes</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">Comeca gratis e escala quando o marketing passa a ser continuo.</h1>
                    <p class="lead muted mb-4">1 credito pago = 1 campanha ativa em 1 plataforma durante 30 dias. Compra pacotes a partir de EUR 24.99 ou escolhe ilimitado mensal/anual.</p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Comecar com 5 creditos gratis</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">Como funciona</a>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-gift"></i>
                        <div>
                            <strong>Conta gratis primeiro</strong>
                            <span>Usa 5 creditos para validar o fluxo de campanha antes de comprar capacidade.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-wallet2"></i>
                        <div>
                            <strong>Creditos para campanhas ocasionais</strong>
                            <span>Pacotes de 25, 50 e 100 creditos cobrem campanhas-plataformas ativas durante 30 dias.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-stars"></i>
                        <div>
                            <strong>Anual e melhor valor</strong>
                            <span>EUR 299/ano poupa mais de 50% face ao pagamento mensal.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-4 pricing-grid">
            <div class="col-lg-3">
                <div class="surface plan">
                    <div class="plan-title">Gratis</div>
                    <div class="plan-price mt-2">EUR 0</div>
                    <div class="muted mt-2">Valida o fluxo antes de pagar.</div>

                    <ul class="mt-3 muted">
                        <li>5 creditos para 5 campanhas-plataformas ativas</li>
                        <li>Planeamento social, email e SMS</li>
                        <li>Dashboard e historico de campanhas</li>
                    </ul>

                    <div class="plan-footer">
                        <button type="button" class="btn btn-outline-secondary w-100" data-auth-open="register">Criar conta gratis</button>
                        <div class="plan-footer-note" aria-hidden="true"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Pacotes de creditos</div>
                        <span class="plan-badge"><i class="bi bi-wallet2"></i> Flexivel</span>
                    </div>

                    <div class="plan-price mt-2">desde EUR 24.99</div>
                    <div class="muted mt-2">Adiciona capacidade por 30 dias apenas quando precisares.</div>

                    <ul class="mt-3 muted">
                        <li>25 creditos por EUR 24.99</li>
                        <li>50 creditos por EUR 34.99</li>
                        <li>100 creditos por EUR 49.99</li>
                        <li>Creditos expiram 30 dias depois do pagamento</li>
                        <li>Pagamento por cartao</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Comprar creditos</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Comprar creditos</button>
                        }
                        <div class="plan-footer-note small muted text-center">A capacidade do pacote fica ativa durante 30 dias.</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan plan-highlight">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Ilimitado mensal</div>
                        <span class="plan-badge"><i class="bi bi-arrow-repeat"></i> Flexivel</span>
                    </div>

                    <div class="plan-price mt-2">EUR 49.99<span class="fs-6 muted">/mes</span></div>
                    <div class="muted mt-2">Para equipas que querem cobrir todos os produtos, canais e plataformas mes a mes.</div>

                    <ul class="mt-3 muted">
                        <li>Campanhas-plataformas ativas ilimitadas</li>
                        <li>Posts, emails e SMS planeados</li>
                        <li>Pagamento por cartao</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Subscrever mensal</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Subscrever mensal</button>
                        }
                        <div class="plan-footer-note small muted text-center">O acesso mensal ativa depois da confirmacao de pagamento.</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="surface plan plan-highlight">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="plan-title">Ilimitado anual</div>
                        <span class="plan-badge plan-badge-warm"><i class="bi bi-stars"></i> Melhor valor</span>
                    </div>

                    <div class="plan-price mt-2">EUR 299<span class="fs-6 muted">/ano</span></div>
                    <div class="muted mt-2">Paga uma vez por ano e poupa mais de 50% face ao mensal.</div>

                    <ul class="mt-3 muted">
                        <li>Campanhas-plataformas ativas ilimitadas durante 1 ano</li>
                        <li>Todos os tipos de campanha social, email e SMS</li>
                        <li>Melhor opcao para equipas com marketing continuo</li>
                    </ul>

                    <div class="plan-footer">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-primary w-100" asp-page="/App/Billing">Subscrever anual</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary w-100" data-auth-open="register">Subscrever anual</button>
                        }
                        <div class="plan-footer-note small muted text-center">O acesso anual ativa depois da confirmacao de pagamento.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Ainda em duvida?</span>
                <h2 class="h3 fw-bold mb-2">Comeca gratis. Faz upgrade quando as campanhas forem rotina.</h2>
                <p class="mb-0 muted">A maioria dos utilizadores comeca com 5 creditos gratis, depois escolhe pacotes de 30 dias ou ilimitado anual.</p>
            </div>
            <div class="conversion-actions">
                <a class="btn btn-outline-secondary btn-lg" asp-page="/HowItWorks">Como funciona</a>
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" asp-page="/App/Billing">Ir para faturacao</a>
                }
                else
                {
                    <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Comecar gratis</button>
                }
            </div>
        </div>
    </div>
</section>
