@page
@model Alivert.Pages.HowItWorksModel
@{
    ViewData["Title"] = "How it works";
}

<section class="hero-section">
    <div class="container">
        <div class="page-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-diagram-3-fill"></i>
                        <span>Setup in minutes</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">From product idea to live marketing campaign without friction.</h1>
                    <p class="lead muted mb-4">
                        Promovert turns a URL, company or business idea into social content, personalized outreach and a dashboard for reach, interaction and conversion.
                    </p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">Compare plans</a>
                    </div>
                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> 5 free campaign credits</span>
                        <span><i class="bi bi-check2"></i> Social, email and SMS</span>
                        <span><i class="bi bi-check2"></i> Funnel metrics</span>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-link-45deg"></i>
                        <div>
                            <strong>Add a source</strong>
                            <span>Use an application URL, company name or short business idea.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-camera-video"></i>
                        <div>
                            <strong>Choose the campaign asset</strong>
                            <span>Posts, short videos, LinkedIn content, personalized email or SMS.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-graph-up-arrow"></i>
                        <div>
                            <strong>Measure the funnel</strong>
                            <span>See reached, engaged and converted users in the dashboard.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5">
            <div class="section-header">
                <span class="section-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Workflow</span>
                <h2 class="section-title">A simple system for repeatable campaign setup.</h2>
                <p class="section-copy">Every screen is designed to reduce the time between a marketing idea and a measurable campaign.</p>
            </div>

            <div class="step-grid">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h2>Create your account</h2>
                    <p class="mb-0">Start with 5 free credits. No payment is needed until you want more active campaigns or Unlimited.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h2>Build the campaign</h2>
                    <p class="mb-0">Pick the source, asset type, cadence, goal and channel.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h2>Track results</h2>
                    <p class="mb-0">Review reach, interaction and subscriptions or purchases before scaling.</p>
                </div>
            </div>
        </section>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Best next step</span>
                <h2 class="h3 fw-bold mb-2">Create your first campaign and validate the workflow.</h2>
                <p class="mb-0 muted">The fastest path is to start with free credits, then upgrade only when campaigns become part of your routine.</p>
            </div>
            <div class="conversion-actions">
                <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">See pricing</a>
            </div>
        </div>
    </div>
</section>
