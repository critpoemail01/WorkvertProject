@page
@model Alivert.Pages.HowItWorksModel
@{
    ViewData["Title"] = "How it works";
}

<section class="hero-section">
    <div class="container">
        <div class="page-hero">
            <div class="page-hero-grid">
                <div>
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-diagram-3-fill"></i>
                        <span>Setup in minutes</span>
                    </div>
                    <h1 class="hero-title display-5 fw-bold mb-3">From market idea to live alert without friction.</h1>
                    <p class="lead muted mb-4">
                        Alivert turns price levels, RSI thresholds, EMA crosses and price zones into clean notifications across crypto and traditional markets.
                    </p>
                    <div class="hero-actions">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">Compare plans</a>
                    </div>
                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> 5 free alert credits</span>
                        <span><i class="bi bi-check2"></i> Binance and Yahoo Finance</span>
                        <span><i class="bi bi-check2"></i> No chart staring</span>
                    </div>
                </div>

                <div class="proof-panel">
                    <div class="proof-row">
                        <i class="bi bi-search"></i>
                        <div>
                            <strong>Find any supported symbol</strong>
                            <span>Crypto from Binance and traditional assets through Yahoo Finance.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-sliders2-vertical"></i>
                        <div>
                            <strong>Choose the condition</strong>
                            <span>Price zones, RSI, EMA crosses, 24h moves and volume rules.</span>
                        </div>
                    </div>
                    <div class="proof-row">
                        <i class="bi bi-bell-fill"></i>
                        <div>
                            <strong>React only when it matters</strong>
                            <span>Cooldowns and schedules reduce duplicate noise.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5">
            <div class="section-header">
                <span class="section-eyebrow"><i class="bi bi-lightning-charge-fill"></i> Workflow</span>
                <h2 class="section-title">A simple system for repeatable alert setup.</h2>
                <p class="section-copy">Every screen is designed to reduce the time between an idea and a monitored condition.</p>
            </div>

            <div class="step-grid">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h2>Create your account</h2>
                    <p class="mb-0">Start with 5 free credits. No payment is needed until you want more active alerts or Unlimited.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h2>Build the alert</h2>
                    <p class="mb-0">Pick market type, symbol, timeframe and rule. Defaults match the service presets: RSI 14 and EMA 3/5.</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h2>Route the notification</h2>
                    <p class="mb-0">Use email today, then connect Telegram, Discord or webhooks for faster delivery paths.</p>
                </div>
            </div>
        </section>

        <section class="surface p-4 p-lg-5 mt-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <span class="section-eyebrow"><i class="bi bi-wallet2"></i> Credits</span>
                    <h2 class="section-title">Pay for capacity in the way that fits your rhythm.</h2>
                    <p class="section-copy">Use credits for focused watchlists. Move to Unlimited monthly or annual when every market and timeframe deserves coverage.</p>
                </div>
                <div class="col-lg-5">
                    <div class="comparison-strip">
                        <div class="comparison-item">
                            <strong>5</strong>
                            <span>free credits</span>
                        </div>
                        <div class="comparison-item">
                            <strong>25</strong>
                            <span>EUR 25</span>
                        </div>
                        <div class="comparison-item">
                            <strong>100</strong>
                            <span>EUR 50</span>
                        </div>
                        <div class="comparison-item">
                            <strong>300</strong>
                            <span>EUR/year</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Best next step</span>
                <h2 class="h3 fw-bold mb-2">Create your first alert and validate the workflow.</h2>
                <p class="mb-0 muted">The fastest path is to start with free credits, then upgrade only when the system becomes part of your routine.</p>
            </div>
            <div class="conversion-actions">
                <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">See pricing</a>
            </div>
        </div>
    </div>
</section>
