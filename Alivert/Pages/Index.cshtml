@page
@model Alivert.Pages.IndexModel
@{
    ViewData["Title"] = "Online campaign engine";
}

<section class="hero-section">
    <div class="container">
        <div class="promo-strip mb-4">
            <div>
                <span class="promo-label">Launch promo</span>
                <span class="promo-copy">Start with 5 free campaign credits. Upgrade to Unlimited from EUR 50/month or EUR 300/year when marketing becomes continuous.</span>
            </div>
            <a class="promo-link" asp-page="/Pricing">Compare plans <i class="bi bi-arrow-right-short"></i></a>
        </div>

        <div class="surface hero-card p-4 p-md-5">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <div class="hero-kicker mb-3">
                        <i class="bi bi-megaphone-fill"></i>
                        <span>AI social calendar, email sequences and lead generation</span>
                    </div>

                    <h1 class="display-5 fw-bold hero-title mb-3">Promovert turns any URL, company or idea into an AI-managed acquisition calendar.</h1>
                    <p class="lead mb-4 muted">
                        Generate daily posts, video scripts, email sequences and prospecting targets, approve the suggestions, then let Promovert schedule the work across each channel.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">
                            Start free
                        </button>
                        <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">See plans</a>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Dashboard">Open dashboard</a>
                        }
                    </div>

                    <div class="micro-proof-row">
                        <span><i class="bi bi-check2"></i> 5 free campaigns</span>
                        <span><i class="bi bi-check2"></i> AI-generated monthly calendar</span>
                        <span><i class="bi bi-check2"></i> Reach, engagement and conversion metrics</span>
                    </div>

                    <div class="hero-proof mt-4">
                        <div>
                            <strong>3</strong>
                            <span>core metrics</span>
                        </div>
                        <div>
                            <strong>6</strong>
                            <span>marketing channels</span>
                        </div>
                        <div>
                            <strong>EUR 300</strong>
                            <span>Unlimited/year</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="market-panel">
                        <div class="market-panel-header">
                            <span class="badge badge-soft">Campaign desk</span>
                            <span class="market-dot"></span>
                        </div>
                        <div class="market-card active">
                            <div>
                                <div class="fw-semibold">https://app.example.com</div>
                                <div class="small muted">30-day TikTok + Instagram schedule</div>
                            </div>
                            <span class="signal signal-buy">Drafting</span>
                        </div>
                        <div class="market-card">
                            <div>
                                <div class="fw-semibold">B2B SaaS launch</div>
                                <div class="small muted">LinkedIn posts + email sequence</div>
                            </div>
                            <span class="signal">Queued</span>
                        </div>
                        <div class="market-card">
                            <div>
                                <div class="fw-semibold">Local service offer</div>
                                <div class="small muted">Facebook campaign + SMS follow-up</div>
                            </div>
                            <span class="signal">Measuring</span>
                        </div>
                        <div class="market-panel-footer">
                            <i class="bi bi-graph-up-arrow"></i>
                            <span>Reached, engaged, converted. One dashboard.</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <section class="mt-5">
            <div class="section-header">
                <span class="section-eyebrow"><i class="bi bi-stars"></i> Built for practical acquisition</span>
                <h2 class="section-title">AI planning, approval, outreach and measurement in one workspace.</h2>
                <p class="section-copy">Promovert focuses on three outcomes: users reached, users engaged and users converted into subscribers or buyers.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-camera-video"></i></div>
                        <h5>AI content calendar</h5>
                        <p class="mb-0 muted">Generate hooks, captions, short scripts and channel-specific angles for TikTok, Instagram, Facebook, LinkedIn and more.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-envelope-paper"></i></div>
                        <h5>Email and lead suggestions</h5>
                        <p class="mb-0 muted">Prepare multi-day templates for potential clients and get suggested company profiles, roles and search prompts.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="surface feature-card h-100">
                        <div class="icon-pill mb-3"><i class="bi bi-speedometer2"></i></div>
                        <h5>Campaign dashboard</h5>
                        <p class="mb-0 muted">Track how many users were reached, how many interacted and how many subscribed or bought through your marketing.</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="conversion-band mt-4">
            <div>
                <span class="tag mb-2">Best next step</span>
                <h2 class="fw-bold mb-2">Add a URL or idea and launch your first campaign.</h2>
                <p class="mb-0 muted">Credit packs start at EUR 25 and stay active for 30 days. Unlimited is EUR 50/month or EUR 300/year for teams running campaigns every week.</p>
            </div>
            <div class="conversion-actions">
                <button type="button" class="btn btn-primary btn-lg" data-auth-open="register">Start free</button>
                <a class="btn btn-outline-secondary btn-lg" asp-page="/Pricing">View pricing</a>
            </div>
        </div>
    </div>
</section>
