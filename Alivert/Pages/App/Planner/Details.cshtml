@page "{id:int}"
@model Alivert.Pages.App.Planner.DetailsModel
@{
    ViewData["Title"] = "AI plan";
}

<section class="app-page-hero ai-planner-hero">
    <div>
        <span class="tag mb-3">AI plan</span>
        <h1 class="hero-title fw-bold mb-2">@Model.Plan.ProductName</h1>
        <p class="lead muted mb-0">@Model.Plan.TargetAudience</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Planner/Index"><i class="bi bi-arrow-left me-1"></i>Planner</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Planner/Index" asp-route-sourcePlanId="@Model.Plan.Id"><i class="bi bi-arrow-repeat me-1"></i>Next campaign</a>
        <form method="post" asp-page-handler="ApproveAll" asp-route-id="@Model.Plan.Id">
            <button class="btn btn-primary btn-lg" type="submit"><i class="bi bi-check2-all me-1"></i>Approve all</button>
        </form>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info mt-4 mb-0">@Model.StatusMessage</div>
}

<section class="surface dashboard-plan-card mt-4">
    <div class="dashboard-plan-main">
        <span class="app-stat-icon dashboard-plan-icon"><i class="bi bi-stars"></i></span>
        <div>
            <div class="app-stat-label">Plan status</div>
            <h2>@Model.Plan.Status</h2>
            @if (Model.Plan.CrmLeadSourceCount > 0)
            {
                <p class="mb-1"><i class="bi bi-database-check me-1"></i>@Model.Plan.CrmLeadSourceCount imported CRM lead email@(Model.Plan.CrmLeadSourceCount == 1 ? "" : "s") included@(string.IsNullOrWhiteSpace(Model.Plan.CrmLeadFilter) ? "" : $" for '{Model.Plan.CrmLeadFilter}'").</p>
            }
            <p class="mb-1"><i class="bi bi-geo-alt me-1"></i>@LocationLabel()</p>
            <p>@Model.Plan.StartDate.ToString("MMM d, yyyy") - @Model.Plan.EndDate.ToString("MMM d, yyyy") · @Model.Plan.Platforms.Replace(",", ", ") · @FrequencyLabel(Model.Plan.Frequency) · @Model.PlanCreditUnits credit@(Model.PlanCreditUnits == 1 ? "" : "s") when scheduled</p>
        </div>
    </div>
    <div class="planner-metric-strip">
        <div><strong>@Model.Metrics.Drafts</strong><span>draft</span></div>
        <div><strong>@Model.Metrics.Approved</strong><span>approved</span></div>
        <div><strong>@Model.Metrics.Scheduled</strong><span>scheduled</span></div>
        <div><strong>@Model.Metrics.Published</strong><span>live/sent</span></div>
    </div>
    <div class="dashboard-plan-actions">
        <form method="post" asp-page-handler="ScheduleApproved" asp-route-id="@Model.Plan.Id">
            <button class="btn btn-primary" type="submit"><i class="bi bi-calendar-check me-1"></i>Schedule approved</button>
        </form>
        <form method="post" asp-page-handler="PublishDue" asp-route-id="@Model.Plan.Id">
            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-send-check me-1"></i>Publish due now</button>
        </form>
    </div>
</section>

@if (Model.CompanyLearning.HasData)
{
    <section class="surface app-panel mt-4">
        <div class="app-panel-header">
            <div>
                <h2>Company learning</h2>
                <p>Promovert learns from this company results and adapts the next campaign.</p>
            </div>
            <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Index" asp-route-sourcePlanId="@Model.Plan.Id"><i class="bi bi-arrow-repeat me-1"></i>Use learning in next campaign</a>
        </div>

        <div class="company-learning-grid">
            <article>
                <strong>@Model.CompanyLearning.CampaignsAnalyzed</strong>
                <span>campaigns learned</span>
            </article>
            <article>
                <strong>@Model.CompanyLearning.LeadsGenerated</strong>
                <span>leads attributed</span>
            </article>
            <article>
                <strong>@string.Join(", ", Model.CompanyLearning.PreferredPlatforms)</strong>
                <span>preferred channels</span>
            </article>
        </div>

        <div class="company-learning-columns mt-3">
            <div>
                <strong>This company converts better with</strong>
                @foreach (var pattern in Model.CompanyLearning.WinningPatterns)
                {
                    <span><i class="bi bi-check2"></i>@pattern</span>
                }
            </div>
            <div>
                <strong>How the AI will adapt</strong>
                @foreach (var adaptation in Model.CompanyLearning.RecommendedAdaptations)
                {
                    <span><i class="bi bi-arrow-repeat"></i>@adaptation</span>
                }
            </div>
        </div>

        <div class="company-learning-recommendation mt-3">
            <i class="bi bi-stars"></i>
            <span>@Model.CompanyLearning.RecommendedCampaignBrief</span>
        </div>
    </section>
}

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Business analytics</h2>
            <p>Campaign report focused on clicks, leads, conversion, cost per lead and the next action.</p>
        </div>
    </div>

    <div class="business-metric-grid">
        <article>
            <span><i class="bi bi-cursor"></i></span>
            <div>
                <strong>@Model.BusinessReport.Clicks</strong>
                <small>clicks</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-person-lines-fill"></i></span>
            <div>
                <strong>@Model.BusinessReport.Leads</strong>
                <small>leads</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-graph-up-arrow"></i></span>
            <div>
                <strong>@Model.BusinessReport.ConversionRateLabel</strong>
                <small>lead conversion</small>
            </div>
        </article>
        <article>
            <span><i class="bi bi-calculator"></i></span>
            <div>
                <strong>@Model.BusinessReport.CostPerLeadLabel</strong>
                <small>cost per lead</small>
            </div>
        </article>
    </div>

    <div class="business-insight-grid mt-3">
        <article>
            <span class="tag">Top channel</span>
            <h3>@Model.BusinessReport.TopLeadChannel</h3>
            <p>@Model.BusinessReport.TopLeadChannelLeads leads generated or projected.</p>
        </article>
        <article>
            <span class="tag">Best post</span>
            <h3>@Model.BusinessReport.TopLeadPost</h3>
            <p>@Model.BusinessReport.TopLeadPostDetail</p>
        </article>
        <article>
            <span class="tag">Best email</span>
            <h3>@Model.BusinessReport.BestEmail</h3>
            <p>@Model.BusinessReport.BestEmailDetail</p>
        </article>
        <article>
            <span class="tag">Profitability</span>
            <h3>@Model.BusinessReport.MostProfitableSummary</h3>
            <p>Lead volume is evaluated against active campaign-platform credits.</p>
        </article>
    </div>

    <div class="business-next-action mt-3">
        <span><i class="bi bi-lightning-charge-fill"></i></span>
        <div>
            <strong>Next recommended action</strong>
            <p>@Model.BusinessReport.RecommendedNextAction</p>
        </div>
    </div>

    @if (Model.BusinessReport.Channels.Any())
    {
        <div class="table-responsive mt-3">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Channel</th>
                        <th>Reach</th>
                        <th>Clicks</th>
                        <th>Leads</th>
                        <th>Conversion</th>
                        <th>Signal</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var channel in Model.BusinessReport.Channels)
                {
                    <tr>
                        <td><strong>@channel.Channel</strong></td>
                        <td>@channel.Reach</td>
                        <td>@channel.Clicks</td>
                        <td>@channel.Leads</td>
                        <td>@channel.ConversionRateLabel</td>
                        <td class="text-muted">@channel.Signal</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Official publishing authorization</h2>
            <p>Social posts are published only through authorized accounts/pages. Channels without official authorization stay blocked instead of being marked live.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Settings"><i class="bi bi-plug me-1"></i>Manage integrations</a>
    </div>

    <div class="official-auth-grid">
        @foreach (var item in Model.PublicationAuthorizations)
        {
            <article class="official-auth-card @(item.IsAuthorized ? "ready" : "blocked")">
                <span><i class="bi @(item.IsAuthorized ? "bi-shield-check" : "bi-shield-exclamation")"></i></span>
                <div>
                    <strong>@item.Channel</strong>
                    <p>@item.Detail</p>
                </div>
                <em>@(item.IsAuthorized ? "Authorized" : "Needs setup")</em>
            </article>
        }
    </div>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Campaign funnel</h2>
            <p>URL da empresa -> Business DNA -> campanha completa -> aprovação -> publicação autorizada -> captação de leads -> relatório e próxima campanha.</p>
        </div>
    </div>
    <div class="campaign-flow">
        <span><i class="bi bi-link-45deg"></i>URL</span>
        <span><i class="bi bi-fingerprint"></i>Business DNA</span>
        <span><i class="bi bi-megaphone"></i>Posts + emails + landing</span>
        <span><i class="bi bi-check2-square"></i>Approval</span>
        <span><i class="bi bi-send-check"></i>Authorized publishing</span>
        <span><i class="bi bi-person-plus"></i>Lead capture</span>
        <span><i class="bi bi-graph-up"></i>Report</span>
    </div>
    <div class="business-dna-box mt-3">
        <strong>Business DNA</strong>
        <p>@(string.IsNullOrWhiteSpace(Model.Plan.BusinessDna) ? "Business DNA will be generated for new campaigns." : Model.Plan.BusinessDna)</p>
    </div>

    <div class="campaign-structure-grid mt-3">
        <article>
            <h3>Structured campaign brief</h3>
            <dl class="campaign-brief-list">
                <div><dt>Objetivo</dt><dd>@Model.Plan.CampaignGoal</dd></div>
                <div><dt>Duração</dt><dd>@(Model.Plan.EndDate.DayNumber - Model.Plan.StartDate.DayNumber + 1) dias</dd></div>
                <div><dt>Público-alvo</dt><dd>@Model.Plan.TargetAudience</dd></div>
                <div><dt>Oferta</dt><dd>@Model.Plan.ValueProposition</dd></div>
                <div><dt>Canais</dt><dd>@Model.Plan.Platforms.Replace(",", " + ") + Email</dd></div>
                <div><dt>Landing page</dt><dd>@(Model.Plan.LandingPage is null ? "não" : "sim")</dd></div>
                <div><dt>Formulário</dt><dd>@(Model.Plan.LandingPage is null ? "não" : "sim")</dd></div>
                <div><dt>Follow-up automático</dt><dd>@(Model.Plan.Emails.Any() ? "sim" : "não")</dd></div>
                <div><dt>Relatório</dt><dd>sim</dd></div>
            </dl>
        </article>

        <article>
            <h3>Campaign assets</h3>
            <div class="campaign-asset-list">
                <span><i class="bi bi-check2"></i>Estratégia</span>
                <span><i class="bi bi-check2"></i>Calendário</span>
                <span><i class="bi bi-check2"></i>Posts</span>
                <span><i class="bi bi-check2"></i>Emails</span>
                <span><i class="bi bi-check2"></i>Landing page</span>
                <span><i class="bi bi-check2"></i>Criativos</span>
                <span><i class="bi bi-check2"></i>Formulário</span>
                <span><i class="bi bi-check2"></i>UTMs</span>
                <span><i class="bi bi-check2"></i>Automação</span>
                <span><i class="bi bi-check2"></i>Relatório</span>
            </div>
        </article>
    </div>
</section>

@if (Model.NextCampaignRecommendations.Any())
{
    <section class="surface app-panel mt-4">
        <div class="app-panel-header">
            <div>
                <h2>Suggested next campaigns</h2>
                <p>Sector-specific campaigns based on this company, application and audience.</p>
            </div>
        </div>
        <div class="campaign-library-grid">
            @foreach (var recommendation in Model.NextCampaignRecommendations)
            {
                <article class="campaign-template-card">
                    <span class="tag">@recommendation.Sector</span>
                    <h4>@recommendation.Title</h4>
                    <p>@recommendation.Strategy</p>
                    <dl>
                        <div><dt>Goal</dt><dd>@recommendation.Goal</dd></div>
                        <div><dt>Offer</dt><dd>@recommendation.Offer</dd></div>
                        <div><dt>Channels</dt><dd>@string.Join(" + ", recommendation.Platforms)</dd></div>
                        <div><dt>Report</dt><dd>@recommendation.ReportFocus</dd></div>
                    </dl>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Index" asp-route-sourcePlanId="@Model.Plan.Id" asp-route-templateKey="@recommendation.Key">Prepare this campaign</a>
                </article>
            }
        </div>
    </section>
}

<div class="dashboard-stat-grid mt-4">
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-broadcast"></i></span>
        <div>
            <div class="app-stat-label">Reached by this plan</div>
            <div class="app-stat-value">@Model.Metrics.Reach</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-chat-dots"></i></span>
        <div>
            <div class="app-stat-label">Interactions</div>
            <div class="app-stat-value">@Model.Metrics.Interactions</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-bag-check"></i></span>
        <div>
            <div class="app-stat-label">Subscriptions/purchases</div>
            <div class="app-stat-value">@Model.Metrics.Conversions</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-envelope-paper"></i></span>
        <div>
            <div class="app-stat-label">Landing views</div>
            <div class="app-stat-value">@Model.Metrics.LandingViews</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-person-plus-fill"></i></span>
        <div>
            <div class="app-stat-label">Captured leads</div>
            <div class="app-stat-value">@Model.Metrics.CapturedLeads</div>
        </div>
    </div>
</div>

@if (Model.Plan.LandingPage is not null)
{
    var landingUrl = Url.Page("/Campaign", new { slug = Model.Plan.LandingPage.Slug });
    <section class="surface app-panel mt-4">
        <div class="app-panel-header">
            <div>
                <h2>Landing page and form</h2>
                <p>The landing page stays draft/approved until the campaign is scheduled. After authorized publication, it captures leads into this report.</p>
            </div>
            @if (Model.Plan.LandingPage.Status == "Published")
            {
                <a class="btn btn-sm btn-outline-secondary" href="@landingUrl" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>Open public page</a>
            }
        </div>

        <article class="landing-review-card">
            <div class="planner-post-head">
                <span>@landingUrl</span>
                <span class="badge @StatusClass(Model.Plan.LandingPage.Status)">@Model.Plan.LandingPage.Status</span>
            </div>
            <h3>@Model.Plan.LandingPage.Headline</h3>
            <p class="planner-hook">@Model.Plan.LandingPage.Subheadline</p>
            <div class="landing-body-preview">
                @foreach (var paragraph in Model.Plan.LandingPage.Body.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <p>@paragraph</p>
                }
            </div>
            <div class="planner-card-footer">
                <span>@Model.Plan.LandingPage.ViewCount views Â· @Model.Plan.LandingPage.Leads.Count captured leads</span>
                @if (Model.Plan.LandingPage.Status == "Draft")
                {
                    <form method="post" asp-page-handler="ApproveLanding" asp-route-id="@Model.Plan.Id">
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Approve landing</button>
                    </form>
                }
            </div>

            @if (Model.Plan.LandingPage.Status is "Draft" or "Approved")
            {
                <details class="planner-editor">
                    <summary><i class="bi bi-pencil-square"></i>Edit landing page</summary>
                    <form method="post" asp-page-handler="UpdateLanding" asp-route-id="@Model.Plan.Id" class="planner-editor-form">
                        <div class="planner-editor-grid">
                            <label class="planner-editor-field planner-editor-field-full">
                                <span>Headline</span>
                                <input class="form-control" name="headline" maxlength="180" value="@Model.Plan.LandingPage.Headline" />
                            </label>
                            <label class="planner-editor-field planner-editor-field-full">
                                <span>Subheadline</span>
                                <textarea class="form-control" name="subheadline" maxlength="260" rows="2">@Model.Plan.LandingPage.Subheadline</textarea>
                            </label>
                            <label class="planner-editor-field planner-editor-field-full">
                                <span>Body</span>
                                <textarea class="form-control" name="body" maxlength="1600" rows="7">@Model.Plan.LandingPage.Body</textarea>
                            </label>
                            <label class="planner-editor-field">
                                <span>CTA</span>
                                <input class="form-control" name="primaryCallToAction" maxlength="120" value="@Model.Plan.LandingPage.PrimaryCallToAction" />
                            </label>
                            <label class="planner-editor-field">
                                <span>Form title</span>
                                <input class="form-control" name="formTitle" maxlength="160" value="@Model.Plan.LandingPage.FormTitle" />
                            </label>
                            <label class="planner-editor-field planner-editor-field-full">
                                <span>Form intro</span>
                                <input class="form-control" name="formIntro" maxlength="260" value="@Model.Plan.LandingPage.FormIntro" />
                            </label>
                            <label class="planner-editor-field planner-editor-field-full">
                                <span>Thank-you message</span>
                                <input class="form-control" name="thankYouMessage" maxlength="260" value="@Model.Plan.LandingPage.ThankYouMessage" />
                            </label>
                        </div>
                        <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-save2 me-1"></i>Save landing page</button>
                    </form>
                </details>
            }
        </article>

        @if (Model.Plan.LandingPage.Leads.Any())
        {
            <div class="table-responsive mt-3">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Lead</th>
                            <th>Company</th>
                            <th>Source</th>
                            <th>Captured</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var lead in Model.Plan.LandingPage.Leads.OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <tr>
                            <td><strong>@lead.Name</strong><div class="text-muted">@lead.Email</div></td>
                            <td><strong>@lead.Company</strong><div class="text-muted">@lead.Role</div></td>
                            <td>@lead.Source</td>
                            <td class="text-muted">@lead.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        <div class="utm-grid mt-3">
            <div>
                <h3>UTM links</h3>
                <p class="muted mb-0">Use these links in posts, emails and ads so captured leads keep their source in the report.</p>
            </div>
            <div class="utm-link-list">
                @foreach (var platform in Model.Plan.Platforms.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    <code>@BuildUtmUrl(Model.Plan.LandingPage.Slug, platform, "social")</code>
                }
                <code>@BuildUtmUrl(Model.Plan.LandingPage.Slug, "email", "email")</code>
            </div>
        </div>
    </section>
}

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Suggested social calendar</h2>
            <p>Every item is platform-specific and stays in draft until approved.</p>
        </div>
    </div>

    <div class="planner-calendar">
        @foreach (var day in Model.Plan.Posts.GroupBy(x => x.ScheduledForUtc.Date))
        {
            <article class="planner-day">
                <div class="planner-day-head">
                    <strong>@day.Key.ToString("ddd, MMM d")</strong>
                    <span>@day.Count() post@(day.Count() == 1 ? "" : "s")</span>
                </div>
                <div class="planner-post-grid">
                    @foreach (var post in day)
                    {
                        <div class="planner-post-card">
                            <div class="planner-post-head">
                                <span class="planner-platform">@PlatformIcon(post.Platform) @post.Platform</span>
                                <span class="badge @StatusClass(post.Status)">@post.Status</span>
                            </div>
                            <h3>@post.Title</h3>
                            <p class="planner-hook">@post.Hook</p>
                            <p>@post.Caption</p>
                            <small>@post.CreativeBrief</small>
                            <div class="planner-tags">@post.Hashtags</div>
                            @if (post.Status is "Draft" or "Approved")
                            {
                                <details class="planner-editor">
                                    <summary><i class="bi bi-pencil-square"></i>Edit</summary>
                                    <form method="post" asp-page-handler="UpdatePost" asp-route-id="@Model.Plan.Id" class="planner-editor-form">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <div class="planner-editor-grid">
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>Title</span>
                                                <input class="form-control" name="title" maxlength="140" value="@post.Title" />
                                            </label>
                                            <label class="planner-editor-field">
                                                <span>Publish date</span>
                                                <input class="form-control" type="datetime-local" name="scheduledForLocal" value="@post.ScheduledForUtc.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
                                            </label>
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>Hook</span>
                                                <textarea class="form-control" name="hook" maxlength="300" rows="2">@post.Hook</textarea>
                                            </label>
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>Caption</span>
                                                <textarea class="form-control" name="caption" maxlength="1600" rows="5">@post.Caption</textarea>
                                            </label>
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>Creative brief</span>
                                                <textarea class="form-control" name="creativeBrief" maxlength="900" rows="3">@post.CreativeBrief</textarea>
                                            </label>
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>Hashtags</span>
                                                <input class="form-control" name="hashtags" maxlength="300" value="@post.Hashtags" />
                                            </label>
                                            <label class="planner-editor-field planner-editor-field-full">
                                                <span>CTA</span>
                                                <input class="form-control" name="callToAction" maxlength="180" value="@post.CallToAction" />
                                            </label>
                                        </div>
                                        <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-save2 me-1"></i>Save changes</button>
                                    </form>
                                </details>
                            }
                            <div class="planner-card-footer">
                                <span>@post.EstimatedReach reach · @post.EstimatedInteractions interactions · @post.EstimatedConversions conversions</span>
                                @if (post.Status == "Draft")
                                {
                                    <form method="post" asp-page-handler="ApprovePost" asp-route-id="@Model.Plan.Id">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <button class="btn btn-sm btn-outline-secondary" type="submit">Approve</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</section>

<div class="planner-two-col mt-4">
    <section class="surface app-panel">
        <div class="app-panel-header">
            <div>
                <h2>Email sequence</h2>
                <p>Templates for different days in the campaign.</p>
            </div>
        </div>

        <div class="planner-email-list">
            @foreach (var email in Model.Plan.Emails)
            {
                <article class="planner-email-card">
                    <div class="planner-post-head">
                        <span>Day @email.DayNumber · @email.ScheduledForUtc.ToLocalTime().ToString("MMM d, HH:mm")</span>
                        <span class="badge @StatusClass(email.Status)">@email.Status</span>
                    </div>
                    <h3>@email.Subject</h3>
                    <p class="muted">@email.PreviewText</p>
                    <pre>@email.Body</pre>
                    @if (email.Status is "Draft" or "Approved")
                    {
                        <details class="planner-editor">
                            <summary><i class="bi bi-pencil-square"></i>Edit</summary>
                            <form method="post" asp-page-handler="UpdateEmail" asp-route-id="@Model.Plan.Id" class="planner-editor-form">
                                <input type="hidden" name="emailId" value="@email.Id" />
                                <div class="planner-editor-grid">
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Subject</span>
                                        <input class="form-control" name="subject" maxlength="160" value="@email.Subject" />
                                    </label>
                                    <label class="planner-editor-field">
                                        <span>Send date</span>
                                        <input class="form-control" type="datetime-local" name="scheduledForLocal" value="@email.ScheduledForUtc.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
                                    </label>
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Preview text</span>
                                        <textarea class="form-control" name="previewText" maxlength="220" rows="2">@email.PreviewText</textarea>
                                    </label>
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Email body</span>
                                        <textarea class="form-control" name="body" maxlength="4000" rows="9">@email.Body</textarea>
                                    </label>
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Audience segment</span>
                                        <input class="form-control" name="audienceSegment" maxlength="160" value="@email.AudienceSegment" />
                                    </label>
                                </div>
                                <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-save2 me-1"></i>Save changes</button>
                            </form>
                        </details>
                    }
                    <div class="planner-card-footer">
                        <span>@email.EstimatedReach reach · @email.EstimatedInteractions interactions · @email.EstimatedConversions conversions</span>
                        @if (email.Status == "Draft")
                        {
                            <form method="post" asp-page-handler="ApproveEmail" asp-route-id="@Model.Plan.Id">
                                <input type="hidden" name="emailId" value="@email.Id" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Approve</button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="surface app-panel">
        <div class="app-panel-header">
            <div>
                <h2>Lead suggestions</h2>
                <p>Company profiles, areas and roles to search for outbound email lists.</p>
            </div>
        </div>

        <div class="planner-lead-list">
            @foreach (var lead in Model.Plan.Leads)
            {
                <article class="planner-lead-card">
                    <div class="planner-post-head">
                        <span>@lead.Industry</span>
                        <span class="badge @StatusClass(lead.Status)">@lead.Status</span>
                    </div>
                    <h3>@lead.CompanyProfile</h3>
                    <p><strong>Role:</strong> @lead.ContactRole</p>
                    <p><strong>Email search:</strong> @lead.EmailSearchHint</p>
                    <p class="muted">@lead.Reason</p>
                    @if (lead.Status is "Suggested" or "Accepted")
                    {
                        <details class="planner-editor">
                            <summary><i class="bi bi-pencil-square"></i>Edit</summary>
                            <form method="post" asp-page-handler="UpdateLead" asp-route-id="@Model.Plan.Id" class="planner-editor-form">
                                <input type="hidden" name="leadId" value="@lead.Id" />
                                <div class="planner-editor-grid">
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Company profile</span>
                                        <input class="form-control" name="companyProfile" maxlength="160" value="@lead.CompanyProfile" />
                                    </label>
                                    <label class="planner-editor-field">
                                        <span>Industry</span>
                                        <input class="form-control" name="industry" maxlength="120" value="@lead.Industry" />
                                    </label>
                                    <label class="planner-editor-field">
                                        <span>Contact role</span>
                                        <input class="form-control" name="contactRole" maxlength="120" value="@lead.ContactRole" />
                                    </label>
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Email search</span>
                                        <input class="form-control" name="emailSearchHint" maxlength="180" value="@lead.EmailSearchHint" />
                                    </label>
                                    <label class="planner-editor-field planner-editor-field-full">
                                        <span>Reason</span>
                                        <textarea class="form-control" name="reason" maxlength="500" rows="3">@lead.Reason</textarea>
                                    </label>
                                </div>
                                <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-save2 me-1"></i>Save changes</button>
                            </form>
                        </details>
                    }
                    @if (lead.Status == "Suggested")
                    {
                        <form method="post" asp-page-handler="ApproveLead" asp-route-id="@Model.Plan.Id">
                            <input type="hidden" name="leadId" value="@lead.Id" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Accept target</button>
                        </form>
                    }
                </article>
            }
        </div>
    </section>
</div>

@functions {
    private static string FrequencyLabel(string frequency)
    {
        return frequency switch
        {
            "Weekdays" => "weekdays",
            "ThreePerWeek" => "3 times per week",
            "Weekly" => "weekly",
            _ => "daily"
        };
    }

    private static string StatusClass(string status)
    {
        return status switch
        {
            "Published" or "Sent" => "text-bg-success",
            "Scheduled" => "text-bg-info",
            "Approved" or "Accepted" => "text-bg-primary",
            "NeedsAuthorization" => "text-bg-warning",
            _ => "text-bg-secondary"
        };
    }

    private static string PlatformIcon(string platform)
    {
        return platform switch
        {
            "TikTok" => "TT",
            "Instagram" => "IG",
            "Facebook" => "f",
            "LinkedIn" => "in",
            "YouTube Shorts" => "YT",
            _ => "#"
        };
    }

    private string LocationLabel()
    {
        if (Model.Plan.AudienceLocationScope.Equals("Country", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(Model.Plan.AudienceCountry))
            return Model.Plan.AudienceCountry;

        if (Model.Plan.AudienceLocationScope.Equals("City", StringComparison.OrdinalIgnoreCase))
        {
            var place = string.Join(", ", new[] { Model.Plan.AudienceCity, Model.Plan.AudienceCountry }.Where(x => !string.IsNullOrWhiteSpace(x)));
            if (string.IsNullOrWhiteSpace(place))
                place = "Selected city";

            return Model.Plan.AudienceRadiusKm is > 0 ? $"{place} + {Model.Plan.AudienceRadiusKm} km" : place;
        }

        return "Worldwide";
    }

    private string BuildUtmUrl(string slug, string source, string medium)
    {
        var baseUrl = Url.Page("/Campaign", new { slug }) ?? $"/campaign/{slug}";
        var campaign = Model.Plan.ProductName.ToLowerInvariant().Replace(" ", "-", StringComparison.Ordinal);
        return $"{baseUrl}?utm_source={Uri.EscapeDataString(source.ToLowerInvariant())}&utm_medium={Uri.EscapeDataString(medium)}&utm_campaign={Uri.EscapeDataString(campaign)}";
    }
}
