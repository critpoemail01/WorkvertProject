@page
@model Alivert.Pages.App.Planner.IndexModel
@{
    ViewData["Title"] = "AI campaign planner";
}

<section class="app-page-hero ai-planner-hero">
    <div>
        <span class="tag mb-3">AI campaign planner</span>
        <h1 class="hero-title fw-bold mb-2">Turn a company URL into a complete campaign funnel.</h1>
        <p class="lead muted mb-0">Promovert builds the Business DNA, posts, emails, landing page, approval workflow, lead capture and report for the next campaign.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Dashboard"><i class="bi bi-bar-chart me-1"></i>Dashboard</a>
    </div>
</section>

<div class="planner-layout mt-4">
    <form method="post" asp-page-handler="Generate" class="surface app-panel planner-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @if (!string.IsNullOrWhiteSpace(Model.SuggestionMessage))
        {
            <div class="alert alert-success mb-3">
                <i class="bi bi-magic me-1"></i>@Model.SuggestionMessage
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LeadDiscoveryMessage))
        {
            <div class="alert alert-info mb-3">
                <i class="bi bi-building-add me-1"></i>@Model.LeadDiscoveryMessage
            </div>
        }
        <div class="app-panel-header">
            <div>
                <h2>Campaign intelligence</h2>
                <p>Add a URL and let Promovert suggest the brief, then adjust anything before generating posts, emails, a landing page and lead capture.</p>
            </div>
        </div>
        <input asp-for="Input.DetectedApplicationType" type="hidden" />

        <div class="row g-3">
            <div class="col-12">
                <section class="mvp-funnel-panel">
                    <div>
                        <span class="tag">Recommended MVP</span>
                        <h3>14-day complete campaign funnel</h3>
                        <p>Use this to keep the first version focused: company URL, Business DNA, 3 suggested campaigns, one selected campaign, 5 LinkedIn posts, 5 Instagram posts, 3 emails, 1 landing page, UTM links, lead capture and a simple results dashboard.</p>
                    </div>
                    <div class="mvp-funnel-actions">
                        <button class="btn btn-outline-secondary" type="submit" formaction="?handler=UseMvp" formnovalidate>
                            <i class="bi bi-magic me-1"></i>Use MVP funnel
                        </button>
                        <span>Initial integrations: LinkedIn, Instagram/Facebook, Brevo or Mailchimp, Google Analytics/Pixel/UTM.</span>
                    </div>
                </section>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ProductName" class="form-label"></label>
                <input asp-for="Input.ProductName" class="form-control" placeholder="Promovert, Acme CRM, AI invoicing..." />
                <span asp-validation-for="Input.ProductName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ProductUrl" class="form-label"></label>
                <div class="planner-url-row">
                    <input asp-for="Input.ProductUrl" class="form-control" placeholder="https://app.example.com" />
                    <button class="btn btn-outline-secondary" type="submit" formaction="?handler=Suggest" formnovalidate>
                        <i class="bi bi-magic me-1"></i>Suggest from URL
                    </button>
                </div>
                <div class="form-text">Use this to auto-fill the campaign brief from the application website.</div>
                <span asp-validation-for="Input.ProductUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Input.CompanyOrIdea" class="form-label"></label>
                <textarea asp-for="Input.CompanyOrIdea" class="form-control" rows="3" placeholder="What the company/app does, business model and current stage"></textarea>
                <span asp-validation-for="Input.CompanyOrIdea" class="text-danger"></span>
            </div>
            @if (Model.CompanyLearning.HasData)
            {
                <div class="col-12">
                    <section class="company-learning-panel">
                        <div class="company-learning-head">
                            <span><i class="bi bi-graph-up-arrow"></i></span>
                            <div>
                                <h3>Company learning</h3>
                                <p>@Model.CompanyLearning.Summary</p>
                            </div>
                        </div>
                        <div class="company-learning-grid">
                            <article>
                                <strong>@Model.CompanyLearning.CampaignsAnalyzed</strong>
                                <span>campaigns learned</span>
                            </article>
                            <article>
                                <strong>@Model.CompanyLearning.LeadsGenerated</strong>
                                <span>leads attributed</span>
                            </article>
                            <article>
                                <strong>@string.Join(", ", Model.CompanyLearning.PreferredPlatforms)</strong>
                                <span>preferred channels</span>
                            </article>
                        </div>
                        <div class="company-learning-columns">
                            <div>
                                <strong>This company converts better with</strong>
                                @foreach (var pattern in Model.CompanyLearning.WinningPatterns)
                                {
                                    <span><i class="bi bi-check2"></i>@pattern</span>
                                }
                            </div>
                            <div>
                                <strong>Next campaign adaptation</strong>
                                @foreach (var adaptation in Model.CompanyLearning.RecommendedAdaptations)
                                {
                                    <span><i class="bi bi-arrow-repeat"></i>@adaptation</span>
                                }
                            </div>
                        </div>
                        <div class="company-learning-recommendation">
                            <i class="bi bi-stars"></i>
                            <span>@Model.CompanyLearning.RecommendedCampaignBrief</span>
                        </div>
                    </section>
                </div>
            }
            @if (Model.CampaignRecommendations.Any())
            {
                <div class="col-12">
                    <section class="campaign-library-panel">
                        <div class="lead-discovery-head">
                            <div>
                                <h3>Campaign library by sector</h3>
                                <p class="form-text mb-0">Suggested complete campaigns for this type of company. Apply one to replace the generic plan with a sector-specific campaign.</p>
                            </div>
                        </div>
                        <div class="campaign-library-grid">
                            @foreach (var recommendation in Model.CampaignRecommendations)
                            {
                                <article class="campaign-template-card">
                                    <span class="tag">@recommendation.Sector</span>
                                    <h4>@recommendation.Title</h4>
                                    <p>@recommendation.Strategy</p>
                                    <dl>
                                        <div><dt>Goal</dt><dd>@recommendation.Goal</dd></div>
                                        <div><dt>Offer</dt><dd>@recommendation.Offer</dd></div>
                                        <div><dt>Channels</dt><dd>@string.Join(" + ", recommendation.Platforms)</dd></div>
                                        <div><dt>Duration</dt><dd>@recommendation.DurationDays days</dd></div>
                                    </dl>
                                    <button class="btn btn-sm btn-outline-secondary" type="submit" formaction="?handler=UseTemplate&templateKey=@recommendation.Key" formnovalidate>
                                        Apply campaign
                                    </button>
                                </article>
                            }
                        </div>
                    </section>
                </div>
            }
            <div class="col-md-6">
                <label asp-for="Input.TargetAudience" class="form-label"></label>
                <textarea asp-for="Input.TargetAudience" class="form-control" rows="4" placeholder="Founders, local clinics, B2B SaaS teams, ecommerce managers..."></textarea>
                <span asp-validation-for="Input.TargetAudience" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ValueProposition" class="form-label"></label>
                <textarea asp-for="Input.ValueProposition" class="form-control" rows="4" placeholder="The main result, pain solved and why people should care"></textarea>
                <span asp-validation-for="Input.ValueProposition" class="text-danger"></span>
            </div>
            <div class="col-12">
                <section class="planner-location" data-location-targeting>
                    <div class="planner-location-head">
                        <div>
                            <label class="form-label mb-1">Audience region</label>
                            <p class="form-text mb-0">Choose whether this campaign targets the world, a country, or a city with a radius.</p>
                        </div>
                        <span class="planner-location-summary" data-location-summary>Worldwide campaign</span>
                    </div>

                    <div class="planner-location-modes" role="radiogroup" aria-label="Audience region">
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="World" checked="@(Model.Input.AudienceLocationScope == "World")" />
                            <span><i class="bi bi-globe2"></i>World</span>
                        </label>
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="Country" checked="@(Model.Input.AudienceLocationScope == "Country")" />
                            <span><i class="bi bi-flag"></i>Country</span>
                        </label>
                        <label>
                            <input type="radio" name="Input.AudienceLocationScope" value="City" checked="@(Model.Input.AudienceLocationScope == "City")" />
                            <span><i class="bi bi-geo-alt"></i>City radius</span>
                        </label>
                    </div>
                    <span asp-validation-for="Input.AudienceLocationScope" class="text-danger"></span>

                    <div class="planner-location-grid mt-3">
                        <div class="planner-location-country" data-location-panel="country">
                            <label asp-for="Input.AudienceCountry" class="form-label"></label>
                            <input asp-for="Input.AudienceCountry" class="form-control" placeholder="Portugal, Spain, United States..." data-location-country />
                            <span asp-validation-for="Input.AudienceCountry" class="text-danger"></span>
                        </div>
                        <div class="planner-location-city" data-location-panel="city">
                            <label asp-for="Input.AudienceCity" class="form-label"></label>
                            <input asp-for="Input.AudienceCity" class="form-control" placeholder="Lisbon, Porto, Madrid..." data-location-city />
                            <span asp-validation-for="Input.AudienceCity" class="text-danger"></span>
                        </div>
                        <div class="planner-location-city" data-location-panel="city">
                            <label asp-for="Input.AudienceRadiusKm" class="form-label"></label>
                            <div class="planner-radius-row">
                                <input asp-for="Input.AudienceRadiusKm" class="form-control" type="number" min="1" max="1000" step="1" data-location-radius />
                                <span>km</span>
                            </div>
                            <input class="form-range mt-2" type="range" min="1" max="250" step="1" value="@Math.Min(Model.Input.AudienceRadiusKm, 250)" data-location-radius-range />
                            <span asp-validation-for="Input.AudienceRadiusKm" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="planner-map-wrap mt-3" data-location-panel="city">
                        <div class="planner-map" data-location-map></div>
                        <div class="planner-map-meta">
                            <span>Click the map to set the campaign center.</span>
                            <span data-location-coordinates>No point selected yet.</span>
                        </div>
                    </div>

                    <input asp-for="Input.AudienceLatitude" type="hidden" data-location-lat />
                    <input asp-for="Input.AudienceLongitude" type="hidden" data-location-lng />
                    <span asp-validation-for="Input.AudienceLatitude" class="text-danger"></span>
                    <span asp-validation-for="Input.AudienceLongitude" class="text-danger"></span>
                </section>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.CampaignGoal" class="form-label"></label>
                <input asp-for="Input.CampaignGoal" class="form-control" list="campaignGoalOptions" placeholder="subscriptions, demos, purchases..." />
                <datalist id="campaignGoalOptions">
                    @foreach (var goal in Model.GoalOptions)
                    {
                        <option value="@goal"></option>
                    }
                </datalist>
                <span asp-validation-for="Input.CampaignGoal" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Tone" class="form-label"></label>
                <input asp-for="Input.Tone" class="form-control" placeholder="direct, premium, educational..." />
                <span asp-validation-for="Input.Tone" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.StartDate" class="form-label"></label>
                <input asp-for="Input.StartDate" class="form-control" type="date" />
                <span asp-validation-for="Input.StartDate" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.DurationDays" class="form-label"></label>
                <select asp-for="Input.DurationDays" class="form-select">
                    <option value="7">1 week</option>
                    <option value="14">2 weeks</option>
                    <option value="30">1 month</option>
                    <option value="60">2 months</option>
                    <option value="90">3 months</option>
                </select>
                <span asp-validation-for="Input.DurationDays" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Frequency" class="form-label"></label>
                <select asp-for="Input.Frequency" class="form-select">
                    <option value="Daily">Every day</option>
                    <option value="Weekdays">Weekdays</option>
                    <option value="ThreePerWeek">3 times per week</option>
                    <option value="Weekly">Weekly</option>
                    <option value="Mvp14">MVP: 5 LinkedIn + 5 Instagram over 14 days</option>
                </select>
                <span asp-validation-for="Input.Frequency" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Networks</label>
                <div class="planner-platforms">
                    @foreach (var platform in Model.PlatformOptions)
                    {
                        <label>
                            <input type="checkbox" name="Input.Platforms" value="@platform" checked="@Model.Input.Platforms.Contains(platform)" />
                            <span>@platform</span>
                        </label>
                    }
                </div>
                <span asp-validation-for="Input.Platforms" class="text-danger"></span>
            </div>
            <div class="col-12">
                <section class="lead-discovery-panel">
                    <div class="lead-discovery-head">
                        <div>
                            <label asp-for="Input.UseCrmLeads" class="form-label mb-1"></label>
                            <p class="form-text mb-0">@Model.CrmLeadEmails CRM lead email@(Model.CrmLeadEmails == 1 ? "" : "s") available after consent/exclusion filtering from @Model.CrmLeadCount imported contact@(Model.CrmLeadCount == 1 ? "" : "s"). Use these when your own prospecting team already found the audience.</p>
                        </div>
                        <a class="btn btn-outline-secondary" asp-page="/App/Crm/Index">
                            <i class="bi bi-database-add me-1"></i>Import CRM leads
                        </a>
                    </div>
                    <div class="crm-focus-grid mt-3">
                        <label class="crm-focus-toggle">
                            <input asp-for="Input.UseCrmLeads" />
                            <span>Focus this campaign on imported CRM leads</span>
                        </label>
                        <label>
                            <span class="form-label">Filter by stage, tag, industry, company or location</span>
                            <input asp-for="Input.CrmLeadFilter" class="form-control" placeholder="Qualified, manufacturing, Portugal, demo..." />
                        </label>
                        <label>
                            <span class="form-label">Max CRM leads</span>
                            <input asp-for="Input.CrmLeadLimit" class="form-control" type="number" min="1" max="500" />
                        </label>
                    </div>
                    <span asp-validation-for="Input.CrmLeadFilter" class="text-danger"></span>
                    <span asp-validation-for="Input.CrmLeadLimit" class="text-danger"></span>
                </section>
            </div>
            <div class="col-12">
                <label asp-for="Input.EmailAudience" class="form-label"></label>
                <textarea asp-for="Input.EmailAudience" class="form-control" rows="5" placeholder="ana@example.com&#10;joao@example.com&#10;marketing@empresa.pt"></textarea>
                <div class="form-text">One email per line. Promovert generates a multi-day sequence and estimates reach, replies/interactions and conversions.</div>
                <span asp-validation-for="Input.EmailAudience" class="text-danger"></span>
            </div>
            <div class="col-12">
                <section class="lead-discovery-panel">
                    <div class="lead-discovery-head">
                        <div>
                            <label asp-for="Input.LeadCompanyUrls" class="form-label mb-1"></label>
                            <p class="form-text mb-0">Paste public company websites or contact pages, one per line. Promovert extracts visible contact emails and adds them above for review.</p>
                        </div>
                        <button class="btn btn-outline-secondary" type="submit" formaction="?handler=DiscoverLeads" formnovalidate>
                            <i class="bi bi-search me-1"></i>Find potential clients
                        </button>
                    </div>
                    <textarea asp-for="Input.LeadCompanyUrls" class="form-control mt-3" rows="4" placeholder="https://empresa.pt&#10;https://example.com/contact"></textarea>
                    <span asp-validation-for="Input.LeadCompanyUrls" class="text-danger"></span>

                    @if (Model.LeadSearchQueries.Any() || Model.DiscoveredLeadEmails.Any() || Model.LeadDiscoveryWarnings.Any())
                    {
                        <div class="lead-discovery-results">
                            @if (Model.LeadSearchQueries.Any())
                            {
                                <div>
                                    <strong>Prospecting searches</strong>
                                    <div class="lead-query-list">
                                        @foreach (var query in Model.LeadSearchQueries)
                                        {
                                            <a href="@query.Url" target="_blank" rel="noopener">@query.Label <i class="bi bi-box-arrow-up-right"></i></a>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.DiscoveredLeadEmails.Any())
                            {
                                <div>
                                    <strong>Public emails found</strong>
                                    <div class="lead-email-list">
                                        @foreach (var leadEmail in Model.DiscoveredLeadEmails)
                                        {
                                            <span>@leadEmail.Email <small>@leadEmail.SourceHost</small></span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (Model.LeadDiscoveryWarnings.Any())
                            {
                                <div class="lead-discovery-warnings">
                                    @foreach (var warning in Model.LeadDiscoveryWarnings)
                                    {
                                        <span><i class="bi bi-info-circle"></i>@warning</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </section>
            </div>
        </div>

        <div class="alert-form-actions mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-stars me-1"></i>Generate AI plan</button>
            <span class="muted">Suggestions stay in draft until you approve them.</span>
        </div>
    </form>

    <aside class="surface app-panel planner-side">
        <span class="tag">What gets generated</span>
        <div class="planner-feature">
            <i class="bi bi-rocket-takeoff"></i>
            <div>
                <strong>MVP funnel</strong>
                <span>14 days with 5 LinkedIn posts, 5 Instagram posts, 3 emails, 1 landing page and UTM tracking.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-calendar2-week"></i>
            <div>
                <strong>Publishing calendar</strong>
                <span>Posts and video scripts for each selected network across the selected period.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-check2-square"></i>
            <div>
                <strong>Approval workflow</strong>
                <span>Review drafts, approve all, schedule approved content and publish due items.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-envelope-paper"></i>
            <div>
                <strong>Email sequence</strong>
                <span>Multiple templates for different days, personalized with first-name placeholders.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-building-add"></i>
            <div>
                <strong>Lead ideas</strong>
                <span>Suggested industries, roles and search prompts for prospecting.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-window-stack"></i>
            <div>
                <strong>Landing page + form</strong>
                <span>A campaign page captures leads after authorized publication.</span>
            </div>
        </div>
        <div class="planner-feature">
            <i class="bi bi-database-add"></i>
            <div>
                <strong>CRM audience</strong>
                <span>Imported CRM leads can become the focus of the campaign.</span>
            </div>
        </div>
    </aside>
</div>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent AI plans</h2>
            <p>Open a plan to approve, schedule or inspect suggested content.</p>
        </div>
    </div>

    @if (!Model.RecentPlans.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-stars"></i>
            <span>No AI plans yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Period</th>
                        <th>Region</th>
                        <th>Platforms</th>
                        <th>Output</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var plan in Model.RecentPlans)
                {
                    <tr>
                        <td>@plan.ProductName</td>
                        <td>@plan.StartDate.ToString("MMM d") - @plan.EndDate.ToString("MMM d")</td>
                        <td>@plan.Location</td>
                        <td>@plan.Platforms.Replace(",", ", ")</td>
                        <td>@plan.Posts posts / @plan.Emails emails / landing page</td>
                        <td><span class="badge text-bg-secondary">@plan.Status</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Details" asp-route-id="@plan.Id">Open</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/alivert-location-targeting.js" asp-append-version="true"></script>
}
