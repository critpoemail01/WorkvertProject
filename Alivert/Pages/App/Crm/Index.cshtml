@page
@model Alivert.Pages.App.Crm.IndexModel
@{
    ViewData["Title"] = "CSV lead import";
}

<section class="app-page-hero">
    <div>
        <span class="tag mb-3">CSV lead import</span>
        <h1 class="hero-title fw-bold mb-2">Use your prospecting team's leads in campaigns.</h1>
        <p class="lead muted mb-0">For now, import leads by pasting a CSV export. Campaigns can then focus on these contacts inside the campaign builder.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg" asp-page="/App/Planner/Index" asp-fragment="campaign-config"><i class="bi bi-plus-lg me-1"></i>New campaign</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info mt-4 mb-0">@Model.StatusMessage</div>
}

<div class="dashboard-stat-grid mt-4">
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-people"></i></span>
        <div>
            <div class="app-stat-label">CRM leads</div>
            <div class="app-stat-value">@Model.TotalLeads</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-envelope-check"></i></span>
        <div>
            <div class="app-stat-label">With email</div>
            <div class="app-stat-value">@Model.LeadsWithEmail</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-bullseye"></i></span>
        <div>
            <div class="app-stat-label">Campaign-ready</div>
            <div class="app-stat-value">@Model.ReadyForCampaign</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-shield-check"></i></span>
        <div>
            <div class="app-stat-label">Consented</div>
            <div class="app-stat-value">@Model.AuthorizedContacts</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-shield-x"></i></span>
        <div>
            <div class="app-stat-label">Suppressed</div>
            <div class="app-stat-value">@Model.SuppressedContacts</div>
        </div>
    </div>
</div>

<section class="surface app-panel mt-4 crm-csv-import-panel">
    <div class="app-panel-header">
        <div>
            <h2>Import leads by CSV</h2>
            <p>Paste a CSV export from your CRM or prospecting list. Supported headers include name, email, company, role, industry, country, city, stage and tags.</p>
        </div>
    </div>

    <form method="post" asp-page-handler="ImportLeads" class="crm-form">
        <div class="row g-3">
            <div class="col-md-5">
                <label asp-for="Import.Source" class="form-label"></label>
                <input asp-for="Import.Source" class="form-control" placeholder="CSV import, SDR list, trade show..." />
                <span asp-validation-for="Import.Source" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Import.ConsentStatus" class="form-label"></label>
                <select asp-for="Import.ConsentStatus" class="form-select">
                    @foreach (var status in Model.ConsentStatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Import.ConsentStatus" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Import.ConsentSource" class="form-label"></label>
                <input asp-for="Import.ConsentSource" class="form-control" placeholder="Opt-in form, event, CSV consent..." />
                <span asp-validation-for="Import.ConsentSource" class="text-danger"></span>
            </div>
        </div>

        <label asp-for="Import.RawLeads" class="form-label mt-3"></label>
        <textarea asp-for="Import.RawLeads" class="form-control crm-import-box" rows="10" placeholder="name,email,company,role,industry,country,city,stage,tags&#10;Ana Silva,ana@empresa.pt,Empresa SA,Operations Manager,Manufacturing,Portugal,Porto,Qualified,industrial"></textarea>
        <span asp-validation-for="Import.RawLeads" class="text-danger"></span>

        <div class="alert-form-actions mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-cloud-arrow-up me-1"></i>Import leads</button>
            <span class="muted">CSV import is the only lead import mode for now. The campaign builder excludes unsubscribed and suppressed contacts from email campaigns.</span>
        </div>
    </form>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Consent & Email Hub</h2>
            <p>Manage authorized contacts, unsubscribe status and exclusion lists before the campaign builder uses CRM emails in campaigns.</p>
        </div>
    </div>
    <div class="consent-hub-grid">
        <article>
            <span><i class="bi bi-envelope-check"></i></span>
            <strong>Allowed for outreach</strong>
            <p>Unknown and consented contacts can be selected for review. Consented contacts carry an explicit source.</p>
        </article>
        <article>
            <span><i class="bi bi-person-x"></i></span>
            <strong>Exclusion list</strong>
            <p>Unsubscribed or suppressed contacts are blocked from campaign targeting and stay visible for audit.</p>
        </article>
        <article>
            <span><i class="bi bi-window-stack"></i></span>
            <strong>Landing lead capture</strong>
            <p>Public campaign forms capture consent and add leads back into the CRM with campaign and channel origin.</p>
        </article>
    </div>
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Imported CRM leads</h2>
            <p>These contacts become a selectable audience in the campaign builder.</p>
        </div>
    </div>

    @if (!Model.Leads.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-person-lines-fill"></i>
            <span>No CRM leads imported yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Contact</th>
                        <th>Company</th>
                        <th>Segment</th>
                        <th>Location</th>
                        <th>Stage</th>
                        <th>Consent</th>
                        <th>Source</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var lead in Model.Leads)
                {
                    <tr>
                        <td>
                            <strong>@lead.ContactName</strong>
                            <div class="text-muted">@lead.Email</div>
                        </td>
                        <td>
                            <strong>@lead.CompanyName</strong>
                            <div class="text-muted">@lead.Role</div>
                        </td>
                        <td>
                            <span>@lead.Industry</span>
                            <div class="text-muted">@lead.Tags</div>
                        </td>
                        <td>@string.Join(", ", new[] { lead.City, lead.Country }.Where(x => !string.IsNullOrWhiteSpace(x)))</td>
                        <td><span class="badge text-bg-secondary">@lead.Stage</span></td>
                        <td>
                            <form method="post" asp-page-handler="UpdateConsent" asp-route-leadId="@lead.Id" class="crm-consent-form">
                                <select class="form-select form-select-sm" name="consentStatus">
                                    @foreach (var status in Model.ConsentStatusOptions)
                                    {
                                        <option value="@status" selected="@(lead.ConsentStatus == status)">@status</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Save</button>
                            </form>
                            <div class="text-muted small">@lead.ConsentSource</div>
                        </td>
                        <td>
                            <span>@lead.Source</span>
                            <div class="text-muted">@lead.Tags</div>
                        </td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="DeleteLead" asp-route-leadId="@lead.Id">
                                <button class="btn btn-sm btn-outline-secondary" type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Captured leads by campaign</h2>
            <p>Leads from landing pages are stored with campaign, form consent and UTM/channel source for reporting.</p>
        </div>
    </div>

    @if (!Model.CapturedLandingLeads.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-person-plus"></i>
            <span>No landing page leads captured yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Lead</th>
                        <th>Campaign</th>
                        <th>Origin</th>
                        <th>Consent</th>
                        <th>Captured</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var lead in Model.CapturedLandingLeads)
                {
                    <tr>
                        <td><strong>@lead.ContactName</strong><div class="text-muted">@lead.Email</div></td>
                        <td><strong>@lead.Campaign</strong><div class="text-muted">/@lead.LandingSlug</div></td>
                        <td><strong>@lead.Source</strong><div class="text-muted">@lead.CompanyName @lead.Role</div></td>
                        <td><span class="badge @(lead.ConsentAccepted ? "text-bg-success" : "text-bg-warning")">@(lead.ConsentAccepted ? "Accepted" : "Missing")</span></td>
                        <td class="text-muted">@lead.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
