@page
@model Alivert.Pages.App.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="app-page-hero">
    <div>
        <span class="tag mb-3">Growth dashboard</span>
        <h1 class="hero-title fw-bold mb-2">Dashboard</h1>
        <p class="lead muted mb-0">Measure reach, engagement and subscriptions or purchases generated by Promovert campaigns.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Planner/Index"><i class="bi bi-plus-lg me-1"></i> New campaign</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-megaphone me-1"></i>View campaigns</a>
    </div>
</section>

<section class="surface dashboard-plan-card mt-4">
    <div class="dashboard-plan-main">
        <span class="app-stat-icon dashboard-plan-icon"><i class="bi @(Model.IsUnlimitedPlan ? "bi-stars" : "bi-wallet2")"></i></span>
        <div>
            <div class="app-stat-label">Current plan</div>
            <h2>@Model.PlanName</h2>
            <p>@Model.PlanDescription</p>
        </div>
    </div>
    <div class="dashboard-plan-usage">
        <div class="dashboard-plan-meter-head">
            <span>@Model.ActiveAlerts active platform credits</span>
            <strong>@Model.PlanCapacityLabel</strong>
        </div>
        <div class="dashboard-plan-meter" aria-label="Plan usage">
            <span style="width:@Model.PlanUsagePercent%"></span>
        </div>
        <div class="dashboard-plan-meta">
            <span>@Model.PlanRemainingLabel</span>
            @if (Model.PlanExpiresOnUtc is not null && Model.IsUnlimitedPlan)
            {
                <span>Expires @Model.PlanExpiresOnUtc.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
            }
        </div>
    </div>
    <div class="dashboard-plan-actions">
        <a class="btn btn-primary" asp-page="/App/Billing">Manage plan</a>
        <a class="btn btn-outline-secondary" asp-page="/Pricing">Compare plans</a>
    </div>
</section>

<div class="dashboard-stat-grid mt-4">
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-broadcast"></i></span>
        <div>
            <div class="app-stat-label">Users reached</div>
            <div class="app-stat-value">@Model.UsersReached</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-chat-square-heart"></i></span>
        <div>
            <div class="app-stat-label">Users interacted</div>
            <div class="app-stat-value">@Model.UsersInteracted</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-bag-check-fill"></i></span>
        <div>
            <div class="app-stat-label">Subscribed or bought</div>
            <div class="app-stat-value">@Model.UsersConverted</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-percent"></i></span>
        <div>
            <div class="app-stat-label">Conversion rate</div>
            <div class="app-stat-value">@Model.ConversionRateLabel</div>
        </div>
    </div>
</div>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>AI marketing engine</h2>
            <p>Planner output, scheduled work and published content feeding the reach report.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Index">Open planner</a>
    </div>

    <div class="planner-metric-strip dashboard-ai-strip">
        <div><strong>@Model.AiPlans</strong><span>AI plans</span></div>
        <div><strong>@Model.ScheduledAiItems</strong><span>scheduled items</span></div>
        <div><strong>@Model.PublishedAiItems</strong><span>published/sent</span></div>
    </div>

    @if (!Model.LatestAiPlans.Any())
    {
        <div class="empty-state compact mt-3">
            <i class="bi bi-stars"></i>
            <span>No AI plans yet. Generate a plan from your product, target audience and publishing period.</span>
        </div>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Status</th>
                        <th>Generated assets</th>
                        <th>Created</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var plan in Model.LatestAiPlans)
                {
                    <tr>
                        <td>@plan.ProductName</td>
                        <td><span class="badge text-bg-secondary">@plan.Status</span></td>
                        <td>@plan.Posts posts / @plan.Emails emails / landing page</td>
                        <td class="text-muted">@plan.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Details" asp-route-id="@plan.Id">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@if (Model.FailedDeliveriesLast7Days > 0)
{
    <div class="alert alert-warning mt-4 mb-0">
        @Model.FailedDeliveriesLast7Days campaign delivery attempt(s) failed in the last 7 days.
        <a asp-page="/App/Settings">Check marketing channels</a>.
    </div>
}

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent campaign activity</h2>
            <p>Latest campaign events generated by active workflows.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Log">Open log</a>
    </div>

    @if (!Model.LatestTriggers.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-megaphone"></i>
            <span>No activity yet. Create a campaign and monitor its reach, interaction and conversion path.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Source</th>
                        <th>Activity</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestTriggers)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.TriggeredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent deliveries</h2>
            <p>Email, SMS, social and webhook delivery attempts.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Settings">Channel settings</a>
    </div>

    @if (!Model.LatestDeliveries.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-send"></i>
            <span>No delivery attempts yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Source</th>
                        <th>Channel</th>
                        <th>Status</th>
                        <th>Detail</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestDeliveries)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Channel</td>
                        <td>
                            @if (row.Status == "Sent")
                            {
                                <span class="badge text-bg-success">Sent</span>
                            }
                            else if (row.Status == "Failed")
                            {
                                <span class="badge text-bg-danger">Failed</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Skipped</span>
                            }
                        </td>
                        <td class="text-muted">@row.ErrorMessage</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
