@page
@model Alivert.Pages.App.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="app-page-hero">
    <div>
        <span class="tag mb-3">Live workspace</span>
        <h1 class="hero-title fw-bold mb-2">Dashboard</h1>
        <p class="lead muted mb-0">Overview of your alerts, monitored assets and recent trigger activity.</p>
    </div>
    <div class="app-page-hero-actions">
        <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i> New alert</a>
        <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-bell me-1"></i>View alerts</a>
    </div>
</section>

<section class="surface dashboard-plan-card mt-4">
    <div class="dashboard-plan-main">
        <span class="app-stat-icon dashboard-plan-icon"><i class="bi @(Model.IsUnlimitedPlan ? "bi-stars" : "bi-wallet2")"></i></span>
        <div>
            <div class="app-stat-label">Current plan</div>
            <h2>@Model.PlanName</h2>
            <p>@Model.PlanDescription</p>
        </div>
    </div>
    <div class="dashboard-plan-usage">
        <div class="dashboard-plan-meter-head">
            <span>@Model.ActiveAlerts active</span>
            <strong>@Model.PlanCapacityLabel</strong>
        </div>
        <div class="dashboard-plan-meter" aria-label="Plan usage">
            <span style="width:@Model.PlanUsagePercent%"></span>
        </div>
        <div class="dashboard-plan-meta">
            <span>@Model.PlanRemainingLabel</span>
            @if (Model.PlanExpiresOnUtc is not null && Model.IsUnlimitedPlan)
            {
                <span>Expires @Model.PlanExpiresOnUtc.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
            }
        </div>
    </div>
    <div class="dashboard-plan-actions">
        <a class="btn btn-primary" asp-page="/App/Billing">Manage plan</a>
        <a class="btn btn-outline-secondary" asp-page="/Pricing">Compare plans</a>
    </div>
</section>

<div class="dashboard-stat-grid mt-4">
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-bell-fill"></i></span>
        <div>
            <div class="app-stat-label">Alerts</div>
            <div class="app-stat-value">@Model.TotalAlerts</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-activity"></i></span>
        <div>
            <div class="app-stat-label">Active</div>
            <div class="app-stat-value">@Model.ActiveAlerts</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-currency-exchange"></i></span>
        <div>
            <div class="app-stat-label">Assets</div>
            <div class="app-stat-value">@Model.UniqueSymbols</div>
        </div>
    </div>
    <div class="surface app-stat-card">
        <span class="app-stat-icon"><i class="bi bi-lightning-charge-fill"></i></span>
        <div>
            <div class="app-stat-label">Triggers (7 days)</div>
            <div class="app-stat-value">@Model.TriggersLast7Days</div>
        </div>
    </div>
</div>

@if (Model.FailedDeliveriesLast7Days > 0)
{
    <div class="alert alert-warning mt-4 mb-0">
        @Model.FailedDeliveriesLast7Days notification delivery attempt(s) failed in the last 7 days.
        <a asp-page="/App/Settings">Check notification settings</a>.
    </div>
}

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent triggers</h2>
            <p>Latest alert signals evaluated by the worker.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Log">Open log</a>
    </div>

    @if (!Model.LatestTriggers.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-bell"></i>
            <span>No triggers yet. Create alerts and wait for the worker to evaluate them.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Symbol</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestTriggers)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.TriggeredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="surface app-panel mt-4">
    <div class="app-panel-header">
        <div>
            <h2>Recent deliveries</h2>
            <p>Email and notification delivery attempts.</p>
        </div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Settings">Delivery settings</a>
    </div>

    @if (!Model.LatestDeliveries.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-send"></i>
            <span>No delivery attempts yet.</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Symbol</th>
                        <th>Channel</th>
                        <th>Status</th>
                        <th>Detail</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.LatestDeliveries)
                {
                    <tr>
                        <td class="text-muted" style="white-space:nowrap">@row.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge badge-soft">@row.Symbol</span></td>
                        <td>@row.Channel</td>
                        <td>
                            @if (row.Status == "Sent")
                            {
                                <span class="badge text-bg-success">Sent</span>
                            }
                            else if (row.Status == "Failed")
                            {
                                <span class="badge text-bg-danger">Failed</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Skipped</span>
                            }
                        </td>
                        <td class="text-muted">@row.ErrorMessage</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
