@page
@using Alivert.Models
@model Alivert.Pages.App.Alerts.AlertsIndexModel
@{
    ViewData["Title"] = "Campaigns";
    var primaryGroup = Model.AlertGroups.FirstOrDefault();
    var primaryAlert = primaryGroup?.Alerts.OrderByDescending(a => a.IsEnabled).ThenBy(a => a.Id).FirstOrDefault();
    var primaryGroupIsEnabled = primaryGroup?.Alerts.Any(a => a.IsEnabled) == true;
}

<div class="alerts-board">
    <div class="alerts-toolbar">
        <div>
            <span class="tag mb-2">Campaign center</span>
            <h1 class="fw-bold mb-0">Campaigns</h1>
            <p class="muted mb-0">Create, organize and measure campaigns for applications, companies and business ideas.</p>
        </div>
        <div class="alerts-actions">
            <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create">
                <i class="bi bi-plus-lg me-1"></i> New campaign
            </a>
            <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#scheduleModal">
                <i class="bi bi-clock me-1"></i> Delivery window
            </button>
            <a class="btn btn-outline-secondary btn-icon" asp-page="/App/Settings" title="Marketing channels">
                <i class="bi bi-broadcast-pin"></i>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    @if (primaryGroup is not null)
    {
        var primaryHistoryId = GroupHistoryId(primaryGroup.MarketType, primaryGroup.Symbol);
        <div class="alerts-market-bar mt-4">
            <div class="d-flex align-items-center gap-2">
                <button class="alerts-history-trigger collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@primaryHistoryId" aria-expanded="false" aria-controls="@primaryHistoryId" title="Show activity history" aria-label="Show activity history">
                    <i class="bi bi-chevron-down"></i>
                </button>
                <span class="alerts-coin"><i class="bi bi-megaphone-fill"></i></span>
                <div>
                    <strong>@GroupTitle(primaryGroup.MarketType, primaryGroup.Symbol)</strong>
                    <div class="small muted">@SourceKind(primaryGroup.MarketType)</div>
                </div>
            </div>
            <div class="alerts-market-tools">
                @if (primaryAlert is not null)
                {
                    <a class="btn-clean" asp-page="/App/Alerts/Edit" asp-route-id="@primaryAlert.Id" title="Edit campaign" aria-label="Edit campaign"><i class="bi bi-pencil-square"></i></a>
                }
                <form class="alerts-inline-form" method="post" asp-page-handler="DeleteGroup" onsubmit="return confirm('Delete every campaign for this source?');">
                    <input type="hidden" name="marketType" value="@primaryGroup.MarketType" />
                    <input type="hidden" name="symbol" value="@primaryGroup.Symbol" />
                    <button class="btn-clean danger" type="submit" title="Delete source" aria-label="Delete source"><i class="bi bi-x-lg"></i></button>
                </form>
                <form class="alerts-inline-form" method="post" asp-page-handler="ToggleGroup">
                    <input type="hidden" name="marketType" value="@primaryGroup.MarketType" />
                    <input type="hidden" name="symbol" value="@primaryGroup.Symbol" />
                    <button class="alerts-toggle @(primaryGroupIsEnabled ? "on" : "off")" type="submit" title="@(primaryGroupIsEnabled ? "Pause campaigns" : "Activate campaigns")" aria-label="@(primaryGroupIsEnabled ? "Pause campaigns" : "Activate campaigns")"></button>
                </form>
            </div>
        </div>
        <div class="collapse alerts-history-collapse" id="@primaryHistoryId">
            <section class="alerts-trigger-history">
                <div class="alerts-trigger-history-head">
                    <div>
                        <span>Activity history</span>
                        <strong>@GroupTitle(primaryGroup.MarketType, primaryGroup.Symbol)</strong>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Log">Open full log</a>
                </div>
                @if (primaryGroup.TriggerHistory.Any())
                {
                    <div class="alerts-trigger-list">
                        @foreach (var trigger in primaryGroup.TriggerHistory)
                        {
                            <div class="alerts-trigger-item">
                                <span class="alerts-trigger-icon @RuleClass(trigger.RuleType)">
                                    <i class="bi @RuleIcon(trigger.RuleType)"></i>
                                </span>
                                <div class="alerts-trigger-copy">
                                    <strong>@RuleDisplayName(trigger.RuleType)</strong>
                                    <span>@trigger.Message</span>
                                    <small>@CadenceLabel(trigger.Timeframe) &middot; goal @trigger.Threshold</small>
                                </div>
                                <time datetime="@trigger.TriggeredAtUtc.ToString("O")">@trigger.TriggeredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</time>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alerts-trigger-empty">
                        <i class="bi bi-megaphone"></i>
                        <span>No activity recorded for this source yet.</span>
                    </div>
                }
            </section>
        </div>
    }

    @if (Model.AlertGroups.Any())
    {
        <div class="alerts-groups mt-3">
            @foreach (var group in Model.AlertGroups)
            {
                <section class="alerts-group">
                    <div class="alerts-group-title">
                        <div>
                            <span>@GroupTitle(group.MarketType, group.Symbol)</span>
                            <div class="small muted">@SourceKind(group.MarketType)</div>
                        </div>
                        <div class="alerts-group-title-actions">
                            <span class="muted small">@group.Alerts.Count campaign@(group.Alerts.Count == 1 ? "" : "s")</span>
                            <form class="alerts-inline-form" method="post" asp-page-handler="ToggleGroup">
                                <input type="hidden" name="marketType" value="@group.MarketType" />
                                <input type="hidden" name="symbol" value="@group.Symbol" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">
                                    @(group.Alerts.Any(a => a.IsEnabled) ? "Pause source" : "Activate source")
                                </button>
                            </form>
                            <form class="alerts-inline-form" method="post" asp-page-handler="DeleteGroup" onsubmit="return confirm('Delete every campaign for this source?');">
                                <input type="hidden" name="marketType" value="@group.MarketType" />
                                <input type="hidden" name="symbol" value="@group.Symbol" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle alerts-table">
                            <thead>
                                <tr>
                                    <th>Asset</th>
                                    <th>Goal</th>
                                    <th>Cadence</th>
                                    <th>Channel</th>
                                    <th>Status</th>
                                    <th>Last activity</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var alert in group.Alerts)
                            {
                                <tr>
                                    <td>
                                        <i class="bi @RuleIcon(alert.RuleType) me-2 @RuleClass(alert.RuleType)"></i>
                                        @RuleLabel(alert)
                                    </td>
                                    <td>@alert.Threshold</td>
                                    <td>@CadenceLabel(alert.Timeframe)</td>
                                    <td>@alert.Channel</td>
                                    <td>
                                        <span class="badge @(alert.IsEnabled ? "text-bg-success" : "text-bg-secondary")">@(alert.IsEnabled ? "Active" : "Paused")</span>
                                    </td>
                                    <td class="text-muted">@(alert.LastTriggeredAtUtc is null ? "Never" : alert.LastTriggeredAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</td>
                                    <td class="text-end">
                                        <div class="alerts-row-actions">
                                            <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Alerts/Edit" asp-route-id="@alert.Id">Edit</a>
                                            <form class="alerts-inline-form" method="post" asp-page-handler="ToggleAlert">
                                                <input type="hidden" name="id" value="@alert.Id" />
                                                <button class="btn btn-sm btn-outline-secondary" type="submit">@(alert.IsEnabled ? "Pause" : "Activate")</button>
                                            </form>
                                            <form class="alerts-inline-form" method="post" asp-page-handler="DeleteAlert" onsubmit="return confirm('Delete this campaign?');">
                                                <input type="hidden" name="id" value="@alert.Id" />
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        </div>
    }

    <div class="alerts-promo-grid mt-4">
        <article class="alerts-promo-card @(Model.IsAnnualUnlimitedPlan ? "plan-included" : "")">
            <div class="alerts-promo-visual @(Model.IsAnnualUnlimitedPlan ? "visual-star" : "visual-lock")"><i class="bi @(Model.IsAnnualUnlimitedPlan ? "bi-check2-circle" : "bi-lock-fill")"></i></div>
            <div class="alerts-promo-body">
                <h2>@Model.PlanPromoTitle</h2>
                <p>@Model.PlanPromoText</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Billing">View plan</a>
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-star"><i class="bi bi-camera-video"></i></div>
            <div class="alerts-promo-body">
                <h2>Posts and videos</h2>
                <p>Create hooks, scripts and captions for TikTok, Instagram, Facebook and LinkedIn.</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Alerts/Create">Create campaign</a>
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-phone"><i class="bi bi-envelope-paper"></i></div>
            <div class="alerts-promo-body">
                <h2>Email and SMS</h2>
                <p>Prepare personalized messages for potential-client lists and promotional follow-up.</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Settings">Channels</a>
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-chart"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="alerts-promo-body">
                <h2>Measurable funnel</h2>
                <p>Track reach, interaction and conversions before deciding which campaign to scale.</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Dashboard">Dashboard</a>
            </div>
        </article>
    </div>
</div>

<div class="modal fade" id="scheduleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content account-modal alerts-modal">
            <div class="modal-header border-0">
                <h2 class="modal-title h3">Delivery window</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Schedule">
                <div class="modal-body">
                    <p class="fw-semibold mb-3">Run campaigns between...</p>
                    <div class="row g-3">
                        <div class="col-5">
                            <input class="form-control" type="time" name="startTime" value="@(Model.ScheduleSettings?.AlertWindowStart ?? "09:00")" />
                        </div>
                        <div class="col-2 d-flex align-items-center justify-content-center muted">and</div>
                        <div class="col-5">
                            <input class="form-control" type="time" name="endTime" value="@(Model.ScheduleSettings?.AlertWindowEnd ?? "18:00")" />
                        </div>
                    </div>
                    <label class="modal-field-label mt-3" for="scheduleTimeZone">Schedule time zone</label>
                    <select class="form-select" id="scheduleTimeZone" name="timeZone" data-combo>
                        @foreach (var zone in Model.ScheduleTimeZones)
                        {
                            <option value="@zone.Id" selected="@(zone.Id == Model.SelectedScheduleTimeZone)">@zone.Label</option>
                        }
                    </select>
                    <div class="schedule-timezone-card">
                        <div>
                            <span>Detected on this device</span>
                            <strong data-browser-timezone>Detecting browser time zone...</strong>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-use-browser-timezone disabled>Use detected</button>
                        <div>
                            <span>Selected schedule time</span>
                            <strong data-selected-timezone-clock>Checking selected time...</strong>
                        </div>
                    </div>

                    <p class="fw-semibold mt-4 mb-3">On these days...</p>
                    <div class="schedule-days">
                        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <label>
                                <input class="form-check-input" type="checkbox" name="days" value="@day" checked="@DayChecked(day)" />
                                <span>@day</span>
                            </label>
                        }
                    </div>
                    <p class="small muted mt-4 mb-0">Use this window to avoid outreach outside the desired marketing hours.</p>
                </div>
                <div class="modal-footer border-0 schedule-footer @(Model.ScheduleSettings?.AlertScheduleEnabled == true ? "" : "schedule-footer-compact")">
                    @if (Model.ScheduleSettings?.AlertScheduleEnabled == true)
                    {
                        <button type="submit" formaction="?handler=RemoveSchedule" class="btn btn-outline-secondary"><i class="bi bi-broadcast me-1"></i> Use 24/7 delivery</button>
                    }
                    <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-clockwise me-1"></i> Save delivery window</button>
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    private static string GroupTitle(MarketType market, string symbol)
    {
        return string.IsNullOrWhiteSpace(symbol) ? SourceKind(market) : symbol;
    }

    private static string SourceKind(MarketType market)
    {
        return market == MarketType.Crypto ? "Application URL" : "Company or idea";
    }

    private static string GroupHistoryId(MarketType market, string symbol)
    {
        var safeSymbol = new string(symbol.Select(ch => char.IsLetterOrDigit(ch) ? char.ToLowerInvariant(ch) : '-').ToArray());
        safeSymbol = string.IsNullOrWhiteSpace(safeSymbol) ? "campaign" : safeSymbol;
        return $"campaign-history-{market.ToString().ToLowerInvariant()}-{safeSymbol}";
    }

    private static string RuleLabel(Alert alert)
    {
        return alert.RuleType.DisplayName();
    }

    private static string RuleDisplayName(AlertRuleType rule)
    {
        return rule.DisplayName();
    }

    private static string RuleIcon(AlertRuleType rule)
    {
        return rule switch
        {
            AlertRuleType.PriceAbove => "bi-tiktok",
            AlertRuleType.PriceBelow => "bi-instagram",
            AlertRuleType.PercentDrop24h => "bi-facebook",
            AlertRuleType.PercentRise24h => "bi-linkedin",
            AlertRuleType.VolumeAbove24h => "bi-envelope",
            AlertRuleType.PriceZone => "bi-phone-vibrate",
            _ => "bi-megaphone"
        };
    }

    private static string RuleClass(AlertRuleType rule)
    {
        return rule switch
        {
            AlertRuleType.PriceAbove or AlertRuleType.PriceBelow => "text-success",
            AlertRuleType.PercentDrop24h or AlertRuleType.PercentRise24h => "text-info",
            AlertRuleType.PriceZone => "text-warning",
            _ => "text-primary"
        };
    }

    private static string CadenceLabel(string timeframe)
    {
        return timeframe switch
        {
            "1d" => "Daily",
            "3d" => "Every 3 days",
            "1wk" => "Weekly",
            "2wk" => "Biweekly",
            "1mo" => "Monthly",
            _ => timeframe
        };
    }

    private bool DayChecked(string day)
    {
        var days = Model.ScheduleSettings?.AlertWindowDays;
        return string.IsNullOrWhiteSpace(days) || days.Split(',').Contains(day, StringComparer.OrdinalIgnoreCase);
    }
}

@section Scripts {
    <script src="~/js/alivert-combos.js" asp-append-version="true"></script>
}
