@page
@model Alivert.Pages.App.Alerts.AlertsIndexModel
@{
    ViewData["Title"] = "Alerts";
}

<div class="d-flex align-items-end justify-content-between flex-wrap gap-2">
    <div>
        <h1 class="fw-bold mb-0">Alerts</h1>
        <p class="text-muted mb-0">Create and manage custom alerts by symbol and condition.</p>
    </div>
    <a class="btn btn-primary" asp-page="/App/Alerts/Create">New alert</a>
</div>

<div class="surface p-4 mt-4">
        @if (!Model.Alerts.Any())
        {
            <p class="text-muted mb-0">No alerts yet. Click <strong>New alert</strong>.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Symbol</th>
                            <th>Rule</th>
                            <th>Threshold</th>
                            <th>Cooldown</th>
                            <th>Channel</th>
                            <th>Enabled</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var a in Model.Alerts)
                    {
                        <tr>
                            <td><span class="badge badge-soft">@a.Symbol</span></td>
                            <td>@a.RuleType</td>
                            <td>@a.Threshold</td>
                            <td>@a.CooldownMinutes min</td>
                            <td>@a.Channel</td>
                            <td>
                                @if (a.IsEnabled)
                                {
                                    <span class="badge text-bg-success">On</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Off</span>
                                }
                            </td>
                            <td class="text-end" style="white-space:nowrap">
                                <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Alerts/Edit" asp-route-id="@a.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="/App/Alerts/Delete" asp-route-id="@a.Id">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
</div>
