@page
@using Alivert.Models
@model Alivert.Pages.App.Alerts.AlertsIndexModel
@{
    ViewData["Title"] = "My alerts";
    var primaryGroup = Model.AlertGroups.FirstOrDefault();
    var primaryAlert = primaryGroup?.Alerts.OrderByDescending(a => a.IsEnabled).ThenBy(a => a.Id).FirstOrDefault();
    var primaryGroupIsEnabled = primaryGroup?.Alerts.Any(a => a.IsEnabled) == true;
}

<div class="alerts-board">
    <div class="alerts-toolbar">
        <div>
            <span class="tag mb-2">Alert control center</span>
            <h1 class="fw-bold mb-0">My alerts</h1>
            <p class="muted mb-0">Create, schedule and monitor every market condition from one workspace.</p>
        </div>
        <div class="alerts-actions">
            <a class="btn btn-primary btn-lg app-new-alert-action" asp-page="/App/Alerts/Create">
                <i class="bi bi-plus-lg me-1"></i> New alert
            </a>
            <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#scheduleModal">
                <i class="bi bi-clock me-1"></i> Schedule
            </button>
            <a class="btn btn-outline-secondary btn-icon" asp-page="/App/Settings" title="Notification settings">
                <i class="bi bi-power"></i>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    @if (primaryGroup is not null)
    {
        var primaryHistoryId = GroupHistoryId(primaryGroup.MarketType, primaryGroup.Symbol);
        <div class="alerts-market-bar mt-4">
            <div class="d-flex align-items-center gap-2">
                <button class="alerts-history-trigger collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@primaryHistoryId" aria-expanded="false" aria-controls="@primaryHistoryId" title="Show trigger history" aria-label="Show trigger history">
                    <i class="bi bi-chevron-down"></i>
                </button>
                <span class="alerts-coin"><i class="bi bi-currency-bitcoin"></i></span>
                <strong>@GroupTitle(primaryGroup.MarketType, primaryGroup.Symbol)</strong>
            </div>
            <div class="alerts-market-tools">
                @if (primaryAlert is not null)
                {
                    <a class="btn-clean" asp-page="/App/Alerts/Edit" asp-route-id="@primaryAlert.Id" title="Edit alert" aria-label="Edit alert"><i class="bi bi-pencil-square"></i></a>
                }
                <form class="alerts-inline-form" method="post" asp-page-handler="DeleteGroup" onsubmit="return confirm('Delete all alerts in this group?');">
                    <input type="hidden" name="marketType" value="@primaryGroup.MarketType" />
                    <input type="hidden" name="symbol" value="@primaryGroup.Symbol" />
                    <button class="btn-clean danger" type="submit" title="Delete this alert group" aria-label="Delete this alert group"><i class="bi bi-x-lg"></i></button>
                </form>
                <form class="alerts-inline-form" method="post" asp-page-handler="ToggleGroup">
                    <input type="hidden" name="marketType" value="@primaryGroup.MarketType" />
                    <input type="hidden" name="symbol" value="@primaryGroup.Symbol" />
                    <button class="alerts-toggle @(primaryGroupIsEnabled ? "on" : "off")" type="submit" title="@(primaryGroupIsEnabled ? "Turn this alert group off" : "Turn this alert group on")" aria-label="@(primaryGroupIsEnabled ? "Turn this alert group off" : "Turn this alert group on")"></button>
                </form>
            </div>
        </div>
        <div class="collapse alerts-history-collapse" id="@primaryHistoryId">
            <section class="alerts-trigger-history">
                <div class="alerts-trigger-history-head">
                    <div>
                        <span>Trigger history</span>
                        <strong>@GroupTitle(primaryGroup.MarketType, primaryGroup.Symbol)</strong>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Log">Open full log</a>
                </div>
                @if (primaryGroup.TriggerHistory.Any())
                {
                    <div class="alerts-trigger-list">
                        @foreach (var trigger in primaryGroup.TriggerHistory)
                        {
                            <div class="alerts-trigger-item">
                                <span class="alerts-trigger-icon @RuleClass(trigger.RuleType)">
                                    <i class="bi @RuleIcon(trigger.RuleType)"></i>
                                </span>
                                <div class="alerts-trigger-copy">
                                    <strong>@RuleDisplayName(trigger.RuleType)</strong>
                                    <span>@trigger.Message</span>
                                    <small>@trigger.Timeframe &middot; threshold @trigger.Threshold</small>
                                </div>
                                <time datetime="@trigger.TriggeredAtUtc.ToString("O")">@trigger.TriggeredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</time>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alerts-trigger-empty">
                        <i class="bi bi-bell"></i>
                        <span>No triggers recorded for this alert group yet.</span>
                    </div>
                }
            </section>
        </div>
    }

    @if (Model.AlertGroups.Any())
    {
        <div class="alerts-groups mt-3">
            @foreach (var group in Model.AlertGroups)
            {
                <section class="alerts-group">
                    <div class="alerts-group-title">
                        <span>@GroupTitle(group.MarketType, group.Symbol)</span>
                        <div class="alerts-group-title-actions">
                            <span class="muted small">@group.Alerts.Count alert@(group.Alerts.Count == 1 ? "" : "s")</span>
                            <form class="alerts-inline-form" method="post" asp-page-handler="ToggleGroup">
                                <input type="hidden" name="marketType" value="@group.MarketType" />
                                <input type="hidden" name="symbol" value="@group.Symbol" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">
                                    @(group.Alerts.Any(a => a.IsEnabled) ? "Turn off group" : "Turn on group")
                                </button>
                            </form>
                            <form class="alerts-inline-form" method="post" asp-page-handler="DeleteGroup" onsubmit="return confirm('Delete all alerts in this group?');">
                                <input type="hidden" name="marketType" value="@group.MarketType" />
                                <input type="hidden" name="symbol" value="@group.Symbol" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete group</button>
                            </form>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle alerts-table">
                            <thead>
                                <tr>
                                    <th>Alert type</th>
                                    <th>Threshold</th>
                                    <th>Timeframe</th>
                                    <th>Channel</th>
                                    <th>Status</th>
                                    <th>Last trigger</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var alert in group.Alerts)
                            {
                                <tr>
                                    <td>
                                        <i class="bi @RuleIcon(alert.RuleType) me-2 @RuleClass(alert.RuleType)"></i>
                                        @RuleLabel(alert)
                                    </td>
                                    <td>@alert.Threshold</td>
                                    <td>@alert.Timeframe</td>
                                    <td>@alert.Channel</td>
                                    <td>
                                        <span class="badge @(alert.IsEnabled ? "text-bg-success" : "text-bg-secondary")">@(alert.IsEnabled ? "On" : "Off")</span>
                                    </td>
                                    <td class="text-muted">@(alert.LastTriggeredAtUtc is null ? "Never" : alert.LastTriggeredAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</td>
                                    <td class="text-end">
                                        <div class="alerts-row-actions">
                                            <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Alerts/Edit" asp-route-id="@alert.Id">Edit</a>
                                            <form class="alerts-inline-form" method="post" asp-page-handler="ToggleAlert">
                                                <input type="hidden" name="id" value="@alert.Id" />
                                                <button class="btn btn-sm btn-outline-secondary" type="submit">@(alert.IsEnabled ? "Turn off" : "Turn on")</button>
                                            </form>
                                            <form class="alerts-inline-form" method="post" asp-page-handler="DeleteAlert" onsubmit="return confirm('Delete this alert?');">
                                                <input type="hidden" name="id" value="@alert.Id" />
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        </div>
    }

    <div class="alerts-promo-grid mt-4">
        <article class="alerts-promo-card @(Model.IsAnnualUnlimitedPlan ? "plan-included" : "")">
            <div class="alerts-promo-visual @(Model.IsAnnualUnlimitedPlan ? "visual-star" : "visual-lock")"><i class="bi @(Model.IsAnnualUnlimitedPlan ? "bi-check2-circle" : "bi-lock-fill")"></i></div>
            <div class="alerts-promo-body">
                <h2>@Model.PlanPromoTitle</h2>
                @if (Model.IsAnnualUnlimitedPlan)
                {
                    <p>@Model.PlanPromoText</p>
                    <a class="btn btn-outline-secondary" asp-page="/App/Billing">Subscription details</a>
                }
                else if (Model.IsUnlimitedPlan)
                {
                    <p>@Model.PlanPromoText</p>
                    <a class="btn btn-primary" asp-page="/App/Billing">Switch to annual</a>
                }
                else
                {
                    <p><strong>Annual value:</strong> @Model.PlanPromoText</p>
                    <a class="btn btn-primary" asp-page="/App/Billing">Upgrade to annual</a>
                }
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-star"><i class="bi bi-sliders"></i></div>
            <div class="alerts-promo-body">
                <h2>One alert builder</h2>
                <p>Create every alert from the same form: choose the market, symbol, rule type, timeframe and only the fields required for that strategy.</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Alerts/Create">Create alert</a>
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-phone"><i class="bi bi-phone"></i></div>
            <div class="alerts-promo-body">
                <h2>Route alerts to your devices</h2>
                <p>Send notifications through email, Telegram, Discord, Slack, Teams or webhooks from one settings panel.</p>
                <a class="btn btn-outline-secondary" asp-page="/App/Settings">Notification settings</a>
            </div>
        </article>
        <article class="alerts-promo-card">
            <div class="alerts-promo-visual visual-chart"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="alerts-promo-body">
                <h2>Advanced indicator alerts</h2>
                <p>RSI thresholds and EMA cross confirmations work across crypto and traditional market symbols.</p>
                <a class="btn btn-outline-secondary" asp-page="/HowItWorks">More info</a>
            </div>
        </article>
    </div>
</div>

<div class="modal fade" id="scheduleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content account-modal alerts-modal">
            <div class="modal-header border-0">
                <h2 class="modal-title h3">Alerts schedule</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Schedule">
                <div class="modal-body">
                    <p class="fw-semibold mb-3">Send me alerts between...</p>
                    <div class="row g-3">
                        <div class="col-5">
                            <input class="form-control" type="time" name="startTime" value="@(Model.ScheduleSettings?.AlertWindowStart ?? "00:00")" />
                        </div>
                        <div class="col-2 d-flex align-items-center justify-content-center muted">and</div>
                        <div class="col-5">
                            <input class="form-control" type="time" name="endTime" value="@(Model.ScheduleSettings?.AlertWindowEnd ?? "23:59")" />
                        </div>
                    </div>
                    <label class="modal-field-label mt-3" for="scheduleTimeZone">Schedule time zone</label>
                    <select class="form-select" id="scheduleTimeZone" name="timeZone" data-combo>
                        @foreach (var zone in Model.ScheduleTimeZones)
                        {
                            <option value="@zone.Id" selected="@(zone.Id == Model.SelectedScheduleTimeZone)">@zone.Label</option>
                        }
                    </select>
                    <div class="schedule-timezone-card">
                        <div>
                            <span>Detected on this device</span>
                            <strong data-browser-timezone>Detecting browser time zone...</strong>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-use-browser-timezone disabled>Use detected</button>
                        <div>
                            <span>Selected schedule time</span>
                            <strong data-selected-timezone-clock>Checking selected time...</strong>
                        </div>
                    </div>
                    <p class="schedule-timezone-note">Times are evaluated in the selected city time and automatically follow daylight saving rules where applicable.</p>

                    <p class="fw-semibold mt-4 mb-3">On these days...</p>
                    <div class="schedule-days">
                        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <label>
                                <input class="form-check-input" type="checkbox" name="days" value="@day" checked="@DayChecked(day)" />
                                <span>@day</span>
                            </label>
                        }
                    </div>
                    <p class="small muted mt-4 mb-0">Use a delivery window only when you want to mute notifications outside selected days or hours. For uninterrupted delivery, keep alerts running 24/7.</p>
                </div>
                <div class="modal-footer border-0 schedule-footer @(Model.ScheduleSettings?.AlertScheduleEnabled == true ? "" : "schedule-footer-compact")">
                    @if (Model.ScheduleSettings?.AlertScheduleEnabled == true)
                    {
                        <button type="submit" formaction="?handler=RemoveSchedule" class="btn btn-outline-secondary"><i class="bi bi-broadcast me-1"></i> Use 24/7 alerts</button>
                    }
                    <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-clockwise me-1"></i> Save delivery window</button>
                    <button type="button" class="btn btn-outline-secondary w-100" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    private string GroupTitle(MarketType market, string symbol)
    {
        return market == MarketType.Crypto
            ? $"BINANCE : {FormatCryptoPair(symbol)}"
            : $"YAHOO : {symbol}";
    }

    private static string FormatCryptoPair(string symbol)
    {
        return symbol.EndsWith("USDT", StringComparison.OrdinalIgnoreCase)
            ? $"{symbol[..^4]} / USDT"
            : symbol;
    }

    private static string GroupHistoryId(MarketType market, string symbol)
    {
        var safeSymbol = new string(symbol.Select(ch => char.IsLetterOrDigit(ch) ? char.ToLowerInvariant(ch) : '-').ToArray());
        return $"trigger-history-{market.ToString().ToLowerInvariant()}-{safeSymbol}";
    }

    private static string RuleLabel(Alert alert)
    {
        return alert.RuleType.RequiresTechnicalIndicators()
            ? $"{RuleDisplayName(alert.RuleType)} - RSI {alert.RsiPeriod}, EMA {alert.FastEmaPeriod}/{alert.SlowEmaPeriod}"
            : alert.RuleType.UsesPriceZone()
                ? $"Price zone +/- {alert.ZonePercent}%"
                : RuleDisplayName(alert.RuleType);
    }

    private static string RuleDisplayName(AlertRuleType rule)
    {
        return rule switch
        {
            AlertRuleType.PriceAbove => "Price above",
            AlertRuleType.PriceBelow => "Price below",
            AlertRuleType.PercentDrop24h => "24h percent drop",
            AlertRuleType.PercentRise24h => "24h percent rise",
            AlertRuleType.VolumeAbove24h => "24h volume above",
            AlertRuleType.PriceZone => "Price zone",
            AlertRuleType.RsiBelow => "RSI below",
            AlertRuleType.RsiAbove => "RSI above",
            AlertRuleType.RsiOversoldEmaCrossUp => "RSI oversold + EMA cross up",
            AlertRuleType.RsiOverboughtEmaCrossDown => "RSI overbought + EMA cross down",
            _ => rule.ToString()
        };
    }

    private static string RuleIcon(AlertRuleType rule)
    {
        return rule is AlertRuleType.PriceBelow or AlertRuleType.PercentDrop24h or AlertRuleType.RsiOverboughtEmaCrossDown
            ? "bi-chevron-down"
            : "bi-chevron-up";
    }

    private static string RuleClass(AlertRuleType rule)
    {
        return rule is AlertRuleType.PriceBelow or AlertRuleType.PercentDrop24h or AlertRuleType.RsiOverboughtEmaCrossDown
            ? "text-danger"
            : "text-success";
    }

    private bool DayChecked(string day)
    {
        var days = Model.ScheduleSettings?.AlertWindowDays;
        return string.IsNullOrWhiteSpace(days) || days.Split(',').Contains(day, StringComparer.OrdinalIgnoreCase);
    }
}

@section Scripts {
    <script src="~/js/alivert-combos.js" asp-append-version="true"></script>
}
