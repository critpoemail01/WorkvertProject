@page "{id:int}"
@model Alivert.Pages.App.Alerts.EditAlertModel
@{
    ViewData["Title"] = "Edit alert";
}

<div class="alert-form-page">
    <section class="app-page-hero">
        <div>
            <span class="tag mb-3">Alert builder</span>
            <h1 class="hero-title fw-bold mb-2">Edit alert</h1>
            <p class="lead muted mb-0">Update the market condition, cooldown and delivery channel.</p>
        </div>
        <div class="app-page-hero-actions">
            <a class="btn btn-outline-secondary btn-lg" asp-page="/App/Alerts/Index"><i class="bi bi-arrow-left me-1"></i>Back to alerts</a>
        </div>
    </section>

    <div class="alert-form-grid mt-4">
        <form method="post" class="surface app-panel alert-form-panel">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.MarketType" class="form-label"></label>
                    <select asp-for="Input.MarketType" class="form-select" asp-items="Model.MarketTypeOptions" data-symbol-market></select>
                    <span asp-validation-for="Input.MarketType" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Symbol" class="form-label"></label>
                    <input asp-for="Input.Symbol" class="form-control" list="symbolSuggestions" data-symbol-input />
                    <datalist id="symbolSuggestions"></datalist>
                    <span asp-validation-for="Input.Symbol" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.RuleType" class="form-label"></label>
                    <select asp-for="Input.RuleType" class="form-select" asp-items="Model.RuleTypeOptions"></select>
                    <span asp-validation-for="Input.RuleType" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Timeframe" class="form-label"></label>
                    <select asp-for="Input.Timeframe" class="form-select" asp-items="Model.TimeframeOptions"></select>
                    <span asp-validation-for="Input.Timeframe" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Input.Threshold" class="form-label"></label>
                    <input asp-for="Input.Threshold" class="form-control" />
                    <div class="form-text">Price level, price-zone center, volume, percent change, or RSI level such as 30/70.</div>
                    <span asp-validation-for="Input.Threshold" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.ZonePercent" class="form-label"></label>
                    <input asp-for="Input.ZonePercent" class="form-control" />
                    <div class="form-text">Used by PriceZone as +/- percent around threshold.</div>
                    <span asp-validation-for="Input.ZonePercent" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.RsiPeriod" class="form-label"></label>
                    <input asp-for="Input.RsiPeriod" class="form-control" />
                    <span asp-validation-for="Input.RsiPeriod" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.FastEmaPeriod" class="form-label"></label>
                    <input asp-for="Input.FastEmaPeriod" class="form-control" />
                    <span asp-validation-for="Input.FastEmaPeriod" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.SlowEmaPeriod" class="form-label"></label>
                    <input asp-for="Input.SlowEmaPeriod" class="form-control" />
                    <span asp-validation-for="Input.SlowEmaPeriod" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.CooldownMinutes" class="form-label"></label>
                    <input asp-for="Input.CooldownMinutes" class="form-control" />
                    <span asp-validation-for="Input.CooldownMinutes" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Input.Channel" class="form-label"></label>
                    <select asp-for="Input.Channel" class="form-select">
                        <option>Email</option>
                        <option>Telegram</option>
                        <option>Discord</option>
                        <option>Webhook</option>
                    </select>
                    <div class="form-text"><a asp-page="/App/Settings">Configure notification destinations</a>.</div>
                </div>
            </div>

            <label class="form-check alert-form-check mt-4">
                <input class="form-check-input" asp-for="Input.IsEnabled" />
                <span class="form-check-label">Alert is enabled</span>
            </label>

            <div class="alert-form-actions mt-4">
                <button class="btn btn-primary" type="submit"><i class="bi bi-check2 me-1"></i>Save changes</button>
                <a class="btn btn-outline-secondary" asp-page="/App/Alerts/Index">Cancel</a>
            </div>
        </form>

        <aside class="surface app-panel alert-form-aside">
            <div class="plan-badge mb-3"><i class="bi bi-sliders"></i> Rule setup</div>
            <h2>Keep the signal precise</h2>
            <p>Changing timeframe or indicator periods can materially change trigger frequency.</p>

            <div class="alert-form-tip">
                <strong>Price zones</strong>
                <span>Use ZonePercent to define the allowed band around the threshold.</span>
            </div>
            <div class="alert-form-tip">
                <strong>Delivery</strong>
                <span>Email works by default. Configure Telegram, Discord or webhooks in notification settings.</span>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/alivert-symbols.js" asp-append-version="true"></script>
}
