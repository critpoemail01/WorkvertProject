@page
@model Alivert.Pages.App.HelpDeskModel
@{
    ViewData["Title"] = "Help desk";
}

<div class="account-page">
    <div class="account-heading">
        <div>
            <span class="tag mb-2">Help & support</span>
            <h1 class="fw-bold mb-0">Help desk</h1>
            <p class="muted mb-0">Open a support ticket when something is broken or you need help with alerts, billing or notifications.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mt-4 mb-0">@Model.StatusMessage</div>
    }

    <section class="account-section mt-4">
        <div class="account-section-title">Open new support ticket</div>
        <form method="post" class="helpdesk-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <input asp-for="Input.Name" class="form-control" placeholder="Name" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="col-md-7">
                    <input asp-for="Input.Subject" class="form-control" placeholder="Subject" />
                    <span asp-validation-for="Input.Subject" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <textarea asp-for="Input.Message" class="form-control helpdesk-message" placeholder="Message"></textarea>
                    <span asp-validation-for="Input.Message" class="text-danger"></span>
                </div>
            </div>

            <button class="btn btn-primary mt-4" type="submit">Submit new ticket</button>
        </form>
        <p class="small muted mt-4 mb-0">
            Note: please do not open duplicate tickets for the same issue. Add follow-up details by replying to the confirmation email or opening a new ticket only when the issue is different.
        </p>
    </section>

    <section class="account-section mt-4">
        <div class="account-section-title">Recent tickets</div>
        @if (!Model.Tickets.Any())
        {
            <div class="empty-state compact">
                <i class="bi bi-chat-left-text"></i>
                <span>No support tickets yet.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Subject</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td class="text-muted">@ticket.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@ticket.Subject</td>
                            <td><span class="badge text-bg-secondary">@ticket.Status</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
