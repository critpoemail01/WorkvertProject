@page
@model Alivert.Pages.App.LogModel
@{
    ViewData["Title"] = "Log view";
}

<div class="log-view">
    <section class="app-page-hero">
        <div>
            <span class="tag mb-3">Alert history</span>
            <h1 class="hero-title fw-bold mb-2">Log view</h1>
            <p class="lead muted mb-0">Review alert deliveries, skipped windows and failed notification attempts.</p>
        </div>
        <form method="get" class="log-alert-picker app-page-hero-actions">
            <select class="form-select" name="alertId" onchange="this.form.submit()">
                <option value="">All alerts</option>
                @foreach (var option in Model.AlertOptions)
                {
                    <option value="@option.Id" selected="@(Model.AlertId == option.Id)">@option.Label</option>
                }
            </select>
            @if (Model.SelectedTimeframe != "all")
            {
                <input type="hidden" name="timeframe" value="@Model.SelectedTimeframe" />
            }
        </form>
    </section>

    <div class="log-layout">
        <section class="log-main-panel">
            <div class="log-context-bar">
                <span>@Model.SelectedAlertName</span>
                @if (Model.SelectedTimeframe != "all")
                {
                    <strong>@Model.SelectedTimeframe</strong>
                }
            </div>

            <div class="log-table-wrap">
                @if (!Model.Rows.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-journal-text"></i>
                        <h2>No log entries yet</h2>
                        <p>Create or trigger alerts to see delivery attempts and schedule skips here.</p>
                    </div>
                }
                else
                {
                    <table class="table log-table align-middle">
                        <thead>
                            <tr>
                                <th>Alert type</th>
                                <th>Market</th>
                                <th>Channel</th>
                                <th>Status</th>
                                <th class="text-end">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>
                                    <div class="log-rule">
                                        <i class="bi @(row.Status == "Sent" ? "bi-arrow-up-short text-success" : row.Status == "Failed" ? "bi-exclamation-triangle text-danger" : "bi-dash-circle text-muted")"></i>
                                        <div>
                                            <strong>@Alivert.Pages.App.LogModel.FormatRule(row.RuleType)</strong>
                                            @if (!string.IsNullOrWhiteSpace(row.Detail))
                                            {
                                                <small>@row.Detail</small>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span>@row.MarketType</span>
                                    <small>@Alivert.Pages.App.LogModel.FormatSymbol(row.Symbol) &middot; @row.Timeframe</small>
                                </td>
                                <td>@row.Channel</td>
                                <td>
                                    <span class="status-pill status-@row.Status.ToLowerInvariant()">@row.Status</span>
                                </td>
                                <td class="text-end muted">@row.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </section>

        <aside class="log-side-panel">
            <div class="timeframe-tabs">
                <a class="@(Model.SelectedTimeframe == "all" ? "active" : "")" href="@Model.AllTimeframesUrl()">All</a>
                @foreach (var timeframe in Model.Timeframes)
                {
                    <a class="@(Model.SelectedTimeframe == timeframe ? "active" : "")" href="@Model.TimeframeUrl(timeframe)">@timeframe</a>
                }
            </div>

            <div class="rule-filter-list">
                @if (!Model.RuleFilters.Any())
                {
                    <div class="rule-filter-row disabled">
                        <span class="rule-dot"></span>
                        <span>No alert rules yet</span>
                        <i class="bi bi-lock"></i>
                    </div>
                }
                else
                {
                    @foreach (var rule in Model.RuleFilters)
                    {
                        <div class="rule-filter-row @(rule.Enabled ? "enabled" : "disabled")">
                            <span class="rule-dot @rule.Tone"></span>
                            <span>@rule.Name</span>
                            <small>@rule.Count</small>
                        </div>
                    }
                }
            </div>

            <div class="log-upgrade-card">
                <span>Premium only</span>
                <a asp-page="/App/Billing">Upgrade</a>
                <p>Unlimited keeps every alert active without managing credit capacity.</p>
            </div>
        </aside>
    </div>
</div>
