@model Alivert.ViewComponents.AppPlanCtaViewComponent.AppPlanCtaModel

@if (Model.IsUnlimited)
{
    <a class="btn btn-sm btn-outline-secondary w-100 mt-2" asp-page="/App/Billing">
        <i class="bi bi-check2-circle me-1"></i>Subscription active
    </a>
}
else
{
    <a class="btn btn-sm btn-primary w-100 mt-2" asp-page="/App/Billing">Upgrade plan</a>
}
