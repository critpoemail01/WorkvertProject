@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alivert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/brand/alivert_favicon_32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="512x512" href="~/assets/brand/alivert_icon_512.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
<div class="app-shell">
    <aside class="app-sidebar">
        <a class="app-brand" asp-page="/Index">
            
            <img class="side-brand-logo" src="~/assets/brand/alivert_logo_clean_transparent.png"
                 srcset="~/assets/brand/alivert_logo_clean_transparent.png 1x, ~/assets/brand/alivert_logo_clean_transparent_2x.png 2x"
                 width="82" height="32" asp-append-version="true" alt="Alivert" />

        </a>

        <nav class="app-nav mt-4">
            <a class="app-nav-link" asp-page="/App/Dashboard">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </a>
            <a class="app-nav-link" asp-page="/App/Alerts/Index">
                <i class="bi bi-bell-fill"></i>
                <span>Alerts</span>
            </a>
            <a class="app-nav-link" asp-page="/Pricing">
                <i class="bi bi-credit-card-2-front-fill"></i>
                <span>Pricing</span>
            </a>
            <a class="app-nav-link" asp-page="/HowItWorks">
                <i class="bi bi-question-circle-fill"></i>
                <span>How it works</span>
            </a>
        </nav>

        <div class="app-sidebar-footer mt-auto">
            <div class="small text-muted">@User?.Identity?.Name</div>
            <div class="d-flex gap-2 mt-2">
                <a class="btn btn-sm btn-outline-secondary" asp-area="Identity" asp-page="/Account/Manage/Index">Account</a>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-light">Sign out</button>
                </form>
            </div>
        </div>
    </aside>

    <div class="app-main">
        <header class="app-topbar">
            <div class="d-flex align-items-center gap-2">
                <span class="badge badge-soft"><i class="bi bi-lightning-charge-fill me-1"></i>Alerts em background</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a class="btn btn-sm btn-primary" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i>New alert</a>
            </div>
        </header>

        <main class="app-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
