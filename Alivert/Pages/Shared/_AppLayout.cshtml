@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isActive = (string pagePath) => currentPath.Equals(pagePath, StringComparison.OrdinalIgnoreCase);
    var isActivePrefix = (string pagePath) => currentPath.StartsWith(pagePath, StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Promovert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/alivert_favicon.svg" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/brand/alivert_favicon_32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="512x512" href="~/assets/brand/alivert_icon_512_clean.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
<div class="app-shell">
    <aside class="app-sidebar">
        <a class="app-brand brand-lockup app-brand-lockup" asp-page="/Index" aria-label="Promovert home">
            <span class="brand-mark">
                <img src="~/assets/brand/alivert_brand_mark.svg" width="44" height="44" asp-append-version="true" alt="" />
            </span>
            <span class="brand-wordmark">
                <span class="brand-title">Promovert<sup>TM</sup></span>
                <span class="brand-subtitle">Online Campaign Engine</span>
            </span>
        </a>

        <nav class="app-nav mt-4" aria-label="App navigation">
            <div class="app-nav-section">Main menu</div>
            <a class="app-nav-link" asp-page="/Index">
                <i class="bi bi-arrow-left"></i>
                <span>Back to website</span>
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")" method="post">
                <button type="submit" class="app-nav-link app-nav-button">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Sign out</span>
                </button>
            </form>

            <div class="app-nav-section">Marketing</div>
            <a class="app-nav-link @(isActive("/App/Dashboard") ? "active" : "")" asp-page="/App/Dashboard">
                <i class="bi bi-bar-chart-fill"></i>
                <span>Dashboard</span>
            </a>
            <a class="app-nav-link @(isActivePrefix("/App/Planner") ? "active" : "")" asp-page="/App/Planner/Index">
                <i class="bi bi-stars"></i>
                <span>AI Planner</span>
            </a>
            <a class="app-nav-link @(isActivePrefix("/App/Alerts") ? "active" : "")" asp-page="/App/Alerts/Index">
                <i class="bi bi-bell-fill"></i>
                <span>Campaigns</span>
            </a>
            <a class="app-nav-link @(isActive("/App/Log") ? "active" : "")" asp-page="/App/Log">
                <i class="bi bi-clock-history"></i>
                <span>Activity log</span>
            </a>

            <div class="app-nav-section">Account & settings</div>
            <a class="app-nav-link @(isActivePrefix("/App/Account") ? "active" : "")" asp-page="/App/Account/Index">
                <i class="bi bi-person-fill"></i>
                <span>Personal details</span>
            </a>
            <a class="app-nav-link @(isActive("/App/Billing") ? "active" : "")" asp-page="/App/Billing">
                <i class="bi bi-credit-card-2-front"></i>
                <span>Subscription</span>
            </a>
            <a class="app-nav-link @(isActive("/App/Settings") ? "active" : "")" asp-page="/App/Settings">
                <i class="bi bi-broadcast-pin"></i>
                <span>Marketing channels</span>
            </a>
            <a class="app-nav-link @(isActive("/App/HelpDesk") ? "active" : "")" asp-page="/App/HelpDesk">
                <i class="bi bi-chat-left-text-fill"></i>
                <span>Help desk</span>
            </a>
        </nav>

        <div class="app-sidebar-footer mt-auto">
            <div class="small text-muted">@User?.Identity?.Name</div>
            @await Component.InvokeAsync("AppPlanCta")
        </div>
    </aside>

    <div class="app-main">
        <header class="app-topbar">
            <div class="app-topbar-status">
                <span class="app-status-badge"><i class="bi bi-lightning-charge-fill"></i>Campaign workspace active</span>
                @await Component.InvokeAsync("AppPlanBadge")
            </div>
            <div class="app-topbar-actions">
                <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Account/Index"><i class="bi bi-person-circle me-1"></i>My account</a>
                <a class="btn btn-sm btn-outline-secondary" asp-page="/App/Planner/Index"><i class="bi bi-stars me-1"></i> AI planner</a>
                <a class="btn btn-sm btn-primary app-new-alert-action" asp-page="/App/Alerts/Create"><i class="bi bi-plus-lg me-1"></i> New campaign</a>
            </div>
        </header>

        <main class="app-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
