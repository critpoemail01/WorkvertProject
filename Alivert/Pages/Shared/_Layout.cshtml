@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}
<!DOCTYPE html>
<html lang="en-US" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alivert</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/assets/brand/alivert_favicon_32.png" asp-append-version="true" />
    <link rel="apple-touch-icon" sizes="512x512" href="~/assets/brand/alivert_icon_512.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="csrf-token" content="@tokens.RequestToken" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg alivert-nav">
        <div class="container">
            <a class="navbar-brand fw-semibold brand-lockup" asp-page="/Index">
                
                <img class="brand-logo" src="~/assets/brand/alivert_icon_transparent.png"
                     srcset="~/assets/brand/alivert_logo_clean_transparent.png 1x, ~/assets/brand/alivert_logo_clean_transparent_2x.png 2x"
                     width="72" height="28" asp-append-version="true" alt="Alivert" />

            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-page="/Pricing">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/HowItWorks">How it works</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/News">News</a></li>

                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Dashboard">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/App/Alerts/Index">Alerts</a></li>
                    }
                </ul>

                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>

<main class="py-4">
    @RenderBody()
</main>

<footer class="footer">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <img class="brand-icon-sm" src="~/assets/brand/alivert_icon_transparent.png" srcset="~/assets/brand/alivert_icon_28.png 1x, ~/assets/brand/alivert_icon_56.png 2x" width="22" height="22" asp-append-version="true" alt="Alivert" />
                <span class="text-muted small">© @DateTime.Now.Year Alivert</span>
            </div>
            <div class="d-flex gap-3 small">
                <a class="footer-link" asp-page="/Pricing">Pricing</a>
                <a class="footer-link" asp-page="/HowItWorks">How it works</a>
                <a class="footer-link" asp-page="/About">About</a>
                <a class="footer-link" asp-page="/News">News</a>
            </div>
        </div>
        <div class="text-muted small mt-3">
            Monitoring tool. Not financial advice.
        </div>
    </div>
</footer>

<!-- Auth modal (login/register) -->
<div class="modal fade" id="authModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered auth-modal">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <div class="d-flex align-items-center gap-2">
          <img class="brand-logo" src="~/assets/brand/alivert_icon_transparent.png"
                     srcset="~/assets/brand/alivert_logo_clean_transparent.png 1x, ~/assets/brand/alivert_logo_clean_transparent_2x.png 2x"
                     width="62" height="24" asp-append-version="true" alt="Alivert" />
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body pt-2">
        <ul class="nav nav-pills auth-tabs" id="authTabs" role="tablist">
<li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-register" data-bs-toggle="pill" data-bs-target="#pane-register" type="button" role="tab">Get Started</button>
          </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-login" data-bs-toggle="pill" data-bs-target="#pane-login" type="button" role="tab">Sign In</button>
          </li>
          
</ul>

        <div class="tab-content mt-3">
          <div class="tab-pane fade show active" id="pane-login" role="tabpanel">
            <div id="loginError" class="alert alert-danger d-none" role="alert"></div>
            <form id="loginForm" class="auth-form" method="post" autocomplete="on">
              <input type="hidden" name="ReturnUrl" id="loginReturnUrl" />
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="Email" type="email" class="form-control" required />
              </div>
              <div class="mb-2">
                <label class="form-label">Password</label>
                <input name="Password" type="password" class="form-control" required />
              </div>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <label class="form-check">
                  <input class="form-check-input" type="checkbox" name="RememberMe" />
                  <span class="form-check-label">Remember me</span>
                </label>
                <a class="small" asp-area="Identity" asp-page="/Account/ForgotPassword">Forgot password?</a>
              </div>
              <button class="btn btn-primary w-100" type="submit">SIGN IN</button>
            </form>
          </div>

          <div class="tab-pane fade" id="pane-register" role="tabpanel">
            <div id="registerError" class="alert alert-danger d-none" role="alert"></div>
            <form id="registerForm" class="auth-form" method="post" autocomplete="on">
              <input type="hidden" name="ReturnUrl" id="registerReturnUrl" />
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="Email" type="email" class="form-control" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="Password" type="password" class="form-control" minlength="6" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Password confirmation</label>
                <input name="ConfirmPassword" type="password" class="form-control" minlength="6" required />
              </div>
              <div class="small text-muted mb-3">
                By creating an account, you agree to our terms and privacy policy.
              </div>
              <button class="btn btn-primary w-100" type="submit">CREATE ACCOUNT</button>
            </form>
            <div class="text-muted small mt-3">
              You start with <strong>5 free credits</strong>. 1 credit = 1 active alert.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/alivert-auth.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
