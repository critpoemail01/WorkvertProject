@page
@model Alivert.Pages.NewsModel
@{
    ViewData["Title"] = "News";
}

<section class="hero-section">
  <div class="container">
    <div class="surface hero-card p-4 p-lg-5">
      <div class="row align-items-center g-4">
        <div class="col-lg-7">
          <div class="hero-kicker mb-3">
            <i class="bi bi-newspaper"></i>
            <span>Updates</span>
          </div>
          <h1 class="hero-title display-5 fw-bold mb-3">News & product updates</h1>
          <p class="lead muted mb-0">
            Changelog-style posts about new features, fixes and what we’re building next.
          </p>
        </div>
        <div class="col-lg-5">
          <div class="surface-solid p-4">
            <div class="fw-semibold mb-2">Get updates</div>
            <div class="muted small mb-3">Follow along as we add channels, presets and shareable watchlists.</div>
            <div class="d-flex gap-2">
              <a class="btn btn-primary" asp-page="/Pricing">Plans</a>
              <button type="button" class="btn btn-outline-light" data-auth-open="register">Create account</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-4">
  <div class="container">
    <div class="row g-4">
      @foreach (var p in Model.Posts.OrderByDescending(x => x.DateUtc))
      {
        <div class="col-12">
          <div class="surface p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
              <div class="d-flex align-items-center gap-2">
                <span class="tag">@p.Tag</span>
                <span class="muted small">@p.DateUtc.ToString("yyyy-MM-dd")</span>
              </div>
            </div>
            <h2 class="h4 fw-semibold mt-3 mb-2">@p.Title</h2>
            <p class="muted mb-0">@p.Excerpt</p>
          </div>
        </div>
      }
    </div>
  </div>
</section>
